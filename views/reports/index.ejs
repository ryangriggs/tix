<%- include('../partials/head', { title: 'Reports' }) %>
<%- include('../partials/nav') %>

<main class="container">
  <div class="page-toolbar">
    <h1 class="page-title">Reports</h1>
  </div>

  <% if (user && user.role === 'admin') { %>
    <% if (enableBillableHours || enableLocation) { %>
    <div class="reports-grid">

      <% if (enableBillableHours) { %>
      <!-- Billing Report -->
      <div class="report-card">
        <div class="report-card-title">Billing Report</div>
        <p class="report-card-desc">Generate a report of billable hours logged in the specified date range, grouped by ticket. Based on reply date — hours added in a later period appear in that period's report.</p>
        <div class="form-row" style="gap:.75rem;flex-wrap:wrap;align-items:flex-end">
          <div class="form-group" style="flex:0 0 auto;margin-bottom:0">
            <label for="billing-from">Start Date</label>
            <input type="date" id="billing-from" class="form-input form-input-sm">
          </div>
          <div class="form-group" style="flex:0 0 auto;margin-bottom:0">
            <label for="billing-to">End Date</label>
            <input type="date" id="billing-to" class="form-input form-input-sm">
          </div>
          <% if (organizations && organizations.length) { %>
          <div class="form-group" style="flex:0 0 auto;margin-bottom:0">
            <label>Organization</label>
            <div class="filter-dropdown" id="billing-org-fdd" style="display:inline-block">
              <button type="button" id="billing-org-fdd-btn"
                      class="filter-dropdown-btn"
                      onclick="billingOrgToggle(event)">
                <span id="billing-org-fdd-label">Any org</span>
                <span class="filter-dropdown-arrow">▾</span>
              </button>
              <div class="filter-dropdown-panel" id="billing-org-fdd-panel">
                <label class="filter-dropdown-item">
                  <input type="checkbox" id="billing-org-cb-all" checked
                         onchange="billingOrgChange('all', this)"> Any org
                </label>
                <label class="filter-dropdown-item">
                  <input type="checkbox" class="billing-org-spec-cb" data-val="unassigned"
                         onchange="billingOrgChange('unassigned', this)"> Not assigned
                </label>
                <% if (organizations.length) { %><hr class="filter-dropdown-sep"><% } %>
                <% for (const o of organizations) { %>
                  <label class="filter-dropdown-item">
                    <input type="checkbox" class="billing-org-spec-cb" data-val="<%= o.id %>"
                           onchange="billingOrgChange(<%= o.id %>, this)"> <%= o.name %>
                  </label>
                <% } %>
              </div>
            </div>
          </div>
          <% } %>
          <div class="form-group" style="flex:0 0 auto;margin-bottom:0">
            <button type="button" class="btn btn-primary" onclick="runBillingReport()">Run</button>
          </div>
        </div>
        <p class="form-hint" id="billing-error" style="color:var(--danger,#dc2626);display:none"></p>
      </div>
      <% } %>

      <% if (enableLocation) { %>
      <!-- Travel Report -->
      <div class="report-card">
        <div class="report-card-title">Travel Report</div>
        <p class="report-card-desc">Generate a report of locations visited, grouped by organization and location, for the specified date range. Based on reply dates.</p>
        <div class="form-row" style="gap:.75rem;flex-wrap:wrap">
          <div class="form-group" style="flex:0 0 auto;margin-bottom:0">
            <label for="travel-from">Start Date</label>
            <input type="date" id="travel-from" class="form-input form-input-sm">
          </div>
          <div class="form-group" style="flex:0 0 auto;margin-bottom:0">
            <label for="travel-to">End Date</label>
            <input type="date" id="travel-to" class="form-input form-input-sm">
          </div>
          <div class="form-group" style="flex:0 0 auto;margin-bottom:0;padding-top:1.5rem">
            <button type="button" class="btn btn-primary" onclick="runTravelReport()">Run</button>
          </div>
        </div>
        <p class="form-hint" id="travel-error" style="color:var(--danger,#dc2626);display:none"></p>
      </div>
      <% } %>

    </div>
    <% } else { %>
      <p class="text-muted">No reports are enabled. Turn on Billable Hours or Location Tracking in Settings.</p>
    <% } %>
  <% } else { %>
    <p class="text-muted">No reports are available for your account.</p>
  <% } %>
</main>

<script>
(function() {
  // ---- Org dropdown for billing report ----
  var _billingOrgs = <%- JSON.stringify((organizations || []).map(o => ({ id: o.id, name: o.name }))).replace(/</g, '\\u003C') %>;

  function _billingOrgLabel() {
    var checked = [].slice.call(document.querySelectorAll('.billing-org-spec-cb:checked')).map(function(cb) { return cb.dataset.val; });
    if (!checked.length) return 'Any org';
    var parts = [];
    if (checked.indexOf('unassigned') >= 0) parts.push('Not assigned');
    checked.filter(function(v) { return v !== 'unassigned'; }).forEach(function(id) {
      var o = _billingOrgs.find(function(x) { return String(x.id) === id; });
      if (o) parts.push(o.name);
    });
    if (!parts.length) return 'Any org';
    return parts.length === 1 ? parts[0] : parts[0] + ' +' + (parts.length - 1);
  }

  window.billingOrgToggle = function(e) {
    var panel = document.getElementById('billing-org-fdd-panel');
    if (!panel) return;
    panel.classList.toggle('fdd-open');
    e.stopPropagation();
  };

  window.billingOrgChange = function(val, el) {
    if (val === 'all') {
      document.querySelectorAll('.billing-org-spec-cb').forEach(function(cb) { cb.checked = false; });
    } else {
      document.getElementById('billing-org-cb-all').checked = false;
    }
    var lbl = document.getElementById('billing-org-fdd-label');
    if (lbl) lbl.textContent = _billingOrgLabel();
    var btn = document.getElementById('billing-org-fdd-btn');
    var checked = [].slice.call(document.querySelectorAll('.billing-org-spec-cb:checked'));
    if (btn) btn.classList.toggle('fdd-active', checked.length > 0);
  };

  document.addEventListener('click', function(e) {
    var panel = document.getElementById('billing-org-fdd-panel');
    if (panel && !e.target.closest('#billing-org-fdd')) panel.classList.remove('fdd-open');
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      var panel = document.getElementById('billing-org-fdd-panel');
      if (panel) panel.classList.remove('fdd-open');
    }
  });
})();

function runBillingReport() {
  var from = document.getElementById('billing-from').value;
  var to   = document.getElementById('billing-to').value;
  var err  = document.getElementById('billing-error');
  err.style.display = 'none';
  if (!from || !to) { err.textContent = 'Please select both a start and end date.'; err.style.display = ''; return; }
  if (from > to)    { err.textContent = 'Start date must be on or before the end date.'; err.style.display = ''; return; }
  var checked = [].slice.call(document.querySelectorAll('.billing-org-spec-cb:checked')).map(function(cb) { return cb.dataset.val; });
  var url = '/reports/billing.csv?from=' + encodeURIComponent(from) + '&to=' + encodeURIComponent(to);
  if (checked.length) url += '&org=' + encodeURIComponent(checked.join(','));
  window.location = url;
}

function runTravelReport() {
  var from = document.getElementById('travel-from').value;
  var to   = document.getElementById('travel-to').value;
  var err  = document.getElementById('travel-error');
  err.style.display = 'none';
  if (!from || !to) { err.textContent = 'Please select both a start and end date.'; err.style.display = ''; return; }
  if (from > to)    { err.textContent = 'Start date must be on or before the end date.'; err.style.display = ''; return; }
  window.location = '/reports/travel.csv?from=' + encodeURIComponent(from) + '&to=' + encodeURIComponent(to);
}
</script>

<%- include('../partials/foot') %>
