<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= attachment.original_name %> — Annotate</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: system-ui, Arial, sans-serif;
      font-size: 13px;
      background: #1e293b;
      color: #f1f5f9;
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow: hidden;
    }

    /* ── Toolbar ─────────────────────────────────────── */
    #toolbar {
      flex-shrink: 0;
      background: #1e293b;
      border-bottom: 1px solid #334155;
      user-select: none;
    }

    .tb-row {
      display: flex;
      align-items: center;
      gap: .5rem;
      padding: .4rem .75rem;
      flex-wrap: wrap;
    }

    .tb-row-header {
      background: #0f172a;
      padding: .35rem .75rem;
      gap: .75rem;
    }

    .tb-back {
      color: #94a3b8;
      font-size: .8rem;
      white-space: nowrap;
    }
    .tb-back:hover { color: #f1f5f9; }

    .tb-filename {
      flex: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      font-size: .8rem;
      color: #cbd5e1;
    }

    .tb-sep {
      width: 1px;
      height: 22px;
      background: #334155;
      flex-shrink: 0;
    }

    .tb-tool {
      background: none;
      border: 1px solid transparent;
      border-radius: 4px;
      color: #94a3b8;
      cursor: pointer;
      padding: 3px 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 30px;
      height: 28px;
    }
    .tb-tool:hover  { background: #334155; color: #f1f5f9; }
    .tb-tool.active { background: #2563eb; border-color: #3b82f6; color: #fff; }
    #delete-btn:not(:disabled) { color: #f87171; }
    #delete-btn:not(:disabled):hover { background: #7f1d1d; color: #fca5a5; border-color: #991b1b; }

    .tb-btn {
      background: #334155;
      border: 1px solid #475569;
      border-radius: 4px;
      color: #f1f5f9;
      cursor: pointer;
      padding: 3px 10px;
      font-size: 12px;
      height: 28px;
      white-space: nowrap;
    }
    .tb-btn:hover    { background: #475569; }
    .tb-btn:disabled { opacity: .5; cursor: default; }
    .tb-btn-primary  { background: #2563eb; border-color: #3b82f6; }
    .tb-btn-primary:hover { background: #1d4ed8; }

    .color-group {
      display: flex;
      align-items: center;
      gap: .3rem;
    }
    .color-label { font-size: 11px; color: #94a3b8; white-space: nowrap; }

    input[type="color"] {
      width: 26px; height: 24px;
      border: 1px solid #475569; border-radius: 3px;
      padding: 1px; background: #0f172a; cursor: pointer;
    }
    input[type="range"] {
      width: 64px; height: 4px;
      accent-color: #3b82f6; cursor: pointer;
    }

    #font-controls {
      display: none;
      align-items: center;
      gap: .3rem;
    }
    #font-family {
      background: #0f172a;
      border: 1px solid #475569;
      border-radius: 3px;
      color: #f1f5f9;
      font-size: 12px;
      padding: 2px 4px;
      height: 26px;
    }

    #status-msg {
      font-size: 11px;
      color: #4ade80;
      transition: opacity .4s;
      white-space: nowrap;
      margin-left: auto;
    }

    /* ── Canvas area ──────────────────────────────────── */
    #canvas-wrap {
      flex: 1;
      overflow: auto;
      background: #475569;
    }
    #canvas-wrap.hand-mode  { cursor: grab; }
    #canvas-wrap.hand-grab  { cursor: grabbing !important; }

    #pages-container {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 1.5rem;
      gap: 1.5rem;
      transform-origin: 0 0;
    }

    .page-block {
      flex-shrink: 0;
      line-height: 0;
    }
    .page-block .canvas-container {
      box-shadow: 0 4px 20px rgba(0,0,0,.5);
    }

    /* ── Loading overlay ──────────────────────────────── */
    #loading-overlay {
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, .65);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 9999;
    }
    .spinner {
      width: 44px; height: 44px;
      border: 4px solid rgba(255,255,255,.2);
      border-top-color: #60a5fa;
      border-radius: 50%;
      animation: spin .75s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Print ────────────────────────────────────────── */
    @media print {
      #toolbar, #loading-overlay { display: none !important; }
      body { background: #fff; overflow: visible; height: auto; }
      #canvas-wrap { overflow: visible; background: none; display: block; }
      #pages-container { padding: 0; gap: 0; zoom: 1 !important; display: block; }
      .page-block { page-break-after: always; margin: 0; }
      .page-block:last-child { page-break-after: auto; }
      .page-block .canvas-container { box-shadow: none !important; }
      .canvas-container canvas { max-width: 100%; }
    }
  </style>
</head>
<body>

<div id="loading-overlay"><div class="spinner"></div></div>

<div id="toolbar">
  <div class="tb-row tb-row-header">
    <button class="tb-back tb-btn" style="background:none;border:none;cursor:pointer;padding:0" onclick="confirmClose()">
      ← #<%= formatTicketId(ticket.id) %>
    </button>
    <span class="tb-filename"><%= attachment.original_name %></span>
    <button id="save-btn" class="tb-btn tb-btn-primary">Save and close</button>
    <button id="print-btn" class="tb-btn">Print</button>
  </div>

  <div class="tb-row">
    <button class="tb-tool active" data-tool="select" title="Select / Move (V)">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M4 0l16 12-7 2-4 9z"/></svg>
    </button>
    <button class="tb-tool" data-tool="hand" title="Pan / Zoom (H)">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 11V6a2 2 0 0 0-4 0v5"/><path d="M14 10V4a2 2 0 0 0-4 0v6"/>
        <path d="M10 10.5V6a2 2 0 0 0-4 0v8"/>
        <path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/>
      </svg>
    </button>
    <button class="tb-tool" data-tool="line" title="Line (L)">
      <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" fill="none"><line x1="3" y1="21" x2="21" y2="3"/></svg>
    </button>
    <button class="tb-tool" data-tool="pencil" title="Freehand (P)">
      <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
    </button>
    <button class="tb-tool" data-tool="ellipse" title="Ellipse (E)">
      <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" fill="none"><ellipse cx="12" cy="12" rx="10" ry="7"/></svg>
    </button>
    <button class="tb-tool" data-tool="rect" title="Rectangle (R)">
      <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" fill="none"><rect x="3" y="5" width="18" height="14" rx="1"/></svg>
    </button>
    <button class="tb-tool" data-tool="text" title="Text (T)">
      <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>
    </button>
    <button id="delete-btn" class="tb-tool" title="Delete selected (Del)" disabled>
      <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
    </button>

    <div class="tb-sep"></div>

    <div class="color-group">
      <span class="color-label">Stroke</span>
      <input type="color"  id="stroke-color"   value="#000000" title="Stroke colour">
      <input type="range"  id="stroke-opacity" min="0" max="100" value="100" title="Stroke opacity">
    </div>

    <div class="tb-sep"></div>

    <div class="color-group">
      <span class="color-label">Fill</span>
      <input type="color"  id="fill-color"   value="#ffff00" title="Fill colour">
      <input type="range"  id="fill-opacity" min="0" max="100" value="50" title="Fill opacity">
    </div>

    <div class="tb-sep"></div>

    <div id="font-controls">
      <span class="color-label">Font</span>
      <select id="font-family">
        <option value="Arial">Arial</option>
        <option value="Georgia">Georgia</option>
        <option value="Courier New">Courier New</option>
        <option value="Times New Roman">Times New Roman</option>
        <option value="Verdana">Verdana</option>
      </select>
      <div class="tb-sep"></div>
    </div>

    <span id="status-msg"></span>
  </div>
</div>

<!-- Scroll container → zoom container → pages injected here -->
<div id="canvas-wrap">
  <div id="pages-container"></div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.0/fabric.min.js" crossorigin="anonymous"></script>
<% if (isPdf) { %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js" crossorigin="anonymous"></script>
<script>pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';</script>
<% } %>

<script>
'use strict';

const TICKET_ID   = '<%= ticket.id %>';
const STORED_NAME = '<%= attachment.stored_name %>';
const CSRF        = '<%= csrfToken %>';
const IS_PDF      = <%- isPdf ? 'true' : 'false' %>;
const FILE_URL    = '/tickets/attachments/<%= attachment.stored_name %>';

// ── DOM refs ───────────────────────────────────────────────
const canvasWrap     = document.getElementById('canvas-wrap');
const pagesContainer = document.getElementById('pages-container');

// ── State ──────────────────────────────────────────────────
const pages = [];         // { fc: fabric.Canvas, pageNum }
let activeCanvas = null;
let currentTool  = 'select';
let isDrawing    = false;
let drawStart    = null;
let activeShape  = null;
let isDirty      = false;
let pdfDoc       = null;
let loadCount    = 0;
let zoomLevel    = 1.0;
let handPan      = null;
let handPinch    = null;

let strokeHex     = '#000000';
let strokeOpacity = 1.0;
let fillHex       = '#ffff00';
let fillOpacity   = 0.5;
let fontFamily    = 'Arial';
const STROKE_WIDTH = 2;

// ── Loading overlay ────────────────────────────────────────
const overlay = document.getElementById('loading-overlay');
function showLoading() { loadCount++; overlay.style.display = 'flex'; }
function hideLoading() { if (--loadCount <= 0) { loadCount = 0; overlay.style.display = 'none'; } }

// ── Status bar ─────────────────────────────────────────────
const statusEl = document.getElementById('status-msg');
let statusTimer;
function setStatus(msg, isError) {
  statusEl.textContent = msg;
  statusEl.style.color = isError ? '#f87171' : '#4ade80';
  statusEl.style.opacity = '1';
  clearTimeout(statusTimer);
  statusTimer = setTimeout(() => { statusEl.style.opacity = '0'; }, 3000);
}

// ── Close with dirty check ─────────────────────────────────
function confirmClose() {
  if (isDirty && !confirm('You have unsaved changes. Close without saving?')) return;
  window.close();
}

window.addEventListener('beforeunload', e => {
  if (isDirty) { e.preventDefault(); e.returnValue = ''; }
});

// ── Colour helpers ─────────────────────────────────────────
function hexToRgba(hex, opacity) {
  const r = parseInt(hex.slice(1,3),16);
  const g = parseInt(hex.slice(3,5),16);
  const b = parseInt(hex.slice(5,7),16);
  return `rgba(${r},${g},${b},${opacity.toFixed(3)})`;
}
function rgbaToHex(c) {
  if (!c || c === 'transparent') return '#000000';
  const m = String(c).match(/rgba?\(\s*(\d+)[,\s]+(\d+)[,\s]+(\d+)/);
  if (!m) return c.startsWith('#') ? c.slice(0,7) : '#000000';
  return '#' + [m[1],m[2],m[3]].map(n => (+n).toString(16).padStart(2,'0')).join('');
}
function rgbaToAlpha(c) {
  if (!c || c === 'transparent') return 0;
  const m = String(c).match(/rgba?\(\s*\d+[,\s]+\d+[,\s]+\d+[,\s]+([0-9.]+)/);
  return m ? parseFloat(m[1]) : 1;
}
function getStroke() { return hexToRgba(strokeHex, strokeOpacity); }
function getFill()   { return hexToRgba(fillHex,   fillOpacity);   }

// ── Hand / pan / zoom mode ─────────────────────────────────
function applyZoom() {
  pagesContainer.style.zoom = zoomLevel;
}

function zoomAround(newZoom, cx, cy) {
  const sl = canvasWrap.scrollLeft, st = canvasWrap.scrollTop;
  const ratio = newZoom / zoomLevel;
  zoomLevel = newZoom;
  applyZoom();
  canvasWrap.scrollLeft = (sl + cx) * ratio - cx;
  canvasWrap.scrollTop  = (st + cy) * ratio - cy;
}

function onTouchStartHand(e) {
  e.preventDefault();
  if (e.touches.length === 1) {
    handPan = { x: e.touches[0].clientX, y: e.touches[0].clientY,
                scrollLeft: canvasWrap.scrollLeft, scrollTop: canvasWrap.scrollTop };
    handPinch = null;
  } else if (e.touches.length >= 2) {
    const t1 = e.touches[0], t2 = e.touches[1];
    handPinch = { startDist: Math.hypot(t1.clientX - t2.clientX, t1.clientY - t2.clientY),
                  startZoom: zoomLevel };
    handPan = null;
  }
}

function onTouchMoveHand(e) {
  e.preventDefault();
  if (e.touches.length === 1 && handPan) {
    canvasWrap.scrollLeft = handPan.scrollLeft - (e.touches[0].clientX - handPan.x);
    canvasWrap.scrollTop  = handPan.scrollTop  - (e.touches[0].clientY - handPan.y);
  } else if (e.touches.length >= 2 && handPinch) {
    const t1 = e.touches[0], t2 = e.touches[1];
    const dist    = Math.hypot(t1.clientX - t2.clientX, t1.clientY - t2.clientY);
    const newZoom = Math.min(4, Math.max(0.25, handPinch.startZoom * (dist / handPinch.startDist)));
    const rect    = canvasWrap.getBoundingClientRect();
    zoomAround(newZoom,
      (t1.clientX + t2.clientX) / 2 - rect.left,
      (t1.clientY + t2.clientY) / 2 - rect.top);
  }
}

function onTouchEndHand(e) {
  if (e.touches.length < 2) handPinch = null;
  if (e.touches.length === 0) handPan = null;
}

function onMouseDownHand(e) {
  if (e.button !== 0) return;
  handPan = { x: e.clientX, y: e.clientY,
               scrollLeft: canvasWrap.scrollLeft, scrollTop: canvasWrap.scrollTop };
  canvasWrap.classList.add('hand-grab');
  e.preventDefault();
}

function onMouseMoveHand(e) {
  if (!handPan) return;
  canvasWrap.scrollLeft = handPan.scrollLeft - (e.clientX - handPan.x);
  canvasWrap.scrollTop  = handPan.scrollTop  - (e.clientY - handPan.y);
}

function onMouseUpHand() {
  handPan = null;
  canvasWrap.classList.remove('hand-grab');
}

function onWheelHand(e) {
  if (!e.ctrlKey) return;
  e.preventDefault();
  const rect    = canvasWrap.getBoundingClientRect();
  const delta   = e.deltaY > 0 ? 0.9 : 1.1;
  zoomAround(Math.min(4, Math.max(0.25, zoomLevel * delta)),
    e.clientX - rect.left, e.clientY - rect.top);
}

function activateHandMode() {
  document.querySelectorAll('.page-block').forEach(b => b.style.pointerEvents = 'none');
  canvasWrap.addEventListener('touchstart', onTouchStartHand, { passive: false });
  canvasWrap.addEventListener('touchmove',  onTouchMoveHand,  { passive: false });
  canvasWrap.addEventListener('touchend',   onTouchEndHand);
  canvasWrap.addEventListener('mousedown',  onMouseDownHand);
  canvasWrap.addEventListener('wheel',      onWheelHand, { passive: false });
  document.addEventListener('mousemove', onMouseMoveHand);
  document.addEventListener('mouseup',   onMouseUpHand);
  canvasWrap.classList.add('hand-mode');
}

function deactivateHandMode() {
  document.querySelectorAll('.page-block').forEach(b => b.style.pointerEvents = '');
  canvasWrap.removeEventListener('touchstart', onTouchStartHand);
  canvasWrap.removeEventListener('touchmove',  onTouchMoveHand);
  canvasWrap.removeEventListener('touchend',   onTouchEndHand);
  canvasWrap.removeEventListener('mousedown',  onMouseDownHand);
  canvasWrap.removeEventListener('wheel',      onWheelHand);
  document.removeEventListener('mousemove', onMouseMoveHand);
  document.removeEventListener('mouseup',   onMouseUpHand);
  handPan = null; handPinch = null;
  canvasWrap.classList.remove('hand-mode', 'hand-grab');
}

// ── Tool management ────────────────────────────────────────
function setTool(tool) {
  if (currentTool === 'hand') deactivateHandMode();
  currentTool = tool;
  for (const { fc } of pages) {
    fc.isDrawingMode       = (tool === 'pencil');
    fc.selection           = (tool === 'select');
    fc.defaultCursor       = (tool === 'select') ? 'default' : 'crosshair';
    fc.allowTouchScrolling = (tool === 'select');
    fc.forEachObject(obj => {
      obj.selectable = (tool === 'select');
      obj.evented    = (tool === 'select');
    });
    if (tool === 'pencil') {
      fc.freeDrawingBrush.color = getStroke();
      fc.freeDrawingBrush.width = STROKE_WIDTH;
    }
    fc.renderAll();
  }
  if (tool === 'hand') activateHandMode();
  document.querySelectorAll('.tb-tool').forEach(b =>
    b.classList.toggle('active', b.dataset.tool === tool));
  document.getElementById('font-controls').style.display =
    (tool === 'text') ? 'flex' : 'none';
}

// ── Per-canvas event setup ─────────────────────────────────
function setupCanvasEvents(fc) {
  fc.on('mouse:down', function(opt) {
    activeCanvas = fc;
    if (currentTool === 'select' || currentTool === 'pencil') return;
    if (opt.target && currentTool !== 'text') return;
    const ptr = fc.getPointer(opt.e);

    if (currentTool === 'text') {
      const tb = new fabric.Textbox('Text', {
        left: ptr.x, top: ptr.y, width: 180,
        fill: getStroke(), fontFamily, fontSize: 18, editable: true,
      });
      fc.add(tb);
      fc.setActiveObject(tb);
      tb.enterEditing();
      tb.selectAll();
      markDirty();
      return;
    }

    isDrawing = true;
    drawStart = { x: ptr.x, y: ptr.y };
    const stroke = getStroke();
    const fill   = (currentTool === 'line') ? 'transparent' : getFill();

    if (currentTool === 'line') {
      activeShape = new fabric.Line([ptr.x, ptr.y, ptr.x, ptr.y],
        { stroke, strokeWidth: STROKE_WIDTH, selectable: false, evented: false });
    } else if (currentTool === 'ellipse') {
      activeShape = new fabric.Ellipse({
        left: ptr.x, top: ptr.y, rx: 0, ry: 0,
        stroke, strokeWidth: STROKE_WIDTH, fill, selectable: false, evented: false });
    } else if (currentTool === 'rect') {
      activeShape = new fabric.Rect({
        left: ptr.x, top: ptr.y, width: 0, height: 0,
        stroke, strokeWidth: STROKE_WIDTH, fill, selectable: false, evented: false });
    }
    if (activeShape) fc.add(activeShape);
  });

  fc.on('mouse:move', function(opt) {
    if (!isDrawing || !activeShape) return;
    const ptr = fc.getPointer(opt.e);
    if (currentTool === 'line') {
      activeShape.set({ x2: ptr.x, y2: ptr.y });
    } else if (currentTool === 'ellipse') {
      const dx = ptr.x - drawStart.x, dy = ptr.y - drawStart.y;
      activeShape.set({
        rx: Math.abs(dx) / 2, ry: Math.abs(dy) / 2,
        left: Math.min(drawStart.x, ptr.x), top: Math.min(drawStart.y, ptr.y),
      });
    } else if (currentTool === 'rect') {
      activeShape.set({
        width:  Math.abs(ptr.x - drawStart.x),
        height: Math.abs(ptr.y - drawStart.y),
        left:   Math.min(drawStart.x, ptr.x),
        top:    Math.min(drawStart.y, ptr.y),
      });
    }
    fc.renderAll();
  });

  fc.on('mouse:up', function() {
    if (!isDrawing || !activeShape) return;
    isDrawing = false;
    activeShape.set({ selectable: true, evented: true });
    fc.setActiveObject(activeShape);
    activeShape = null;
    markDirty();
    setTool('select');
    fc.requestRenderAll();
  });

  fc.on('selection:created', () => { activeCanvas = fc; syncToolbarToSelection(fc); document.getElementById('delete-btn').disabled = false; });
  fc.on('selection:updated', () => { activeCanvas = fc; syncToolbarToSelection(fc); document.getElementById('delete-btn').disabled = false; });
  fc.on('selection:cleared', () => {
    document.getElementById('font-controls').style.display =
      (currentTool === 'text') ? 'flex' : 'none';
    document.getElementById('delete-btn').disabled = true;
  });
  fc.on('object:modified', markDirty);
  fc.on('object:removed',  markDirty);
  fc.on('path:created',    markDirty);
}

// ── Selection → sync toolbar ───────────────────────────────
function syncToolbarToSelection(fc) {
  const obj = fc.getActiveObject();
  if (!obj) return;
  const stroke = obj.stroke;
  if (stroke && stroke !== 'transparent') {
    document.getElementById('stroke-color').value = rgbaToHex(stroke);
    document.getElementById('stroke-opacity').value = Math.round(rgbaToAlpha(stroke) * 100);
    strokeHex     = rgbaToHex(stroke);
    strokeOpacity = rgbaToAlpha(stroke);
  }
  const fill = obj.fill;
  if (fill && fill !== 'transparent') {
    document.getElementById('fill-color').value = rgbaToHex(fill);
    document.getElementById('fill-opacity').value = Math.round(rgbaToAlpha(fill) * 100);
    fillHex     = rgbaToHex(fill);
    fillOpacity = rgbaToAlpha(fill);
  }
  const isText = obj.type === 'textbox' || obj.type === 'i-text';
  document.getElementById('font-controls').style.display = isText ? 'flex' : 'none';
  if (isText && obj.fontFamily)
    document.getElementById('font-family').value = obj.fontFamily;
}

// ── Dirty tracking ─────────────────────────────────────────
function markDirty() { isDirty = true; }

// ── Keyboard shortcuts ─────────────────────────────────────
document.addEventListener('keydown', e => {
  const editing = activeCanvas?.getActiveObject()?.isEditing;
  if (editing) return;
  if (e.key === 'v' || e.key === 'V') { setTool('select'); return; }
  if (e.key === 'h' || e.key === 'H') { setTool('hand');   return; }
  if (e.key === 'l' || e.key === 'L') { setTool('line');   return; }
  if (e.key === 'p' || e.key === 'P') { setTool('pencil'); return; }
  if (e.key === 'e' || e.key === 'E') { setTool('ellipse');return; }
  if (e.key === 'r' || e.key === 'R') { setTool('rect');   return; }
  if (e.key === 't' || e.key === 'T') { setTool('text');   return; }
  if (e.key === 'Escape') {
    activeCanvas?.discardActiveObject();
    setTool('select');
    activeCanvas?.renderAll();
  }
  if (e.key === 'Delete' || e.key === 'Backspace') { deleteSelected(); }
});

// ── Delete selected (single or multi-select) ───────────────
function deleteSelected() {
  if (!activeCanvas) return;
  const objs = activeCanvas.getActiveObjects();
  if (!objs.length) return;
  activeCanvas.discardActiveObject();
  objs.forEach(obj => activeCanvas.remove(obj));
  activeCanvas.renderAll();
  markDirty();
}

// ── Toolbar wiring ─────────────────────────────────────────
document.querySelectorAll('.tb-tool[data-tool]').forEach(btn =>
  btn.addEventListener('click', () => setTool(btn.dataset.tool)));

document.getElementById('delete-btn').addEventListener('click', deleteSelected);

const strokeColorEl   = document.getElementById('stroke-color');
const strokeOpacityEl = document.getElementById('stroke-opacity');
const fillColorEl     = document.getElementById('fill-color');
const fillOpacityEl   = document.getElementById('fill-opacity');

function applyStroke() {
  strokeHex     = strokeColorEl.value;
  strokeOpacity = strokeOpacityEl.value / 100;
  const rgba = getStroke();
  const obj  = activeCanvas?.getActiveObject();
  if (obj) { obj.set({ stroke: rgba }); activeCanvas.renderAll(); markDirty(); }
  for (const { fc } of pages) {
    if (fc.isDrawingMode) fc.freeDrawingBrush.color = rgba;
  }
}
function applyFill() {
  fillHex     = fillColorEl.value;
  fillOpacity = fillOpacityEl.value / 100;
  const rgba = getFill();
  const obj  = activeCanvas?.getActiveObject();
  if (obj && obj.type !== 'line' && obj.type !== 'path') {
    obj.set({ fill: rgba }); activeCanvas.renderAll(); markDirty();
  }
}
strokeColorEl.addEventListener('input', applyStroke);
strokeOpacityEl.addEventListener('input', applyStroke);
fillColorEl.addEventListener('input', applyFill);
fillOpacityEl.addEventListener('input', applyFill);

document.getElementById('font-family').addEventListener('change', function() {
  fontFamily = this.value;
  const obj = activeCanvas?.getActiveObject();
  if (obj && (obj.type === 'textbox' || obj.type === 'i-text')) {
    obj.set({ fontFamily }); activeCanvas.renderAll(); markDirty();
  }
});

// ── Save all pages ─────────────────────────────────────────
async function saveAllAnnotations() {
  for (const { fc, pageNum } of pages) {
    const json = fc.toJSON();
    json.canvasWidth  = fc.getWidth();
    json.canvasHeight = fc.getHeight();
    delete json.backgroundImage;
    const resp = await fetch(
      `/tickets/${TICKET_ID}/attachments/${STORED_NAME}/annotations/${pageNum}`,
      { method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF },
        body: JSON.stringify(json),
        credentials: 'include' }
    );
    if (!resp.ok) throw new Error('Server returned ' + resp.status + ' for page ' + pageNum);
  }
}

document.getElementById('save-btn').addEventListener('click', async () => {
  const btn = document.getElementById('save-btn');
  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    await saveAllAnnotations();
    isDirty = false;
    window.close();
  } catch (err) {
    setStatus('Save failed: ' + err.message, true);
    btn.disabled = false; btn.textContent = 'Save and close';
  }
});

document.getElementById('print-btn').addEventListener('click', () => window.print());

// ── Load annotations for one page ─────────────────────────
async function loadAnnotations(pageNum, fc) {
  try {
    const resp = await fetch(
      `/tickets/${TICKET_ID}/attachments/${STORED_NAME}/annotations/${pageNum}`,
      { credentials: 'include' });
    if (!resp.ok) {
      const body = await resp.json().catch(() => ({}));
      throw new Error(body.error || `Server error ${resp.status}`);
    }
    const data = await resp.json();

    if (!data || !Array.isArray(data.objects) || data.objects.length === 0) {
      isDirty = false;
      hideLoading();
      return;
    }

    const scaleX = data.canvasWidth  ? fc.getWidth()  / data.canvasWidth  : 1;
    const scaleY = data.canvasHeight ? fc.getHeight() / data.canvasHeight : 1;
    const savedBg    = fc.backgroundImage;
    const jsonToLoad = { ...data, backgroundImage: null };

    fc.loadFromJSON(jsonToLoad, () => {
      if (savedBg) fc.backgroundImage = savedBg;
      if (scaleX !== 1 || scaleY !== 1) {
        fc.forEachObject(obj => {
          obj.scaleX = (obj.scaleX || 1) * scaleX;
          obj.scaleY = (obj.scaleY || 1) * scaleY;
          obj.left   = (obj.left   || 0) * scaleX;
          obj.top    = (obj.top    || 0) * scaleY;
          obj.setCoords();
        });
      }
      fc.forEachObject(obj => { obj.selectable = true; obj.evented = true; });
      isDirty = false;
      fc.renderAll();
      hideLoading();
    });
  } catch (err) {
    hideLoading();
    setStatus('Could not load annotations: ' + err.message, true);
  }
}

// ── Create a page block with a new Fabric canvas ───────────
function createPageCanvas(pageNum) {
  const block    = document.createElement('div');
  block.className   = 'page-block';
  block.dataset.page = pageNum;
  const canvasEl = document.createElement('canvas');
  block.appendChild(canvasEl);
  pagesContainer.appendChild(block);   // ← into the zoom container

  const fc = new fabric.Canvas(canvasEl, {
    selection:              true,
    preserveObjectStacking: true,
    enableRetinaScaling:    false,
    allowTouchScrolling:    true,       // default; updated by setTool()
  });

  // Replace Fabric's getPointer entirely.
  // getBoundingClientRect() already reflects current scroll + CSS zoom position,
  // so (clientX - rect.left) / zoomLevel gives exact canvas-pixel coordinates
  // without any scroll-compensation arithmetic.
  fc.getPointer = function(e) {
    const touch   = (e.touches && e.touches[0]) || (e.changedTouches && e.changedTouches[0]);
    const clientX = touch ? touch.clientX : (e.clientX || 0);
    const clientY = touch ? touch.clientY : (e.clientY || 0);
    const rect    = this.upperCanvasEl.getBoundingClientRect();
    // Convert viewport px → canvas px using the live rendered scale,
    // which already reflects CSS zoom + scroll without any separate correction.
    const scaleX  = this.upperCanvasEl.width  / (rect.width  || 1);
    const scaleY  = this.upperCanvasEl.height / (rect.height || 1);
    return {
      x: (clientX - rect.left) * scaleX,
      y: (clientY - rect.top)  * scaleY,
    };
  };

  setupCanvasEvents(fc);
  pages.push({ fc, pageNum });
  return fc;
}

// ── Render one PDF page ────────────────────────────────────
async function renderPdfPage(pageNum) {
  showLoading();
  try {
    const page     = await pdfDoc.getPage(pageNum);
    const viewport = page.getViewport({ scale: 1.5 });

    const off = document.createElement('canvas');
    off.width  = viewport.width;
    off.height = viewport.height;
    await page.render({ canvasContext: off.getContext('2d'), viewport }).promise;

    const fc = createPageCanvas(pageNum);
    fc.setWidth(viewport.width);
    fc.setHeight(viewport.height);

    fabric.Image.fromURL(off.toDataURL(), img => {
      fc.setBackgroundImage(img, async () => {
        fc.renderAll();
        await loadAnnotations(pageNum, fc);
      });
    });
  } catch (err) {
    hideLoading();
    setStatus(`Failed to render page ${pageNum}: ` + err.message, true);
  }
}

// ── Load all content ───────────────────────────────────────
async function loadBackground() {
  showLoading();
  try {
    const resp = await fetch(FILE_URL, { credentials: 'include' });
    if (!resp.ok) throw new Error('HTTP ' + resp.status);

    if (IS_PDF) {
      const buf = await resp.arrayBuffer();
      pdfDoc = await pdfjsLib.getDocument({ data: buf }).promise;
      hideLoading(); // balance loadBackground's showLoading; each renderPdfPage adds its own
      for (let p = 1; p <= pdfDoc.numPages; p++) {
        await renderPdfPage(p);
      }
    } else {
      const blob    = await resp.blob();
      const blobUrl = URL.createObjectURL(blob);
      await new Promise((resolve, reject) => {
        fabric.Image.fromURL(blobUrl, img => {
          if (!img) return reject(new Error('Image failed to load'));
          const fc = createPageCanvas(1);
          fc.setWidth(img.width || img.getScaledWidth());
          fc.setHeight(img.height || img.getScaledHeight());
          fc.setBackgroundImage(img, () => { fc.renderAll(); resolve(); });
        });
      });
      await loadAnnotations(1, pages[0].fc);
    }
  } catch (err) {
    hideLoading();
    setStatus('Failed to load file: ' + err.message, true);
  }
}

// ── Boot ──────────────────────────────────────────────────
loadBackground();
setTool('select');
</script>
</body>
</html>
