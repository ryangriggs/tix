<%- include('../partials/head', { title: 'Organizations' }) %>
<%- include('../partials/nav') %>

<main class="container">
  <h1 class="page-title">Organizations</h1>

  <% if (message) { %>
    <div class="alert alert-info"><%= message %></div>
  <% } %>

  <% if (!organizations.length) { %>
    <p style="color:#6b7280">No organizations yet. They are created automatically when assigned to users or tickets.</p>
  <% } else { %>
    <table class="data-table">
      <thead>
        <tr>
          <th>Name</th>
          <th style="width:1%">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% for (const o of organizations) { %>
          <tr>
            <td><%= o.name %></td>
            <td style="white-space:nowrap;display:flex;gap:.4rem">
              <button class="btn btn-sm btn-secondary"
                      onclick="openOrgDialog(<%= o.id %>, <%= JSON.stringify(o.name) %>)">Edit</button>
              <form method="POST" action="/admin/organizations/<%= o.id %>/delete" style="display:inline"
                    onsubmit="return confirm('Delete organization «<%= o.name %>»?\nUsers and tickets will lose this org assignment.')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
              </form>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  <% } %>
</main>

<!-- Org Edit Dialog -->
<dialog id="org-dialog" class="modal-dialog">
  <div class="modal-header">
    <h2 id="org-dialog-title" style="font-size:1.1rem;font-weight:600;margin:0"></h2>
    <button class="btn-icon" onclick="document.getElementById('org-dialog').close()" title="Close">✕</button>
  </div>

  <div class="modal-body">
    <!-- Rename -->
    <div class="form-group">
      <label style="font-size:.85rem;font-weight:600">Organization Name</label>
      <div style="display:flex;gap:.5rem">
        <input type="text" id="org-name-input" class="form-input" style="flex:1">
        <button class="btn btn-secondary btn-sm" onclick="saveOrgName()">Save</button>
      </div>
      <p id="org-name-error" class="form-hint" style="color:var(--danger);display:none"></p>
    </div>

    <!-- Locations list -->
    <div style="margin-top:1.25rem">
      <h3 style="font-size:.85rem;font-weight:600;margin-bottom:.6rem">Locations</h3>
      <div id="org-locations-list"></div>

      <!-- Add location form -->
      <div style="display:flex;gap:.5rem;align-items:flex-end;margin-top:.75rem;flex-wrap:wrap">
        <div style="flex:1 1 160px">
          <label style="font-size:.8rem;color:var(--text-muted)">Name</label>
          <input type="text" id="new-loc-name" class="form-input form-input-sm" placeholder="Location name">
        </div>
        <div style="flex:0 0 100px">
          <label style="font-size:.8rem;color:var(--text-muted)">Distance (mi)</label>
          <input type="number" id="new-loc-dist" class="form-input form-input-sm"
                 min="0" step="0.1" placeholder="0" style="width:100%">
        </div>
        <button class="btn btn-primary btn-sm" onclick="addLocation()">Add</button>
      </div>
      <p id="loc-add-error" class="form-hint" style="color:var(--danger);display:none"></p>
    </div>

    <!-- Urgent ticket notifications -->
    <div style="margin-top:1.5rem;border-top:1px solid var(--border);padding-top:1.25rem">
      <h3 style="font-size:.85rem;font-weight:600;margin-bottom:.35rem">Urgent Ticket Notifications</h3>
      <p style="font-size:.8rem;color:var(--text-muted);margin-bottom:.6rem">
        Override the global list for tickets belonging to this organization. Leave empty to use the global default.
      </p>
      <div id="org-urgent-wrap"
           style="display:flex;flex-wrap:wrap;gap:.35rem;align-items:center;padding:.4rem .5rem;border:1px solid var(--border);border-radius:var(--radius);min-height:2.5rem;background:var(--surface);cursor:text"
           onclick="document.getElementById('org-urgent-input').focus()">
        <input type="text" id="org-urgent-input" autocomplete="off"
               placeholder="Search users to add…"
               style="border:none;outline:none;background:none;flex:1;min-width:120px;font-size:.85rem;padding:.1rem 0;color:var(--text)">
      </div>
      <div style="display:flex;gap:.5rem;margin-top:.6rem;align-items:center">
        <button class="btn btn-secondary btn-sm" onclick="saveOrgUrgentNotify()">Save</button>
        <span id="org-urgent-status" style="font-size:.8rem;color:var(--text-muted)"></span>
      </div>
    </div>
  </div>
</dialog>

<script>
let _orgDialogId  = null;
let _csrfToken    = '<%= csrfToken %>';
const _allUsers   = <%- JSON.stringify(allUsers.map(u => ({ id: u.id, label: u.name ? `${u.name} (${u.email})` : u.email }))).replace(/</g, '\\u003C') %>;

function openOrgDialog(orgId, orgName) {
  _orgDialogId = orgId;
  document.getElementById('org-dialog-title').textContent = 'Edit: ' + orgName;
  document.getElementById('org-name-input').value = orgName;
  document.getElementById('org-name-error').style.display = 'none';
  document.getElementById('loc-add-error').style.display  = 'none';
  document.getElementById('org-urgent-status').textContent = '';
  document.getElementById('new-loc-name').value = '';
  document.getElementById('new-loc-dist').value = '';
  loadLocations();
  document.getElementById('org-dialog').showModal();
}

async function loadLocations() {
  const res  = await fetch('/admin/organizations/' + _orgDialogId + '/json');
  const data = await res.json();
  renderLocations(data.locations);
  renderUrgentSelect(data.org.urgent_notify_user_ids || '');
}

// ---- Org urgent-notify pill selector ----
const _orgUrgentSelected = new Set();

function renderUrgentSelect(currentIds) {
  const wrap  = document.getElementById('org-urgent-wrap');
  const input = document.getElementById('org-urgent-input');
  if (!wrap || !input) return;
  // Remove all existing pills (leave the input in place)
  wrap.querySelectorAll('[data-urgent-user-id]').forEach(el => el.remove());
  _orgUrgentSelected.clear();
  const ids = String(currentIds || '').split(',').map(Number).filter(Boolean);
  ids.forEach(id => {
    const u = _allUsers.find(u => u.id === id);
    if (u) _addOrgUrgentPill(id, u.label);
  });
}

function _addOrgUrgentPill(id, label) {
  id = Number(id);
  if (_orgUrgentSelected.has(id)) return;
  _orgUrgentSelected.add(id);
  const wrap  = document.getElementById('org-urgent-wrap');
  const input = document.getElementById('org-urgent-input');
  const pill  = document.createElement('span');
  pill.dataset.urgentUserId = id;
  pill.style.cssText = 'display:inline-flex;align-items:center;gap:.2rem;background:#eff6ff;border:1px solid #bfdbfe;border-radius:999px;padding:.15rem .5rem .15rem .65rem;font-size:.8rem;white-space:nowrap';
  pill.innerHTML = `<span>${escHtml(label)}</span><button type="button" title="Remove" style="background:none;border:none;cursor:pointer;font-size:1.1rem;line-height:1;color:#64748b;padding:0 .15rem">×</button>`;
  pill.querySelector('button').addEventListener('click', () => {
    _orgUrgentSelected.delete(id);
    pill.remove();
  });
  wrap.insertBefore(pill, input);
}

async function saveOrgUrgentNotify() {
  const statusEl = document.getElementById('org-urgent-status');
  statusEl.textContent = 'Saving…';
  const body = new URLSearchParams({ _csrf: _csrfToken });
  _orgUrgentSelected.forEach(id => body.append('urgent_notify_user_ids', id));
  const res  = await fetch('/admin/organizations/' + _orgDialogId + '/urgent-notify', { method: 'POST', body });
  const data = await res.json();
  statusEl.textContent = data.ok ? 'Saved.' : (data.error || 'Error');
  setTimeout(() => { statusEl.textContent = ''; }, 2500);
}

// Init autocomplete for the org urgent-notify input (runs once on page load)
if (typeof createAutocomplete === 'function') {
  createAutocomplete(document.getElementById('org-urgent-input'), {
    fetchUrl: q => `/api/users/search?q=${encodeURIComponent(q)}`,
    formatItem: item => {
      const name = item.name ? `<strong>${escHtml(item.name)}</strong> ` : '';
      const org  = item.org  ? ` <em style="color:#6b7280">[${escHtml(item.org)}]</em>` : '';
      return `${name}(${escHtml(item.email)})${org}`;
    },
    onSelect: item => {
      _addOrgUrgentPill(item.id, item.name ? `${item.name} (${item.email})` : item.email);
      document.getElementById('org-urgent-input').value = '';
    },
  });
}

function renderLocations(locs) {
  const el = document.getElementById('org-locations-list');
  if (!locs.length) {
    el.innerHTML = '<p style="font-size:.85rem;color:var(--text-muted)">No locations yet.</p>';
    return;
  }
  el.innerHTML = locs.map(l => `
    <div class="loc-row" id="loc-row-${l.id}" style="display:flex;align-items:center;gap:.5rem;padding:.35rem 0;border-bottom:1px solid var(--border);flex-wrap:wrap">
      <input type="text" value="${escHtml(l.name)}" data-id="${l.id}" data-field="name"
             class="form-input form-input-sm loc-name-input" style="flex:1 1 140px">
      <input type="number" value="${l.distance_miles}" data-id="${l.id}" data-field="dist"
             class="form-input form-input-sm loc-dist-input" min="0" step="0.1" style="width:80px"
             title="Distance (mi)">
      <button class="btn btn-sm btn-secondary" onclick="saveLocation(${l.id})">Save</button>
      <button class="btn btn-sm btn-danger"    onclick="deleteLocation(${l.id})">Delete</button>
    </div>
  `).join('');
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

async function saveOrgName() {
  const name = document.getElementById('org-name-input').value.trim();
  const errEl = document.getElementById('org-name-error');
  if (!name) { errEl.textContent = 'Name is required.'; errEl.style.display = ''; return; }
  errEl.style.display = 'none';
  const body = new URLSearchParams({ _csrf: _csrfToken, name });
  const res  = await fetch('/admin/organizations/' + _orgDialogId + '/rename', { method: 'POST', body });
  if (res.redirected || res.ok) {
    document.getElementById('org-dialog-title').textContent = 'Edit: ' + name;
    // Update the row in the table
    const rows = document.querySelectorAll('.data-table tbody td:first-child');
    rows.forEach(td => { if (td.textContent.trim() === document.getElementById('org-dialog-title').textContent.replace('Edit: ','')) td.textContent = name; });
    location.reload();
  }
}

async function addLocation() {
  const name  = document.getElementById('new-loc-name').value.trim();
  const dist  = parseFloat(document.getElementById('new-loc-dist').value) || 0;
  const errEl = document.getElementById('loc-add-error');
  if (!name) { errEl.textContent = 'Name is required.'; errEl.style.display = ''; return; }
  errEl.style.display = 'none';
  const body = new URLSearchParams({ _csrf: _csrfToken, name, distance_miles: dist });
  const res  = await fetch('/admin/organizations/' + _orgDialogId + '/locations/add', { method: 'POST', body });
  const data = await res.json();
  if (data.error) { errEl.textContent = data.error; errEl.style.display = ''; return; }
  document.getElementById('new-loc-name').value = '';
  document.getElementById('new-loc-dist').value = '';
  loadLocations();
}

async function saveLocation(locId) {
  const row  = document.getElementById('loc-row-' + locId);
  const name = row.querySelector('.loc-name-input').value.trim();
  const dist = parseFloat(row.querySelector('.loc-dist-input').value) || 0;
  const body = new URLSearchParams({ _csrf: _csrfToken, name, distance_miles: dist });
  const res  = await fetch('/admin/organizations/' + _orgDialogId + '/locations/' + locId + '/update', { method: 'POST', body });
  const data = await res.json();
  if (data.error) { alert(data.error); return; }
  loadLocations();
}

async function deleteLocation(locId) {
  if (!confirm('Delete this location?')) return;
  const body = new URLSearchParams({ _csrf: _csrfToken });
  const res  = await fetch('/admin/organizations/' + _orgDialogId + '/locations/' + locId + '/delete', { method: 'POST', body });
  const data = await res.json();
  if (data.error) { alert(data.error); return; }
  loadLocations();
}
</script>

<%- include('../partials/foot') %>
