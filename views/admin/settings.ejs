<%- include('../partials/head', { title: 'Settings' }) %>
<%- include('../partials/nav') %>

<main class="container container-narrow">
  <h1 class="page-title">Settings</h1>

  <% if (message) { %>
    <div class="alert alert-info"><%= message %></div>
  <% } %>

  <div class="card">
    <form method="POST" action="/admin/settings" class="ticket-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="form-group">
        <label for="default_assignee_email">Default assignee email</label>
        <input
          type="email"
          id="default_assignee_email"
          name="default_assignee_email"
          value="<%= defaultAssignee %>"
          placeholder="assignee@example.com"
          class="form-input"
        >
        <p class="form-hint">
          All tickets created via inbound email or web (by others) will be assigned to this person as an owner.
          Leave blank to disable automatic assignment.
        </p>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save settings</button>
      </div>
    </form>
  </div>
</main>

<%- include('../partials/foot') %>
