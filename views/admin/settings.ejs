<%- include('../partials/head', { title: 'Settings' }) %>
<%- include('../partials/nav') %>

<aside class="settings-sidenav" id="settings-sidenav" aria-label="Settings sections">
  <div class="settings-sidenav-title">Sections</div>
  <div style="padding:.4rem .6rem .5rem">
    <button type="button" class="btn btn-primary" style="width:100%;font-size:.78rem;padding:.3rem .5rem"
            onclick="document.querySelector('.ticket-form').requestSubmit()">Save</button>
  </div>
  <a href="#s-site"          class="settings-sidenav-link">Site &amp; Identity</a>
  <a href="#s-email"         class="settings-sidenav-link">Email Transport</a>
  <a href="#s-notifications" class="settings-sidenav-link">Notifications</a>
  <a href="#s-security"      class="settings-sidenav-link">Security</a>
  <a href="#s-uploads"       class="settings-sidenav-link">Uploads</a>
  <a href="#s-features"      class="settings-sidenav-link">Features</a>
  <div class="settings-sidenav-group">System</div>
  <a href="#s-updates"        class="settings-sidenav-link sub">Updates</a>
  <a href="#s-backups"        class="settings-sidenav-link sub">Backups</a>
  <a href="#s-infrastructure" class="settings-sidenav-link sub">Infrastructure</a>
  <a href="#s-server-stats"   class="settings-sidenav-link sub">Server Stats</a>
  <a href="#s-browser-cache"  class="settings-sidenav-link sub">Browser Cache</a>
</aside>

<main class="container container-narrow">
  <h1 class="page-title">Settings</h1>

  <% if (message) { %>
    <div class="alert alert-info"><%= message %></div>
  <% } %>

  <!-- Mobile Table of Contents -->
  <details class="settings-mobile-toc">
    <summary>Jump to section</summary>
    <nav class="settings-mobile-toc-nav">
      <a href="#s-site">Site &amp; Identity</a>
      <a href="#s-email">Email Transport</a>
      <a href="#s-notifications">Notifications &amp; Reminders</a>
      <a href="#s-security">Security</a>
      <a href="#s-uploads">Uploads</a>
      <a href="#s-features">Features</a>
      <span class="toc-group-label">System</span>
      <a href="#s-updates"        class="toc-sub">Updates</a>
      <a href="#s-backups"        class="toc-sub">Backups</a>
      <a href="#s-infrastructure" class="toc-sub">Infrastructure</a>
      <a href="#s-server-stats"   class="toc-sub">Server Stats</a>
      <a href="#s-browser-cache"  class="toc-sub">Browser Cache</a>
    </nav>
  </details>

  <form method="POST" action="/admin/settings" class="ticket-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <!-- ── Site & Identity ──────────────────────────────────── -->
    <div class="card" id="s-site" style="margin-bottom:1.5rem">
      <h2 class="settings-section-title">Site &amp; Identity</h2>

      <div class="form-group">
        <label for="site_name">Site name</label>
        <input type="text" id="site_name" name="site_name"
               value="<%= s.site_name || '' %>" placeholder="✅ Tix" class="form-input">
        <p class="form-hint">Displayed in the navigation bar and on login pages.</p>
      </div>

      <div class="form-group">
        <label for="app_url">Application URL</label>
        <input type="url" id="app_url" name="app_url"
               value="<%= s.app_url || '' %>" placeholder="https://tickets.example.com" class="form-input">
        <p class="form-hint">Public base URL used in outbound email links. No trailing slash.</p>
      </div>

      <div class="form-group">
        <label for="ticket_prefix">Ticket ID prefix <span class="optional">(optional)</span></label>
        <input type="text" id="ticket_prefix" name="ticket_prefix"
               value="<%= s.ticket_prefix || '' %>" placeholder="TKT-" class="form-input" style="width:10rem">
        <p class="form-hint">Prepended to ticket numbers in subject lines, e.g. <code>TKT-42</code>. Leave blank for plain numbers.</p>
      </div>

      <hr class="settings-hr">
      <h3 class="settings-sub-title">Email Addresses</h3>

      <div class="form-group">
        <label for="ticket_email">Ticket email address</label>
        <input type="email" id="ticket_email" name="ticket_email"
               value="<%= s.ticket_email || '' %>" placeholder="tickets@example.com" class="form-input">
        <p class="form-hint">Inbound address for new tickets and replies. The SMTP server's domain filter reflects this at startup — changes here require a restart to affect inbound routing.</p>
      </div>

      <div class="form-group">
        <label for="ticket_silent_email">Silent ticket email <span class="optional">(optional)</span></label>
        <input type="email" id="ticket_silent_email" name="ticket_silent_email"
               value="<%= s.ticket_silent_email || '' %>" placeholder="noreply@example.com" class="form-input">
        <p class="form-hint">If set, emails to this address create tickets silently (no confirmation sent to sender).</p>
      </div>

      <div class="form-group">
        <label for="mail_from_name">Mail from name</label>
        <input type="text" id="mail_from_name" name="mail_from_name"
               value="<%= s.mail_from_name || '' %>" placeholder="Tix" class="form-input">
        <p class="form-hint">Display name used in the From header of outbound emails.</p>
      </div>

      <hr class="settings-hr">
      <h3 class="settings-sub-title">Users</h3>

      <div class="form-group">
        <label for="admin_email">Admin email <span class="optional">(optional)</span></label>
        <input type="email" id="admin_email" name="admin_email"
               value="<%= s.admin_email || '' %>" placeholder="admin@example.com" class="form-input">
        <p class="form-hint">First user created with this email is automatically given the admin role.</p>
      </div>

      <div class="form-group">
        <label for="default_assignee_email">Default assignee email <span class="optional">(optional)</span></label>
        <input type="email" id="default_assignee_email" name="default_assignee_email"
               value="<%= s.default_assignee_email || '' %>" placeholder="assignee@example.com" class="form-input">
        <p class="form-hint">Tickets created via inbound email or web (by others) are automatically assigned to this person.</p>
      </div>
    </div>

    <!-- ── Email Transport ──────────────────────────────────── -->
    <div class="card" id="s-email" style="margin-bottom:1.5rem">
      <h2 class="settings-section-title">Email Transport</h2>

      <div class="form-group">
        <label for="mail_transport">Transport</label>
        <select id="mail_transport" name="mail_transport" class="form-select" style="width:auto">
          <option value="mailgun" <%= (s.mail_transport||'mailgun')==='mailgun' ? 'selected':'' %>>Mailgun</option>
          <option value="smtp"    <%= s.mail_transport==='smtp'    ? 'selected':'' %>>SMTP Relay</option>
          <option value="gmail"   <%= s.mail_transport==='gmail'   ? 'selected':'' %>>Gmail API</option>
          <option value="resend"  <%= s.mail_transport==='resend'  ? 'selected':'' %>>Resend</option>
        </select>
      </div>

      <div class="form-group">
        <label for="mail_queue_delay_ms">Queue delay (ms)</label>
        <input type="number" id="mail_queue_delay_ms" name="mail_queue_delay_ms"
               value="<%= s.mail_queue_delay_ms || '0' %>" min="0" max="5000" step="50"
               class="form-input form-input-sm" style="width:7rem">
        <p class="form-hint">Delay between outgoing emails. Set to <strong>600</strong> when using Resend to stay under their 2&nbsp;msg/sec limit. 0&nbsp;= no delay.</p>
      </div>

      <!-- Mailgun -->
      <div class="settings-transport-section" id="transport-mailgun">
        <h3 class="settings-sub-title">Mailgun</h3>
        <div class="form-group">
          <label for="mailgun_api_key">API key</label>
          <input type="password" id="mailgun_api_key" name="mailgun_api_key"
                 value="<%= s.mailgun_api_key || '' %>" autocomplete="new-password" class="form-input">
        </div>
        <div class="form-group">
          <label for="mailgun_domain">Domain</label>
          <input type="text" id="mailgun_domain" name="mailgun_domain"
                 value="<%= s.mailgun_domain || '' %>" placeholder="mg.example.com" class="form-input">
        </div>
      </div>

      <!-- SMTP Relay -->
      <div class="settings-transport-section" id="transport-smtp">
        <h3 class="settings-sub-title">SMTP Relay</h3>
        <div class="form-group">
          <label for="smtp_relay_host">Host</label>
          <input type="text" id="smtp_relay_host" name="smtp_relay_host"
                 value="<%= s.smtp_relay_host || '' %>" placeholder="smtp.example.com" class="form-input">
        </div>
        <div class="form-row" style="gap:.75rem;flex-wrap:wrap">
          <div class="form-group" style="flex:0 0 auto">
            <label for="smtp_relay_port">Port</label>
            <input type="number" id="smtp_relay_port" name="smtp_relay_port"
                   value="<%= s.smtp_relay_port || '587' %>" min="1" max="65535" step="1"
                   class="form-input form-input-sm" style="width:6rem">
          </div>
        </div>
        <div class="form-group">
          <label for="smtp_relay_user">Username</label>
          <input type="text" id="smtp_relay_user" name="smtp_relay_user"
                 value="<%= s.smtp_relay_user || '' %>" class="form-input">
        </div>
        <div class="form-group">
          <label for="smtp_relay_pass">Password</label>
          <input type="password" id="smtp_relay_pass" name="smtp_relay_pass"
                 value="<%= s.smtp_relay_pass || '' %>" autocomplete="new-password" class="form-input">
        </div>
      </div>

      <!-- Resend -->
      <div class="settings-transport-section" id="transport-resend">
        <h3 class="settings-sub-title">Resend</h3>
        <p class="form-hint">Get your API key at <a href="https://resend.com/api-keys" target="_blank" rel="noopener">resend.com/api-keys</a>. Add and verify your sending domain at <a href="https://resend.com/domains" target="_blank" rel="noopener">resend.com/domains</a>.</p>
        <div class="form-group">
          <label for="resend_api_key">API key</label>
          <input type="password" id="resend_api_key" name="resend_api_key"
                 value="<%= s.resend_api_key || '' %>" autocomplete="new-password" class="form-input"
                 placeholder="re_xxxxxxxxxxxxxxxxxxxx">
        </div>
      </div>

      <!-- Gmail API -->
      <div class="settings-transport-section" id="transport-gmail">
        <h3 class="settings-sub-title">Gmail API</h3>
        <p class="form-hint">Run <code>npm run gmail-setup</code> to obtain a refresh token.</p>
        <div class="form-group">
          <label for="gmail_client_id">Client ID</label>
          <input type="text" id="gmail_client_id" name="gmail_client_id"
                 value="<%= s.gmail_client_id || '' %>" class="form-input">
        </div>
        <div class="form-group">
          <label for="gmail_client_secret">Client secret</label>
          <input type="password" id="gmail_client_secret" name="gmail_client_secret"
                 value="<%= s.gmail_client_secret || '' %>" autocomplete="new-password" class="form-input">
        </div>
        <div class="form-group">
          <label for="gmail_refresh_token">Refresh token</label>
          <input type="password" id="gmail_refresh_token" name="gmail_refresh_token"
                 value="<%= s.gmail_refresh_token || '' %>" autocomplete="new-password" class="form-input">
        </div>
        <div class="form-group">
          <label for="gmail_user">Gmail user (email)</label>
          <input type="email" id="gmail_user" name="gmail_user"
                 value="<%= s.gmail_user || '' %>" placeholder="you@gmail.com" class="form-input">
        </div>
      </div>

      <hr class="settings-hr">
      <h3 class="settings-sub-title">Inbound Email Security</h3>
      <p class="form-hint" style="margin-bottom:.75rem">
        SPF and DKIM results are always logged to the Email Log for monitoring.
        Enable enforcement only after confirming no legitimate senders are failing — check the log first.
        Only hard failures are rejected; softfail, neutral, and unsigned emails are never blocked.
      </p>

      <div class="form-group">
        <label class="checkbox-label">
          <input type="checkbox" name="mailgun_webhook_enabled" value="true"
                 <%= s.mailgun_webhook_enabled === 'true' ? 'checked' : '' %>>
          Enable Mailgun inbound webhook (<code>POST /inbound/mailgun</code>)
        </label>
        <p class="form-hint">Only needed when using Mailgun's inbound routing. Disable if not in use.</p>
      </div>

      <div class="form-group">
        <label class="checkbox-label">
          <input type="checkbox" name="enforce_spf" value="true"
                 <%= s.enforce_spf === 'true' ? 'checked' : '' %>>
          Reject emails that hard-fail SPF (<code>fail</code> only — not softfail or none)
        </label>
      </div>
      <div class="form-group">
        <label class="checkbox-label">
          <input type="checkbox" name="enforce_dkim" value="true"
                 <%= s.enforce_dkim === 'true' ? 'checked' : '' %>>
          Reject emails with an invalid DKIM signature (<code>fail</code> only — unsigned emails still pass)
        </label>
      </div>
    </div>

    <!-- ── Notifications & Reminders ────────────────────────── -->
    <div class="card" id="s-notifications" style="margin-bottom:1.5rem">
      <h2 class="settings-section-title">Notifications &amp; Reminders</h2>

      <div class="form-group">
        <label class="checkbox-label">
          <input type="checkbox" name="notify_email_submitter" value="1"
                 <%= s.notify_email_submitter !== 'false' ? 'checked' : '' %>>
          Notify email submitter on new ticket creation
        </label>
        <p class="form-hint">Send a confirmation email to the sender when their inbound email creates a new ticket.</p>
      </div>

      <div class="form-group">
        <label class="checkbox-label">
          <input type="checkbox" name="notify_email_status_change" value="1"
                 <%= s.notify_email_status_change !== 'false' ? 'checked' : '' %>>
          Notify parties on ticket status changes
        </label>
        <p class="form-hint">Send an email to all ticket parties when the status is changed via the sidebar. Comments that include a status change always send a notification.</p>
      </div>

      <hr class="settings-hr">
      <h3 class="settings-sub-title">Urgent Notifications</h3>
      <p class="form-hint" style="margin-bottom:1rem">
        These users are emailed immediately when any ticket is created as Urgent or has its priority changed to Urgent.
        Per-organization overrides can be set on the <a href="/admin/organizations">Organizations</a> page.
      </p>
      <div class="form-group">
        <label>Notify these users (global default)</label>
        <div id="urgent-notify-wrap"
             style="display:flex;flex-wrap:wrap;gap:.35rem;align-items:center;padding:.4rem .5rem;border:1px solid var(--border);border-radius:var(--radius);min-height:2.5rem;background:var(--surface);cursor:text"
             onclick="document.getElementById('urgent-notify-input').focus()">
          <input type="text" id="urgent-notify-input" autocomplete="off"
                 placeholder="Search users to add…"
                 style="border:none;outline:none;background:none;flex:1;min-width:140px;font-size:.875rem;padding:.1rem 0;color:var(--text)">
        </div>
        <div id="urgent-notify-hiddens"></div>
        <p class="form-hint">Leave empty to disable global urgent notifications.</p>
      </div>

      <hr class="settings-hr">
      <h3 class="settings-sub-title">Due-Date Reminders</h3>
      <div class="form-row" style="gap:.75rem;flex-wrap:wrap">
        <div style="flex:0 0 auto">
          <label for="reminder_count" style="font-size:.85rem;font-weight:normal">Number of reminders</label>
          <input type="number" id="reminder_count" name="reminder_count"
                 value="<%= s.reminder_count || '1' %>" min="0" step="1"
                 class="form-input form-input-sm" style="width:5rem">
        </div>
        <div style="flex:0 0 auto">
          <label for="reminder_frequency_hours" style="font-size:.85rem;font-weight:normal">Frequency (hours apart)</label>
          <input type="number" id="reminder_frequency_hours" name="reminder_frequency_hours"
                 value="<%= s.reminder_frequency_hours || '24' %>" min="0.5" step="0.5"
                 class="form-input form-input-sm" style="width:6rem">
        </div>
      </div>
      <p class="form-hint">
        Reminders are sent only to ticket owners with admin or technician roles.
        Example: 3 reminders, 24 hours apart → sent 72h, 48h, and 24h before the due date.
        Past reminder slots are skipped if the due date was set less than <em>count × frequency</em> hours in advance.
        Set to 0 reminders to disable.
      </p>

      <hr class="settings-hr">
      <h3 class="settings-sub-title">Inactivity Reminders</h3>
      <p class="form-hint" style="margin-bottom:1rem">
        Send a reminder email to ticket owners when an open ticket has had no activity for the specified time.
        Set to 0 to disable for that priority. Reminders repeat each time the period elapses until the ticket is updated or closed.
        Only tickets with <strong>open</strong> status and at least one <strong>owner</strong> are notified.
      </p>
      <div class="form-row" style="gap:1.5rem;flex-wrap:wrap">
        <div class="form-group" style="flex:0 0 auto">
          <label class="form-label">Urgent (hours, 0 = off)</label>
          <input type="number" name="inactivity_hours_urgent" min="0" step="0.5"
                 class="form-input" style="width:8rem"
                 value="<%= s.inactivity_hours_urgent || '0' %>">
        </div>
        <div class="form-group" style="flex:0 0 auto">
          <label class="form-label">High (hours, 0 = off)</label>
          <input type="number" name="inactivity_hours_high" min="0" step="0.5"
                 class="form-input" style="width:8rem"
                 value="<%= s.inactivity_hours_high || '0' %>">
        </div>
        <div class="form-group" style="flex:0 0 auto">
          <label class="form-label">Medium (hours, 0 = off)</label>
          <input type="number" name="inactivity_hours_medium" min="0" step="0.5"
                 class="form-input" style="width:8rem"
                 value="<%= s.inactivity_hours_medium || '0' %>">
        </div>
        <div class="form-group" style="flex:0 0 auto">
          <label class="form-label">Low (hours, 0 = off)</label>
          <input type="number" name="inactivity_hours_low" min="0" step="0.5"
                 class="form-input" style="width:8rem"
                 value="<%= s.inactivity_hours_low || '0' %>">
        </div>
      </div>
    </div>

    <!-- ── Security ──────────────────────────────────────────── -->
    <div class="card" id="s-security" style="margin-bottom:1.5rem">
      <h2 class="settings-section-title">Security</h2>

      <div class="form-group">
        <label for="jwt_secret">JWT secret</label>
        <input type="password" id="jwt_secret" name="jwt_secret"
               value="<%= s.jwt_secret || '' %>" autocomplete="new-password" class="form-input">
        <p class="form-hint">Signs session cookies. Changing this logs out all users. Use a long random string in production.</p>
      </div>

      <div class="form-group">
        <label>Secure session cookie</label>
        <label class="checkbox-label">
          <input type="checkbox" name="secure_session" value="1"
                 <%= s.secure_session === 'true' ? 'checked' : '' %>>
          Require HTTPS for session cookie (enable in production behind TLS)
        </label>
      </div>

      <hr class="settings-hr">
      <h3 class="settings-sub-title">OTP &amp; Login Rate Limits</h3>

      <div class="form-row" style="gap:.75rem;flex-wrap:wrap">
        <div class="form-group" style="flex:0 0 auto">
          <label for="otp_max_tries">OTP max tries</label>
          <input type="number" id="otp_max_tries" name="otp_max_tries"
                 value="<%= s.otp_max_tries || '5' %>" min="1" step="1"
                 class="form-input form-input-sm" style="width:5rem">
        </div>
        <div class="form-group" style="flex:0 0 auto">
          <label for="otp_lockout_seconds">OTP lockout (seconds)</label>
          <input type="number" id="otp_lockout_seconds" name="otp_lockout_seconds"
                 value="<%= s.otp_lockout_seconds || '300' %>" min="0" step="1"
                 class="form-input form-input-sm" style="width:6rem">
        </div>
      </div>
      <p class="form-hint">After this many failed OTP attempts, the account is locked for the specified number of seconds.</p>

      <div class="form-row" style="gap:.75rem;flex-wrap:wrap;margin-top:.75rem">
        <div class="form-group" style="flex:0 0 auto">
          <label for="login_rate_limit_ip">Login attempts per IP / hour</label>
          <input type="number" id="login_rate_limit_ip" name="login_rate_limit_ip"
                 value="<%= s.login_rate_limit_ip || '20' %>" min="1" step="1"
                 class="form-input form-input-sm" style="width:6rem">
        </div>
        <div class="form-group" style="flex:0 0 auto">
          <label for="login_rate_limit_email">Login attempts per email / minute</label>
          <input type="number" id="login_rate_limit_email" name="login_rate_limit_email"
                 value="<%= s.login_rate_limit_email || '5' %>" min="1" step="1"
                 class="form-input form-input-sm" style="width:6rem">
        </div>
      </div>
      <p class="form-hint">Limits magic link requests to prevent email bombing. Resets on server restart.</p>

      <hr class="settings-hr">
      <h3 class="settings-sub-title">CAPTCHA (Cloudflare Turnstile)</h3>

      <div class="form-group">
        <label class="checkbox-label">
          <input type="checkbox" name="turnstile_enabled" value="1"
                 <%= s.turnstile_enabled === 'true' ? 'checked' : '' %>>
          Require Turnstile verification when an unrecognised email address attempts to sign in for the first time
        </label>
        <p class="form-hint">Does not affect existing accounts. New users see an intermediate verification screen before any account is created or email is sent.</p>
      </div>

      <div class="form-group">
        <label for="turnstile_site_key">Site Key <span class="optional">(public)</span></label>
        <input type="text" id="turnstile_site_key" name="turnstile_site_key"
               value="<%= s.turnstile_site_key || '' %>" class="form-input"
               placeholder="1x00000000000000000000AA" autocomplete="off">
      </div>

      <div class="form-group">
        <label for="turnstile_secret_key">Secret Key</label>
        <input type="password" id="turnstile_secret_key" name="turnstile_secret_key"
               value="<%= s.turnstile_secret_key || '' %>" autocomplete="new-password" class="form-input"
               placeholder="1x0000000000000000000000000000000AA">
        <p class="form-hint">
          Get your keys at <a href="https://dash.cloudflare.com/?to=/:account/turnstile" target="_blank" rel="noopener">dash.cloudflare.com → Turnstile</a>.
          Create a site, choose <strong>Managed</strong> challenge type, and add your domain.
        </p>
      </div>
    </div>

    <!-- ── Uploads ────────────────────────────────────────────── -->
    <div class="card" id="s-uploads" style="margin-bottom:1.5rem">
      <h2 class="settings-section-title">Uploads</h2>

      <div class="form-group">
        <label for="upload_max_size_mb">Max upload size (MB)</label>
        <input type="number" id="upload_max_size_mb" name="upload_max_size_mb"
               value="<%= s.upload_max_size_mb || '25' %>" min="1" step="1"
               class="form-input form-input-sm" style="width:6rem">
      </div>

      <div class="form-group">
        <label for="upload_allowed_extensions">Allowed file extensions</label>
        <input type="text" id="upload_allowed_extensions" name="upload_allowed_extensions"
               value="<%= s.upload_allowed_extensions || '' %>" class="form-input">
        <p class="form-hint">Comma-separated, no dots, case-insensitive. Leave blank to allow all (subject to blocked list).</p>
      </div>

      <div class="form-group">
        <label for="upload_blocked_extensions">Blocked file extensions</label>
        <input type="text" id="upload_blocked_extensions" name="upload_blocked_extensions"
               value="<%= s.upload_blocked_extensions || '' %>" class="form-input">
        <p class="form-hint">Always rejected even if in the allowed list. Leave blank to block nothing.</p>
      </div>

      <div class="form-group">
        <label for="annotation_extensions">Annotatable file extensions</label>
        <input type="text" id="annotation_extensions" name="annotation_extensions"
               value="<%= s.annotation_extensions || 'pdf,jpg,jpeg,gif,png,svg' %>" class="form-input">
        <p class="form-hint">Comma-separated. Attachments with these extensions show an Annotate button.</p>
      </div>

      <hr class="settings-hr">
      <h3 class="settings-sub-title">Inbound Email Rate Limits</h3>

      <div class="form-row" style="gap:.75rem;flex-wrap:wrap">
        <div class="form-group" style="flex:0 0 auto">
          <label for="email_rate_limit_per_ticket">Rate limit per ticket (msgs/min)</label>
          <input type="number" id="email_rate_limit_per_ticket" name="email_rate_limit_per_ticket"
                 value="<%= s.email_rate_limit_per_ticket || '10' %>" min="0" step="1"
                 class="form-input form-input-sm" style="width:6rem">
        </div>
        <div class="form-group" style="flex:0 0 auto">
          <label for="email_rate_limit_new_tickets">Rate limit new tickets (msgs/min)</label>
          <input type="number" id="email_rate_limit_new_tickets" name="email_rate_limit_new_tickets"
                 value="<%= s.email_rate_limit_new_tickets || '3' %>" min="0" step="1"
                 class="form-input form-input-sm" style="width:6rem">
        </div>
      </div>
      <p class="form-hint">Maximum inbound email messages per minute. 0 disables the limit.</p>
    </div>

    <!-- ── Features ──────────────────────────────────────────── -->
    <div class="card" id="s-features" style="margin-bottom:1.5rem">
      <h2 class="settings-section-title">Features</h2>

      <div class="form-group">
        <label class="checkbox-label">
          <input type="checkbox" name="enable_billable_hours" value="1"
                 <%= s.enable_billable_hours !== 'false' ? 'checked' : '' %>>
          Enable billable hours
        </label>
        <p class="form-hint">Show the billable hours field on ticket replies and include the Billing Report in Reports.</p>
      </div>

      <div class="form-group">
        <label class="checkbox-label">
          <input type="checkbox" name="enable_location" value="1"
                 <%= s.enable_location !== 'false' ? 'checked' : '' %>>
          Enable location tracking
        </label>
        <p class="form-hint">Show the location field on ticket replies and include the Travel Report in Reports.</p>
      </div>
    </div>

    <!-- ── System ─────────────────────────────────────────────── -->
    <div class="settings-section-group-label" id="s-system">System</div>

    <!-- Updates -->
    <div class="card" id="s-updates" style="margin-bottom:1rem">
      <h2 class="settings-section-title">Updates</h2>

      <div class="form-group">
        <label class="checkbox-label">
          <input type="checkbox" name="update_check_enabled" value="1"
                 <%= s.update_check_enabled === 'true' ? 'checked' : '' %>>
          Automatically check for updates
        </label>
      </div>

      <div class="form-group">
        <label for="update_repo_url">Repository URL</label>
        <input type="url" id="update_repo_url" name="update_repo_url"
               value="<%= s.update_repo_url || 'https://github.com/ryangriggs/tix.git' %>"
               class="form-input">
        <p class="form-hint">GitHub repository to check for updates. Only the <code>main</code> branch is used.</p>
      </div>

      <div class="form-group">
        <label for="update_check_interval_hours">Check every (hours)</label>
        <input type="number" id="update_check_interval_hours" name="update_check_interval_hours"
               value="<%= s.update_check_interval_hours || '24' %>" min="1" step="1"
               class="form-input form-input-sm" style="width:6rem">
      </div>

      <p class="form-hint" style="margin-top:.5rem">
        <strong>Note:</strong> Installing an update will run <code>git reset --hard origin/main</code> followed by
        <code>npm install</code>. Any local file customisations will be overwritten.
      </p>

      <hr class="settings-hr">

      <p style="font-size:.9rem;margin-bottom:1rem">
        Running version: <strong>v<%= appVersion %></strong>
        <% if (updateState.checkedAt) { %>
          &mdash; Latest: <strong>v<%= updateState.latestVersion %></strong>
          <% if (updateState.available) { %>
            <span style="color:#d97706;font-weight:600"> — update available</span>
          <% } else { %>
            <span style="color:#16a34a"> — up to date</span>
          <% } %>
          <br><span style="font-size:.8rem;color:var(--text-muted)">Last checked: <%= new Date(updateState.checkedAt).toLocaleString() %></span>
        <% } else { %>
          <span style="color:var(--text-muted)"> — not yet checked</span>
        <% } %>
        <% if (updateState.error) { %>
          <br><span style="color:#dc2626;font-size:.8rem">Check error: <%= updateState.error %></span>
        <% } %>
      </p>

      <div style="display:flex;gap:.75rem;align-items:center;flex-wrap:wrap">
        <button type="button" class="btn btn-secondary" id="check-now-btn" onclick="checkNow()">Check Now</button>
        <% if (updateState.available) { %>
          <button type="button" class="btn btn-primary" style="background:#d97706;border-color:#b45309"
                  onclick="startInstall()">Install Update (v<%= updateState.latestVersion %>)</button>
        <% } %>
        <span id="check-result" style="font-size:.85rem"></span>
      </div>
    </div>

    <!-- Backups -->
    <div class="card" id="s-backups" style="margin-bottom:1.5rem">
      <h2 class="settings-section-title">Backups</h2>

      <div class="form-row" style="gap:1.5rem;flex-wrap:wrap">
        <div class="form-group" style="flex:0 0 auto">
          <label class="form-label">Frequency (hours, 0 = disabled)</label>
          <input type="number" name="backup_frequency_hours" min="0"
                 class="form-input" style="width:8rem"
                 value="<%= s.backup_frequency_hours || '0' %>">
        </div>
        <div class="form-group" style="flex:0 0 auto">
          <label class="form-label">Retention (days, 0 = keep forever)</label>
          <input type="number" name="backup_retention_days" min="0"
                 class="form-input" style="width:8rem"
                 value="<%= s.backup_retention_days || '30' %>">
        </div>
      </div>
      <p class="form-hint">Set BACKUP_DIR in .env to enable. Each backup is a .zip containing the database, .env, and all attachments.</p>

      <hr class="settings-hr">

      <table style="border-collapse:collapse;margin-bottom:1rem;width:100%">
        <tr>
          <td style="color:var(--text-muted);font-size:.875rem;padding:.3rem .5rem;white-space:nowrap;width:40%">Database size</td>
          <td style="font-size:.875rem;padding:.3rem .5rem"><%= backupStatus.dbSizeMb %> MB</td>
        </tr>
        <tr>
          <td style="color:var(--text-muted);font-size:.875rem;padding:.3rem .5rem;white-space:nowrap">Backup directory</td>
          <td style="font-size:.875rem;padding:.3rem .5rem">
            <% if (!backupStatus.backupDir) { %>
              <span style="color:var(--text-muted)">(not configured &mdash; set BACKUP_DIR in .env)</span>
            <% } else if (!backupStatus.dirExists) { %>
              <span style="color:#b91c1c"><%= backupStatus.backupDir %> &mdash; does not exist</span>
            <% } else { %>
              <%= backupStatus.backupDir %> &mdash; <%= backupStatus.dirSizeMb %> MB used
            <% } %>
          </td>
        </tr>
        <tr>
          <td style="color:var(--text-muted);font-size:.875rem;padding:.3rem .5rem;white-space:nowrap">Last backup</td>
          <td style="font-size:.875rem;padding:.3rem .5rem">
            <%= backupStatus.lastBackupAt ? formatDateFull(parseInt(backupStatus.lastBackupAt)) : 'Never' %>
          </td>
        </tr>
      </table>

      <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:1rem">
        <button id="backup-now-btn" type="button" class="btn btn-secondary btn-sm">Backup Now</button>
        <span id="backup-now-status" style="font-size:.875rem"></span>
      </div>

      <% if (backupStatus.dirExists) { %>
      <details id="backup-file-details">
        <summary style="cursor:pointer;font-size:.875rem;font-weight:500;user-select:none;padding:.25rem 0">
          Backup files (<%= backupStatus.allFiles.length %>)
        </summary>
        <div style="margin-top:.75rem">

          <%# Bulk action bar — shown via JS when rows are selected %>
          <div id="backup-bulk-bar" style="display:none;align-items:center;gap:.75rem;flex-wrap:wrap;margin-bottom:.6rem;padding:.45rem .6rem;background:var(--bg-alt,#f3f4f6);border-radius:.375rem;font-size:.85rem">
            <span id="backup-sel-info" style="font-weight:500"></span>
            <button type="button" class="btn btn-sm btn-secondary" onclick="backupDownloadSelected()">Download selected</button>
            <button type="button" class="btn btn-sm btn-danger"    onclick="backupDeleteSelected()">Delete selected</button>
          </div>

          <% if (backupStatus.allFiles.length === 0) { %>
            <p style="font-size:.875rem;color:var(--text-muted)">No backup files found.</p>
          <% } else { %>
          <div style="overflow-x:auto">
          <table id="backup-table" class="data-table" style="font-size:.85rem;min-width:500px">
            <thead>
              <tr>
                <th style="width:2rem;text-align:center">
                  <input type="checkbox" id="backup-select-all" title="Select all" onchange="backupSelectAll(this.checked)">
                </th>
                <th><button class="th-sort-btn" id="bsort-name" onclick="backupSortBy('name')">Filename</button></th>
                <th><button class="th-sort-btn" id="bsort-mtime" onclick="backupSortBy('mtime')">Date ↓</button></th>
                <th style="text-align:right"><button class="th-sort-btn" id="bsort-size" onclick="backupSortBy('size')">Size</button></th>
                <th style="width:1px;white-space:nowrap">Actions</th>
              </tr>
            </thead>
            <tbody id="backup-tbody"></tbody>
          </table>
          </div>
          <% } %>

        </div>
      </details>
      <% } %>

      <%# Embed backup file data for JS rendering %>
      <script>
      var _backupFiles = <%- JSON.stringify(backupStatus.allFiles) %>;
      var _backupCsrf  = '<%= csrfToken %>';
      var _backupSort  = { col: 'mtime', dir: 'desc' };
      var _backupLastChecked = null;
      </script>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save settings</button>
    </div>
  </form>

  <!-- ── Infrastructure (read-only) ──────────────────────────── -->
  <div class="card" id="s-infrastructure" style="margin-top:1rem">
    <h2 class="settings-section-title">Infrastructure</h2>
    <p class="form-hint" style="margin-bottom:1rem">These values come from your <code>.env</code> file and require a server restart to change.</p>
    <table style="width:100%;border-collapse:collapse">
      <% for (const [key, val] of Object.entries(infra)) { %>
        <tr style="border-bottom:1px solid var(--border)">
          <td style="padding:.35rem .5rem .35rem 0;font-size:.8rem;color:var(--text-muted);white-space:nowrap;width:40%"><%= key %></td>
          <td style="padding:.35rem 0;font-size:.85rem;font-family:monospace;word-break:break-all"><%= val %></td>
        </tr>
      <% } %>
    </table>
  </div>

  <!-- ── Server Stats ─────────────────────────────────────────── -->
  <div class="card" id="s-server-stats" style="margin-top:1rem">
    <h2 class="settings-section-title">Server Stats</h2>
    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem;flex-wrap:wrap">
      <button type="button" class="btn btn-secondary btn-sm" id="stats-load-btn" onclick="loadStats()">Load Stats</button>
      <span id="stats-load-status" style="font-size:.85rem;color:var(--text-muted)"></span>
    </div>
    <div id="stats-content" style="display:none">
      <table style="width:100%;border-collapse:collapse" id="stats-table"></table>
    </div>
  </div>

  <!-- ── Browser Cache ─────────────────────────────────────────── -->
  <div class="card" id="s-browser-cache" style="margin-top:1rem;margin-bottom:1.5rem">
    <h2 class="settings-section-title">Browser Cache</h2>
    <p class="form-hint" style="margin-bottom:1.25rem">
      If users report stale UI after an update, they can clear their local service-worker cache and reload.
    </p>
    <button type="button" class="btn btn-secondary" onclick="clearSWCache(this)">Clear cached files &amp; reload</button>
  </div>

</main>

<script>
(function () {
  const nav = document.getElementById('settings-sidenav');
  if (!nav) return;

  const sectionIds = [
    's-site','s-email','s-notifications','s-security','s-uploads','s-features',
    's-updates','s-backups','s-infrastructure','s-server-stats','s-browser-cache',
  ];

  nav.querySelectorAll('.settings-sidenav-link').forEach(link => {
    link.addEventListener('click', e => {
      e.preventDefault();
      const target = document.querySelector(link.getAttribute('href'));
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  const linkMap = {};
  nav.querySelectorAll('.settings-sidenav-link').forEach(a => {
    const id = a.getAttribute('href').slice(1);
    linkMap[id] = a;
  });

  let activeId = null;
  function setActive(id) {
    if (id === activeId) return;
    if (activeId && linkMap[activeId]) linkMap[activeId].classList.remove('active');
    activeId = id;
    if (id && linkMap[id]) linkMap[id].classList.add('active');
  }

  const observer = new IntersectionObserver(entries => {
    let topEntry = null;
    for (const e of entries) {
      if (e.isIntersecting) {
        if (!topEntry || e.boundingClientRect.top < topEntry.boundingClientRect.top) {
          topEntry = e;
        }
      }
    }
    if (topEntry) setActive(topEntry.target.id);
  }, { threshold: 0, rootMargin: '-10% 0px -60% 0px' });

  sectionIds.forEach(id => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });

  // Mobile ToC: smooth scroll and close on link click
  document.querySelectorAll('.settings-mobile-toc-nav a').forEach(link => {
    link.addEventListener('click', e => {
      e.preventDefault();
      const target = document.querySelector(link.getAttribute('href'));
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      link.closest('details').removeAttribute('open');
    });
  });
})();
</script>

<script>
// Show only the active transport section
(function () {
  const sel = document.getElementById('mail_transport');
  function update() {
    document.querySelectorAll('.settings-transport-section').forEach(el => {
      el.style.display = el.id === 'transport-' + sel.value ? '' : 'none';
    });
  }
  sel.addEventListener('change', update);
  update();
})();

async function clearSWCache(btn) {
  btn.disabled = true;
  btn.textContent = 'Clearing…';
  if ('serviceWorker' in navigator) {
    const regs = await navigator.serviceWorker.getRegistrations();
    for (const r of regs) await r.unregister();
  }
  if ('caches' in window) {
    const keys = await caches.keys();
    for (const k of keys) await caches.delete(k);
  }
  window.location.reload();
}
</script>

<script>
(function() {
  var btn    = document.getElementById('backup-now-btn');
  var status = document.getElementById('backup-now-status');
  if (!btn) return;
  btn.addEventListener('click', async function() {
    btn.disabled = true;
    btn.textContent = 'Backing up…';
    status.textContent = '';
    status.style.color = '';
    try {
      var resp = await fetch('/admin/backup/now', {
        method: 'POST',
        headers: { 'X-CSRF-Token': '<%= csrfToken %>' },
        credentials: 'include',
      });
      var data = await resp.json();
      if (data.ok) {
        status.textContent = 'Created: ' + data.filename;
        status.style.color = 'var(--success, #15803d)';
        setTimeout(function() { window.location.reload(); }, 800);
      } else {
        status.textContent = 'Failed: ' + (data.error || 'Unknown error');
        status.style.color = '#b91c1c';
        btn.disabled = false;
        btn.textContent = 'Backup Now';
      }
    } catch (err) {
      status.textContent = 'Failed: ' + err.message;
      status.style.color = '#b91c1c';
      btn.disabled = false;
      btn.textContent = 'Backup Now';
    }
  });
})();
</script>

<script>
// ── Backup file list management ──────────────────────────────
(function() {
  var tbody = document.getElementById('backup-tbody');
  if (!tbody || !_backupFiles) return;

  function fmtSize(bytes) {
    if (bytes >= 1073741824) return (bytes / 1073741824).toFixed(1) + ' GB';
    if (bytes >= 1048576)    return (bytes / 1048576).toFixed(1) + ' MB';
    if (bytes >= 1024)       return (bytes / 1024).toFixed(1) + ' KB';
    return bytes + ' B';
  }

  function fmtDate(ms) {
    return new Date(ms).toLocaleString();
  }

  function getSortedFiles() {
    var files = _backupFiles.slice();
    var col = _backupSort.col, dir = _backupSort.dir;
    files.sort(function(a, b) {
      var av = a[col], bv = b[col];
      if (typeof av === 'string') av = av.toLowerCase();
      if (typeof bv === 'string') bv = bv.toLowerCase();
      return dir === 'asc' ? (av > bv ? 1 : av < bv ? -1 : 0) : (av < bv ? 1 : av > bv ? -1 : 0);
    });
    return files;
  }

  function renderTable() {
    var files = getSortedFiles();
    var html = '';
    for (var i = 0; i < files.length; i++) {
      var f = files[i];
      var enc = encodeURIComponent(f.name);
      var esc = f.name.replace(/"/g, '&quot;');
      html += '<tr data-name="' + esc + '" data-size="' + f.size + '">' +
        '<td style="text-align:center"><input type="checkbox" class="backup-cb" data-name="' + esc + '" onchange="backupCbChange(event,this)"></td>' +
        '<td style="word-break:break-all">' + f.name + '</td>' +
        '<td style="white-space:nowrap">' + fmtDate(f.mtime) + '</td>' +
        '<td style="text-align:right;white-space:nowrap">' + fmtSize(f.size) + '</td>' +
        '<td style="white-space:nowrap">' +
          '<a href="/admin/backup/download/' + enc + '" class="btn btn-sm btn-secondary" style="margin-right:.25rem" download>Download</a>' +
          '<button type="button" class="btn btn-sm btn-danger" onclick="backupDeleteOne(\'' + esc + '\')">Delete</button>' +
        '</td>' +
      '</tr>';
    }
    tbody.innerHTML = html;
    _backupLastChecked = null;
    updateSortHeaders();
    updateBulkBar();
  }

  function updateSortHeaders() {
    ['name','mtime','size'].forEach(function(col) {
      var btn = document.getElementById('bsort-' + col);
      if (!btn) return;
      var label = col === 'name' ? 'Filename' : col === 'mtime' ? 'Date' : 'Size';
      if (_backupSort.col === col) {
        btn.textContent = label + (_backupSort.dir === 'asc' ? ' ↑' : ' ↓');
        btn.classList.add('tlh-active');
      } else {
        btn.textContent = label;
        btn.classList.remove('tlh-active');
      }
    });
  }

  window.backupSortBy = function(col) {
    if (_backupSort.col === col) {
      _backupSort.dir = _backupSort.dir === 'asc' ? 'desc' : 'asc';
    } else {
      _backupSort.col = col;
      _backupSort.dir = col === 'mtime' ? 'desc' : 'asc';
    }
    renderTable();
  };

  window.backupCbChange = function(evt, cb) {
    if (evt.shiftKey && _backupLastChecked) {
      var cbs = Array.from(document.querySelectorAll('.backup-cb'));
      var a = cbs.indexOf(_backupLastChecked), b = cbs.indexOf(cb);
      var lo = Math.min(a, b), hi = Math.max(a, b);
      for (var i = lo; i <= hi; i++) cbs[i].checked = cb.checked;
    }
    _backupLastChecked = cb;
    updateBulkBar();
  };

  window.backupSelectAll = function(checked) {
    document.querySelectorAll('.backup-cb').forEach(function(cb) { cb.checked = checked; });
    _backupLastChecked = null;
    updateBulkBar();
  };

  function getSelected() {
    return Array.from(document.querySelectorAll('.backup-cb:checked')).map(function(cb) { return cb.dataset.name; });
  }

  function getTotalSize(names) {
    var nameSet = new Set(names);
    return _backupFiles.filter(function(f) { return nameSet.has(f.name); })
      .reduce(function(s, f) { return s + f.size; }, 0);
  }

  function updateBulkBar() {
    var sel = getSelected();
    var bar = document.getElementById('backup-bulk-bar');
    var info = document.getElementById('backup-sel-info');
    var allCb = document.getElementById('backup-select-all');
    var allCbs = document.querySelectorAll('.backup-cb');
    if (bar) bar.style.display = sel.length ? 'flex' : 'none';
    if (info) info.textContent = sel.length + ' file' + (sel.length === 1 ? '' : 's') + ' selected — ' + fmtSize(getTotalSize(sel));
    if (allCb) {
      allCb.checked = allCbs.length > 0 && sel.length === allCbs.length;
      allCb.indeterminate = sel.length > 0 && sel.length < allCbs.length;
    }
  }

  window.backupDeleteOne = async function(name) {
    if (!confirm('Delete ' + name + '?\nThis cannot be undone.')) return;
    await doDelete([name]);
  };

  window.backupDeleteSelected = async function() {
    var sel = getSelected();
    if (!sel.length) return;
    if (!confirm('Delete ' + sel.length + ' backup file' + (sel.length === 1 ? '' : 's') + '?\nThis cannot be undone.')) return;
    await doDelete(sel);
  };

  async function doDelete(filenames) {
    try {
      var resp = await fetch('/admin/backup/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': _backupCsrf },
        credentials: 'include',
        body: JSON.stringify({ filenames: filenames }),
      });
      var data = await resp.json();
      if (data.ok) {
        var nameSet = new Set(filenames);
        _backupFiles = _backupFiles.filter(function(f) { return !nameSet.has(f.name); });
        var details = document.getElementById('backup-file-details');
        var summary = details && details.querySelector('summary');
        if (summary) summary.textContent = 'Backup files (' + _backupFiles.length + ')';
        renderTable();
      } else {
        alert('Some files could not be deleted:\n' + (data.errors || []).join('\n'));
        window.location.reload();
      }
    } catch (err) {
      alert('Delete failed: ' + err.message);
    }
  }

  window.backupDownloadSelected = function() {
    var sel = getSelected();
    sel.forEach(function(name, i) {
      setTimeout(function() {
        var a = document.createElement('a');
        a.href = '/admin/backup/download/' + encodeURIComponent(name);
        a.download = name;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
      }, i * 300);
    });
  };

  renderTable();
})();
</script>

<script>
async function loadStats() {
  var btn    = document.getElementById('stats-load-btn');
  var status = document.getElementById('stats-load-status');
  var content = document.getElementById('stats-content');
  var table  = document.getElementById('stats-table');
  btn.disabled = true;
  btn.textContent = 'Loading…';
  status.textContent = '';
  try {
    var resp = await fetch('/admin/stats', { credentials: 'include' });
    if (!resp.ok) throw new Error('HTTP ' + resp.status);
    var d = await resp.json();

    var rows = [
      ['Tickets — New',     d.tickets.new],
      ['Tickets — Open',    d.tickets.open],
      ['Tickets — On Hold', d.tickets.on_hold],
      ['Tickets — Closed',  d.tickets.closed],
      ['Tickets — Total',   d.tickets.total],
      null,
      ['Attachments',          d.attachments.count + ' files'],
      ['Attachment storage',   d.attachments.sizeMb + ' MB'],
      ['Database size',        d.dbSizeMb + ' MB'],
      ['Log files size',       d.logSizeMb + ' MB'],
      ['App directory size',   d.appSizeMb + ' MB (excl. node_modules)'],
      null,
      ['Emails sent today',        d.emailsSentToday !== null ? d.emailsSentToday : '— (no log configured)'],
      ['Emails sent this month',   d.emailsSentThisMonth !== null ? d.emailsSentThisMonth : '— (no log configured)'],
    ];

    var html = '';
    for (var r of rows) {
      if (!r) { html += '<tr><td colspan="2" style="padding:.4rem 0"></td></tr>'; continue; }
      html += '<tr style="border-bottom:1px solid var(--border)">'
        + '<td style="padding:.35rem .5rem .35rem 0;font-size:.85rem;color:var(--text-muted);white-space:nowrap;width:50%">' + r[0] + '</td>'
        + '<td style="padding:.35rem 0;font-size:.85rem">' + r[1] + '</td>'
        + '</tr>';
    }
    table.innerHTML = html;
    content.style.display = '';
    btn.textContent = 'Refresh';
  } catch (err) {
    status.textContent = 'Failed: ' + err.message;
  } finally {
    btn.disabled = false;
    if (!status.textContent) btn.textContent = 'Refresh';
  }
}
</script>

<script>
async function checkNow() {
  const btn = document.getElementById('check-now-btn');
  const result = document.getElementById('check-result');
  btn.disabled = true;
  btn.textContent = 'Checking…';
  result.textContent = '';
  try {
    const resp = await fetch('/admin/update/check', {
      method: 'POST',
      headers: { 'X-CSRF-Token': '<%= csrfToken %>' },
      credentials: 'include',
    });
    const data = await resp.json();
    if (data.error) {
      result.style.color = '#dc2626';
      result.textContent = 'Error: ' + data.error;
    } else if (data.available) {
      result.style.color = '#d97706';
      result.innerHTML = 'Update available: <strong>v' + data.latestVersion + '</strong> &mdash; <a href="#s-updates" onclick="startInstall();return false">Install now</a>';
    } else {
      result.style.color = '#16a34a';
      result.textContent = 'Up to date (v' + data.latestVersion + ')';
    }
  } catch (err) {
    result.style.color = '#dc2626';
    result.textContent = 'Request failed';
  }
  btn.disabled = false;
  btn.textContent = 'Check Now';
}
</script>

<script>
document.addEventListener('DOMContentLoaded', function () {
  if (typeof createAutocomplete !== 'function') return;

  const wrap    = document.getElementById('urgent-notify-wrap');
  const input   = document.getElementById('urgent-notify-input');
  const hiddens = document.getElementById('urgent-notify-hiddens');
  if (!wrap || !input) return;

  const _esc = s => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  const _selected = new Set();

  function addUrgentPill(id, label) {
    id = Number(id);
    if (_selected.has(id)) return;
    _selected.add(id);

    const pill = document.createElement('span');
    pill.dataset.userId = id;
    pill.style.cssText = 'display:inline-flex;align-items:center;gap:.2rem;background:#eff6ff;border:1px solid #bfdbfe;border-radius:999px;padding:.15rem .5rem .15rem .65rem;font-size:.8rem;white-space:nowrap';
    pill.innerHTML = `<span>${_esc(label)}</span><button type="button" title="Remove" style="background:none;border:none;cursor:pointer;font-size:1.1rem;line-height:1;color:#64748b;padding:0 .15rem">×</button>`;
    pill.querySelector('button').addEventListener('click', () => {
      _selected.delete(id);
      wrap.querySelector(`[data-user-id="${id}"]`).remove();
      hiddens.querySelector(`[data-user-id="${id}"]`).remove();
    });
    wrap.insertBefore(pill, input);

    const hidden = document.createElement('input');
    hidden.type = 'hidden';
    hidden.name = 'urgent_notify_user_ids';
    hidden.value = id;
    hidden.dataset.userId = id;
    hiddens.appendChild(hidden);
  }

  // Pre-populate from server-rendered data
  <%
    const _urgentPreIds = (s.urgent_notify_user_ids || '').split(',').map(Number).filter(Boolean);
    const _urgentPreUsers = allUsers.filter(u => _urgentPreIds.includes(u.id));
  %>
  <% for (const u of _urgentPreUsers) { %>
  addUrgentPill(<%= u.id %>, <%- JSON.stringify(u.name ? `${u.name} (${u.email})` : u.email).replace(/</g,'\\u003C') %>);
  <% } %>

  createAutocomplete(input, {
    fetchUrl: q => `/api/users/search?q=${encodeURIComponent(q)}`,
    formatItem: item => {
      const name = item.name ? `<strong>${_esc(item.name)}</strong> ` : '';
      const org  = item.org  ? ` <em style="color:#6b7280">[${_esc(item.org)}]</em>` : '';
      return `${name}(${_esc(item.email)})${org}`;
    },
    onSelect: item => {
      addUrgentPill(item.id, item.name ? `${item.name} (${item.email})` : item.email);
      input.value = '';
    },
  });
});
</script>

