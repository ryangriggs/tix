<%- include('../partials/head', { title: 'User Management' }) %>
<%- include('../partials/nav') %>

<main class="container">
  <h1 class="page-title">User Management</h1>

  <% if (message) { %>
    <div class="alert alert-info"><%= message %></div>
  <% } %>

  <!-- Add user -->
  <details style="margin-bottom:1.25rem">
    <summary class="link-btn">+ Add user</summary>
    <form method="POST" action="/admin/users/pre-add" class="inline-form" style="margin-top:.5rem;gap:.5rem;flex-wrap:wrap">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="email" name="email" placeholder="Email address" class="form-input form-input-sm" required style="width:220px">
      <input type="text"  name="name"  placeholder="Full name (optional)" class="form-input form-input-sm" style="width:200px">
      <button type="submit" class="btn btn-sm btn-primary">Add User</button>
    </form>
  </details>

  <%# Hidden form drives sort navigation %>
  <form id="user-sort-form" method="GET" action="/admin/users" style="display:none">
    <input type="hidden" name="sort"  id="user-sort-field"  value="<%= sort %>">
    <input type="hidden" name="order" id="user-order-field" value="<%= order %>">
  </form>

  <%# Mobile sort bar (hidden on desktop via CSS) %>
  <div class="mobile-sort-bar">
    <label for="user-mobile-sort" style="flex-shrink:0">Sort</label>
    <select id="user-mobile-sort" class="form-select form-select-sm" onchange="setUserSort(this.value)">
      <option value="organization_name" <%= sort==='organization_name' ? 'selected':'' %>>Organization</option>
      <option value="name"              <%= sort==='name'              ? 'selected':'' %>>Name</option>
      <option value="email"             <%= sort==='email'             ? 'selected':'' %>>Email</option>
      <option value="role"              <%= sort==='role'              ? 'selected':'' %>>Role</option>
      <option value="created_at"        <%= sort==='created_at'        ? 'selected':'' %>>Created</option>
    </select>
    <button type="button" class="btn btn-sm btn-ghost" onclick="setUserSort('<%= sort %>')" title="Toggle direction"><%= order==='desc' ? '↓' : '↑' %></button>
  </div>

  <%# Desktop table (hidden on mobile) %>
  <div class="user-table-wrap">
  <table class="data-table">
    <thead>
      <tr>
        <th><button class="th-sort-btn <%= sort==='email' ?'tlh-active':'' %>" onclick="setUserSort('email')">Email<%= sort==='email' ? (order==='asc'?' ↑':' ↓'):'' %></button></th>
        <th><button class="th-sort-btn <%= sort==='name'  ?'tlh-active':'' %>" onclick="setUserSort('name')">Name<%= sort==='name'  ? (order==='asc'?' ↑':' ↓'):'' %></button></th>
        <th><button class="th-sort-btn <%= sort==='role'  ?'tlh-active':'' %>" onclick="setUserSort('role')">Role<%= sort==='role'  ? (order==='asc'?' ↑':' ↓'):'' %></button></th>
        <th><button class="th-sort-btn <%= sort==='organization_name' ?'tlh-active':'' %>" onclick="setUserSort('organization_name')">Organization<%= sort==='organization_name' ? (order==='asc'?' ↑':' ↓'):'' %></button></th>
        <th><button class="th-sort-btn <%= sort==='created_at' ?'tlh-active':'' %>" onclick="setUserSort('created_at')">Created<%= sort==='created_at' ? (order==='asc'?' ↑':' ↓'):'' %></button></th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% for (const u of users) { %>
        <tr class="<%= u.blocked_at ? 'row-blocked' : '' %>">
          <td><%= u.email %></td>
          <td><%= u.name || '—' %></td>
          <td><span class="badge badge-role"><%= u.role %></span></td>
          <td><%= u.organization_name || '—' %></td>
          <td><span data-ts="<%= u.created_at %>"><%= formatDate(u.created_at) %></span></td>
          <td><%= u.blocked_at ? 'Blocked' : 'Active' %></td>
          <td class="actions-cell">
            <button type="button" class="btn btn-sm btn-secondary"
              onclick="openEditDialog(this)"
              data-user-id="<%= u.id %>"
              data-user-email="<%= u.email %>"
              data-user-name="<%= (u.name || '').replace(/"/g,'&quot;') %>"
              data-user-role="<%= u.role %>"
              data-user-org="<%= (u.organization_name || '').replace(/"/g,'&quot;') %>"
              data-user-superuser="<%= u.is_group_superuser ? '1' : '0' %>"
              data-user-blocked="<%= u.blocked_at ? '1' : '0' %>"
              data-is-self="<%= u.id === user.id ? '1' : '0' %>">Edit</button>
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>
  </div>

  <%# Mobile card list (hidden on desktop) %>
  <div class="user-mobile-list">
    <% for (const u of users) { %>
      <div class="user-card <%= u.blocked_at ? 'user-card-blocked' : '' %>"
        onclick="openEditDialog(this)"
        data-user-id="<%= u.id %>"
        data-user-email="<%= u.email %>"
        data-user-name="<%= (u.name || '').replace(/"/g,'&quot;') %>"
        data-user-role="<%= u.role %>"
        data-user-org="<%= (u.organization_name || '').replace(/"/g,'&quot;') %>"
        data-user-superuser="<%= u.is_group_superuser ? '1' : '0' %>"
        data-user-blocked="<%= u.blocked_at ? '1' : '0' %>"
        data-is-self="<%= u.id === user.id ? '1' : '0' %>">
        <div class="user-card-top">
          <span class="user-card-name"><%= u.name || u.email %></span>
          <span class="badge badge-role"><%= u.role %></span>
        </div>
        <% if (u.name) { %><div class="user-card-email"><%= u.email %></div><% } %>
        <div class="user-card-meta">
          <span><%= u.organization_name || '—' %></span>
          <% if (u.blocked_at) { %><span style="color:#dc2626">Blocked</span><% } %>
        </div>
      </div>
    <% } %>
  </div>

</main>

<!-- Edit User Dialog -->
<dialog id="edit-user-dialog">
  <div class="dialog-header">
    <h2 id="dialog-title">Edit User</h2>
    <button type="button" class="btn-icon" style="font-size:1.25rem" onclick="document.getElementById('edit-user-dialog').close()">×</button>
  </div>
  <div class="dialog-body">

    <p id="dialog-email" style="font-size:.9rem;color:var(--text-muted);margin-bottom:1rem"></p>

    <!-- Main edit form (name, role, org, superuser, active) -->
    <form id="dialog-edit-form" method="POST" action="">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="form-group">
        <label for="dialog-name">Name</label>
        <input type="text" id="dialog-name" name="name" class="form-input" placeholder="Full name">
      </div>

      <div class="form-group">
        <label for="dialog-role">Role</label>
        <select id="dialog-role" name="role" class="form-select" onchange="updateDialogSections()">
          <option value="user">User</option>
          <option value="technician">Technician</option>
          <option value="admin">Admin</option>
        </select>
        <p id="dialog-role-note" style="display:none;font-size:.8rem;color:var(--text-muted);margin-top:.25rem">You cannot change your own role.</p>
      </div>

      <div class="form-group">
        <label for="dialog-org">Organization</label>
        <div style="position:relative">
          <input type="text" id="dialog-org" name="organization_name" class="form-input" autocomplete="off" placeholder="None">
        </div>
      </div>

      <div class="form-group" id="dialog-superuser-row">
        <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;font-weight:normal">
          <input type="checkbox" id="dialog-superuser" name="is_group_superuser" value="1" onchange="updateDialogSections()">
          <span>Group Superuser — can view all tickets in their organization</span>
        </label>
      </div>

      <div class="form-group" id="dialog-active-row">
        <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;font-weight:normal">
          <input type="checkbox" id="dialog-active" name="active" value="1">
          <span>Account active</span>
        </label>
      </div>
    </form>

    <!-- Additional orgs section (technicians + superusers) -->
    <div id="dialog-tech-orgs" style="display:none">
      <hr class="dialog-section-divider">
      <div class="sidebar-label" style="margin-bottom:.5rem" id="dialog-tech-orgs-label">Additional Organizations</div>
      <div id="dialog-tech-orgs-list" style="display:flex;flex-wrap:wrap;gap:.35rem;margin-bottom:.5rem"></div>
      <div class="inline-form">
        <div style="position:relative;flex:1">
          <input type="text" id="dialog-tech-org-input" class="form-input form-input-sm"
                 placeholder="Add org…" autocomplete="off">
        </div>
        <button type="button" class="btn btn-sm btn-secondary" onclick="addTechOrg()">Add</button>
      </div>
    </div>

  </div>

  <!-- Dialog footer: destructive actions left, save/cancel right -->
  <div class="dialog-footer">
    <div style="display:flex;gap:.5rem">
      <button type="button" id="dialog-delete-btn" class="btn btn-sm btn-danger" onclick="dialogDeleteUser()">Delete</button>
      <form id="dialog-impersonate-form" method="POST" action="" style="display:inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" id="dialog-impersonate-btn" class="btn btn-sm btn-secondary"
          onclick="return confirm('Sign in as this user? You\'ll see the system exactly as they do.')">
          Sign In As
        </button>
      </form>
    </div>
    <div style="display:flex;gap:.5rem">
      <button type="button" class="btn btn-ghost" onclick="document.getElementById('edit-user-dialog').close()">Cancel</button>
      <button type="submit" form="dialog-edit-form" class="btn btn-primary">Save Changes</button>
    </div>
  </div>
</dialog>

<script>
function setUserSort(col) {
  const sortEl  = document.getElementById('user-sort-field');
  const orderEl = document.getElementById('user-order-field');
  const isCurrent = sortEl.value === col;
  orderEl.value = isCurrent && orderEl.value === 'asc' ? 'desc' : 'asc';
  sortEl.value  = col;
  document.getElementById('user-sort-form').submit();
}

let _dialogUserId = null;
let _dialogBlocked = false;
const _csrf = '<%= csrfToken %>';

function openEditDialog(btn) {
  const d = btn.dataset;
  _dialogUserId = d.userId;
  _dialogBlocked = d.userBlocked === '1';

  document.getElementById('dialog-email').textContent = d.userEmail;
  document.getElementById('dialog-name').value  = d.userName;
  document.getElementById('dialog-org').value   = d.userOrg;
  document.getElementById('dialog-superuser').checked = d.userSuperuser === '1';
  document.getElementById('dialog-active').checked = d.userBlocked !== '1';

  const roleEl = document.getElementById('dialog-role');
  roleEl.value    = d.userRole;
  roleEl.disabled = d.isSelf === '1';
  document.getElementById('dialog-role-note').style.display = d.isSelf === '1' ? 'block' : 'none';

  document.getElementById('dialog-edit-form').action = `/admin/users/${d.userId}/edit`;
  document.getElementById('dialog-impersonate-form').action = `/admin/users/${d.userId}/impersonate`;

  const isSelf = d.isSelf === '1';
  const deleteBtn = document.getElementById('dialog-delete-btn');
  deleteBtn.style.display = isSelf ? 'none' : '';
  document.getElementById('dialog-impersonate-btn').style.display = isSelf ? 'none' : '';
  document.getElementById('dialog-active-row').style.display = isSelf ? 'none' : '';

  updateDialogSections();

  document.getElementById('edit-user-dialog').showModal();
}

function updateDialogSections() {
  const role = document.getElementById('dialog-role').value;
  const isSuperuser = document.getElementById('dialog-superuser').checked;
  document.getElementById('dialog-superuser-row').style.display = role === 'user' ? '' : 'none';

  const showOrgSection = role === 'technician' || (role === 'user' && isSuperuser);
  const techSection = document.getElementById('dialog-tech-orgs');
  techSection.style.display = showOrgSection ? '' : 'none';

  const label = document.getElementById('dialog-tech-orgs-label');
  label.textContent = role === 'technician' ? 'Assigned Organizations' : 'Additional Organizations';

  if (showOrgSection && _dialogUserId) loadTechOrgs();
}

async function loadTechOrgs() {
  const r = await fetch(`/admin/users/${_dialogUserId}/tech-orgs`);
  if (!r.ok) return;
  renderTechOrgs(await r.json());
}

function renderTechOrgs(orgs) {
  const list = document.getElementById('dialog-tech-orgs-list');
  if (!orgs.length) {
    list.innerHTML = '<span style="color:var(--text-muted);font-size:.85rem">None assigned</span>';
    return;
  }
  list.innerHTML = orgs.map(o =>
    `<span style="display:inline-flex;align-items:center;gap:.2rem">
      <span class="badge">${esc(o.name)}</span>
      <button type="button" class="btn-icon" onclick="removeTechOrg(${o.id})" title="Remove">×</button>
    </span>`
  ).join('');
}

async function addTechOrg() {
  const input = document.getElementById('dialog-tech-org-input');
  const name = input.value.trim();
  if (!name || !_dialogUserId) return;
  await fetch(`/admin/users/${_dialogUserId}/tech-orgs/add`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: `_csrf=${encodeURIComponent(_csrf)}&organization_name=${encodeURIComponent(name)}`,
  });
  input.value = '';
  loadTechOrgs();
}

async function removeTechOrg(orgId) {
  if (!_dialogUserId) return;
  await fetch(`/admin/users/${_dialogUserId}/tech-orgs/remove`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: `_csrf=${encodeURIComponent(_csrf)}&organization_id=${orgId}`,
  });
  loadTechOrgs();
}

async function dialogDeleteUser() {
  if (!_dialogUserId) return;
  if (!confirm('Permanently delete this user? This cannot be undone.')) return;
  await fetch(`/admin/users/${_dialogUserId}/delete`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: `_csrf=${encodeURIComponent(_csrf)}`,
  });
  document.getElementById('edit-user-dialog').close();
  window.location.reload();
}

function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

// Org autocomplete on dialog org input
document.addEventListener('DOMContentLoaded', () => {
  const orgInput = document.getElementById('dialog-org');
  if (orgInput && typeof createAutocomplete === 'function') {
    createAutocomplete(orgInput, {
      fetchUrl: q => `/api/organizations/search?q=${encodeURIComponent(q)}`,
      formatItem: item => `<span>${item.name}</span>`,
      onSelect: item => { orgInput.value = item.name; },
      showOnFocus: true,
    });
  }
  const techOrgInput = document.getElementById('dialog-tech-org-input');
  if (techOrgInput && typeof createAutocomplete === 'function') {
    createAutocomplete(techOrgInput, {
      fetchUrl: q => `/api/organizations/search?q=${encodeURIComponent(q)}`,
      formatItem: item => `<span>${item.name}</span>`,
      onSelect: item => { techOrgInput.value = item.name; },
      showOnFocus: true,
    });
  }
});
</script>

<%- include('../partials/foot') %>
