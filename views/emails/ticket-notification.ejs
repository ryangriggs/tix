<%- include('_header') %>

<%- body %>

<hr style="border:none;border-top:1px solid #e0e0e0;margin:24px 0">
<table cellpadding="0" cellspacing="0" style="margin:0 0 16px">
  <tr>
    <td style="background:#1d4ed8;border-radius:4px">
      <a href="<%= appUrl %>/tickets/<%= ticketId %>"
         style="display:block;padding:11px 22px;color:#ffffff;text-decoration:none;font-weight:600;font-size:.95em">
        View Ticket #<%= ticketPrefix %><%= ticketId %>
      </a>
    </td>
  </tr>
</table>
<p style="color:#6b7280;font-size:.85em;margin:0">
  Reply to this email to add a comment.
</p>

<%- include('_footer') %>
