<% const _pageTitle = (tokenId && rawToken) ? 'Log in' : 'Check your email'; %>
<%- include('../partials/head', { title: _pageTitle }) %>
<main class="auth-page">
  <div class="auth-card">
    <div class="auth-logo"><%= siteName %></div>
    <h1 class="auth-title"><%= _pageTitle %></h1>

    <% if (sent) { %>
      <p class="auth-subtitle">We sent a login link and 6-digit code to your email. Enter the code below or click the link in the email.</p>
    <% } else if (tokenId && rawToken) { %>
      <p class="auth-subtitle">Click the button below to complete your sign-in.</p>
    <% } %>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (tokenId && rawToken) { %>
      <%# Magic link flow: user clicked the link in email. We confirm via POST so
           email security scanners (which pre-fetch URLs) cannot consume the token. %>
      <form method="POST" action="/auth/verify" class="auth-form">
        <input type="hidden" name="tokenId" value="<%= tokenId %>">
        <input type="hidden" name="rawToken" value="<%= rawToken %>">
        <input type="hidden" name="next" value="<%= next %>">
        <button type="submit" class="btn btn-primary btn-full">Log in</button>
      </form>
    <% } else if (tokenId) { %>
      <form method="POST" action="/auth/verify" class="auth-form" id="otp-form">
        <input type="hidden" name="tokenId" value="<%= tokenId %>">
        <input type="hidden" name="next" value="<%= next %>">
        <div class="form-group">
          <label for="otp">6-digit code</label>
          <input
            type="text"
            id="otp"
            name="otp"
            inputmode="numeric"
            pattern="[0-9]{6}"
            maxlength="6"
            placeholder="123456"
            autocomplete="one-time-code"
            autofocus
            required
            class="form-input otp-input"
          >
        </div>
        <button type="submit" class="btn btn-primary btn-full">Verify code</button>
      </form>
    <% } %>

    <div style="margin-top:1.5rem;text-align:center">
      <a href="/auth/login" class="link-muted">← Request a new link</a>
    </div>
  </div>
</main>

<!-- Full-screen submit overlay -->
<div id="verify-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9999;flex-direction:column;align-items:center;justify-content:center;gap:1rem">
  <div style="width:40px;height:40px;border:4px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin 0.8s linear infinite"></div>
  <p style="color:#fff;font-size:1rem;font-weight:500;margin:0">Please wait…</p>
</div>
<script>
  function showVerifyOverlay() {
    const el = document.getElementById('verify-overlay');
    el.style.display = 'flex';
  }

  const otpInput = document.getElementById('otp');
  if (otpInput) {
    // Auto-submit when 6 digits are typed or pasted
    otpInput.addEventListener('input', () => {
      if (otpInput.value.replace(/\D/g, '').length === 6) {
        otpInput.value = otpInput.value.replace(/\D/g, '');
        showVerifyOverlay();
        document.getElementById('otp-form').submit();
      }
    });
    // Submit on Enter regardless of digit count (server validates)
    otpInput.addEventListener('keydown', e => {
      if (e.key === 'Enter') { e.preventDefault(); showVerifyOverlay(); document.getElementById('otp-form').submit(); }
    });
  }

  // Also cover manual button click
  const otpForm = document.getElementById('otp-form');
  if (otpForm) {
    otpForm.addEventListener('submit', showVerifyOverlay);
  }

  // Magic-link confirm button
  document.querySelectorAll('form:not(#otp-form) .btn-primary').forEach(btn => {
    btn.closest('form').addEventListener('submit', showVerifyOverlay);
  });
</script>
<%- include('../partials/foot') %>
