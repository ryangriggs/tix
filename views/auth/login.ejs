<%- include('../partials/head', { title: 'Log in' }) %>
<main class="auth-page">
  <div class="auth-card">
    <div class="auth-logo"><%= siteName %></div>
    <h1 class="auth-title">Log in</h1>
    <p class="auth-subtitle">Enter your email and we'll send you a link.</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/auth/login" class="auth-form">
      <input type="hidden" name="next" value="<%= next %>">
      <div class="form-group">
        <label for="email">Email address</label>
        <input
          type="email"
          id="email"
          name="email"
          value="<%= email %>"
          placeholder="you@example.com"
          autocomplete="email"
          autofocus
          required
          class="form-input"
        >
      </div>
      <button type="submit" class="btn btn-primary btn-full" id="login-btn">Send login link</button>
    </form>
  </div>
</main>

<div id="login-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9999;flex-direction:column;align-items:center;justify-content:center;gap:1rem">
  <div style="width:40px;height:40px;border:4px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin 0.8s linear infinite"></div>
  <p style="color:#fff;font-size:1rem;font-weight:500;margin:0">Please wait…</p>
</div>
<script>
  document.querySelector('.auth-form').addEventListener('submit', () => {
    document.getElementById('login-overlay').style.display = 'flex';
    document.getElementById('login-btn').disabled = true;
    document.getElementById('login-btn').textContent = 'Please wait…';
  });
</script>
<%- include('../partials/foot') %>
