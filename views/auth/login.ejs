<%- include('../partials/head', { title: 'Log in' }) %>
<main class="auth-page">
  <div class="auth-card">
    <div class="auth-logo"><%= siteName %></div>
    <h1 class="auth-title">Log in</h1>
    <p class="auth-subtitle">Enter your email and we'll send you a link.</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/auth/login" class="auth-form">
      <input type="hidden" name="next" value="<%= next %>">
      <div class="form-group">
        <label for="email">Email address</label>
        <input
          type="email"
          id="email"
          name="email"
          value="<%= email %>"
          placeholder="you@example.com"
          autocomplete="email"
          autofocus
          required
          class="form-input"
        >
      </div>
      <button type="submit" class="btn btn-primary btn-full">Send login link</button>
    </form>
  </div>
</main>
<%- include('../partials/foot') %>
