<%- include('../partials/head', { title: 'Security' }) %>
<%- include('../partials/nav') %>

<main class="container" style="max-width:680px">
  <div class="page-toolbar">
    <h1 class="page-title">Security</h1>
  </div>

  <% if (success) { %>
    <div class="alert alert-success" style="margin-bottom:1.25rem"><%= success %></div>
  <% } %>
  <% if (error && !totpSetup) { %>
    <div class="alert alert-error" style="margin-bottom:1.25rem"><%= error %></div>
  <% } %>

  <!-- ── Password ──────────────────────────────────────────── -->
  <div class="card" style="margin-bottom:1.25rem">
    <h2 class="settings-section-title">Password</h2>

    <% if (!passwordLoginEnabled) { %>
      <p style="color:var(--text-muted);font-size:.9rem">Password-based login is disabled. Contact your administrator to enable it.</p>
    <% } else { %>
      <p style="margin-bottom:1rem;font-size:.9rem;color:var(--text-muted)">
        <% if (user.password_hash) { %>Password is set. You can sign in with your email and password.<% } else { %>No password set. Add one to enable password-based login.<% } %>
      </p>
      <form method="POST" action="/account/password">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% if (user.password_hash) { %>
        <div class="form-group">
          <label for="current_password">Current password</label>
          <input type="password" id="current_password" name="current_password"
                 autocomplete="current-password" class="form-input" style="max-width:320px">
        </div>
        <% } %>
        <div class="form-group">
          <label for="new_password"><%= user.password_hash ? 'New password' : 'Password' %></label>
          <input type="password" id="new_password" name="new_password"
                 autocomplete="new-password" class="form-input" style="max-width:320px" minlength="8">
          <p class="form-hint">Minimum 8 characters.</p>
        </div>
        <div class="form-group">
          <label for="confirm_password">Confirm password</label>
          <input type="password" id="confirm_password" name="confirm_password"
                 autocomplete="new-password" class="form-input" style="max-width:320px">
        </div>
        <button type="submit" class="btn btn-primary"><%= user.password_hash ? 'Change password' : 'Set password' %></button>
      </form>
    <% } %>
  </div>

  <!-- ── Authenticator app (TOTP) ──────────────────────────── -->
  <% if (passwordLoginEnabled) { %>
  <div class="card" style="margin-bottom:1.25rem">
    <h2 class="settings-section-title">Authenticator App</h2>

    <% if (totpSetup) { %>
      <%# Setup flow: show QR + verification form %>
      <% if (error) { %>
        <div class="alert alert-error" style="margin-bottom:1rem"><%= error %></div>
      <% } %>
      <p style="margin-bottom:1rem;font-size:.9rem;color:var(--text-muted)">
        Scan this QR code with your authenticator app (Google Authenticator, Authy, 1Password, etc.), then enter the 6-digit code to confirm.
      </p>
      <div style="margin-bottom:1rem">
        <img src="<%= totpSetup.qrData %>" alt="TOTP QR code" style="display:block;width:180px;height:180px;border-radius:.5rem">
      </div>
      <details style="margin-bottom:1rem">
        <summary style="cursor:pointer;font-size:.85rem;color:var(--text-muted)">Can't scan? Enter code manually</summary>
        <code style="display:block;margin-top:.5rem;font-size:.85rem;word-break:break-all;padding:.5rem;background:var(--bg-subtle);border-radius:.375rem"><%= totpSetup.secret %></code>
      </details>
      <form method="POST" action="/account/totp/enable" id="totp-enable-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label for="totp-verify-code">Verification code</label>
          <input type="text" id="totp-verify-code" name="totp_code"
                 inputmode="numeric" maxlength="6" placeholder="000000"
                 autocomplete="one-time-code" autofocus required class="form-input otp-input" style="max-width:180px">
        </div>
        <div style="display:flex;gap:.5rem;flex-wrap:wrap">
          <button type="submit" class="btn btn-primary">Enable authenticator</button>
          <a href="/account/security" class="btn btn-ghost">Cancel</a>
        </div>
      </form>
      <script>
        var totpInput = document.getElementById('totp-verify-code');
        if (totpInput) {
          totpInput.addEventListener('input', function() {
            var v = totpInput.value.replace(/\D/g, '');
            if (v.length === 6) { totpInput.value = v; document.getElementById('totp-enable-form').submit(); }
          });
        }
      </script>
    <% } else if (user.totp_enabled) { %>
      <%# TOTP active — offer disable %>
      <p style="margin-bottom:1rem;font-size:.9rem">
        <span class="badge badge-success" style="margin-right:.5rem">Active</span>
        Your account is protected with an authenticator app.
      </p>
      <form method="POST" action="/account/totp/disable">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label for="totp-disable-code">Enter your current authenticator code to remove TOTP</label>
          <input type="text" id="totp-disable-code" name="totp_code"
                 inputmode="numeric" maxlength="6" placeholder="000000"
                 autocomplete="one-time-code" required class="form-input otp-input" style="max-width:180px">
        </div>
        <button type="submit" class="btn btn-danger" onclick="return confirm('Remove authenticator app protection from your account?')">Remove authenticator</button>
      </form>
    <% } else { %>
      <%# Not set up %>
      <p style="margin-bottom:1rem;font-size:.9rem;color:var(--text-muted)">
        Add an extra layer of security. You'll enter a code from your authenticator app each time you sign in with a password.
      </p>
      <form method="POST" action="/account/totp/setup">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-secondary">Set up authenticator app</button>
      </form>
    <% } %>
  </div>
  <% } %>

</main>
<%- include('../partials/foot') %>
