<% if (showBackupDirMissingBanner) { %>
<div class="impersonation-banner" style="background:#fee2e2;color:#991b1b;border-bottom:1px solid #fca5a5">
  Backup directory does not exist. Automatic backups are not being made.
</div>
<% } %>
<% if (showBackupFailedBanner) { %>
<div class="impersonation-banner" id="backup-failed-banner"
     style="background:#fee2e2;color:#991b1b;border-bottom:1px solid #fca5a5"
     data-failed-at="<%= backupFailedAt %>">
  Last automatic backup failed.
  <button type="button"
          style="background:none;border:none;cursor:pointer;color:#991b1b;font-size:.8rem;margin-left:.75rem;text-decoration:underline"
          onclick="dismissBackupFailedBanner()">hide</button>
</div>
<% } %>
<% if (user && user.role === 'admin' && showUpdateBanner) { %>
<div class="impersonation-banner" id="update-banner" data-version="<%= updateVersion %>">
  <span>Tix update available &mdash; v<%= updateVersion %></span>
  <button type="button" class="btn btn-sm"
          style="background:#fff;color:#92400e;border:1px solid #92400e;padding:.2rem .6rem;font-size:.8rem;margin-left:.75rem"
          onclick="startInstall()">Install</button>
  <button type="button"
          style="background:none;border:none;cursor:pointer;color:#92400e;font-size:.8rem;margin-left:.75rem;text-decoration:underline"
          onclick="dismissUpdateBanner()">hide</button>
</div>
<% } %>
<% if (impersonatingAdminEmail) { %>
<div class="impersonation-banner">
  <span>Viewing as <strong><%= user ? user.email : '' %></strong> &mdash; signed in as admin (<%= impersonatingAdminEmail %>)</span>
  <form method="POST" action="/auth/impersonate-return" style="display:inline;margin-left:.75rem">
    <button type="submit" class="btn btn-sm" style="background:#fff;color:#92400e;border:1px solid #92400e;padding:.2rem .6rem;font-size:.8rem">↩ Return to Admin</button>
  </form>
</div>
<% } %>
<header class="app-header">
  <div class="app-header-inner">
    <a href="/" class="app-logo"><%= siteName %></a>
    <nav class="app-nav" id="app-nav">
      <% if (user) { %><a href="/tickets/new" class="btn btn-primary btn-sm nav-new-ticket">+ New Ticket</a><% } %>
      <% if (user) { %><a href="/dashboard" class="nav-link">Dashboard</a><% } %>
      <div class="nav-dropdown">
        <a href="/tickets" class="nav-link nav-dropdown-toggle">Tickets</a>
        <div class="nav-dropdown-menu">
          <a href="/tickets" class="nav-dropdown-item">List</a>
          <a href="/timeline" class="nav-dropdown-item">Timeline</a>
        </div>
      </div>
      <% if (user) { %><a href="/reports" class="nav-link">Reports</a><% } %>
      <% if (user && user.role === 'admin') { %>
        <a href="/admin/users" class="nav-link">Users</a>
        <a href="/admin/organizations" class="nav-link">Organizations</a>
        <a href="/admin/settings" class="nav-link">Settings</a>
        <a href="/admin/logs" class="nav-link">Logs</a>
      <% } %>
    </nav>
    <div class="app-header-right">
      <% if (user) { %>
        <span class="user-email"><%= user.email %></span>
        <form method="POST" action="/auth/logout" style="display:inline">
          <button type="submit" class="btn btn-ghost btn-sm">Log out</button>
        </form>
      <% } %>
    </div>
    <button class="hamburger-btn" id="hamburger-btn" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
<script>
(function() {
  var btn = document.getElementById('hamburger-btn');
  var nav = document.getElementById('app-nav');
  if (!btn || !nav) return;
  btn.addEventListener('click', function() {
    var open = nav.classList.toggle('nav-open');
    btn.setAttribute('aria-expanded', open);
    btn.classList.toggle('hamburger-active', open);
  });
  nav.addEventListener('click', function(e) {
    if (e.target.closest('a[href]')) {
      nav.classList.remove('nav-open');
      btn.classList.remove('hamburger-active');
      btn.setAttribute('aria-expanded', 'false');
    }
  });
})();
</script>

<% if (user && user.role === 'admin') { %>
<div id="install-overlay" style="display:none;position:fixed;inset:0;background:rgba(15,23,42,.8);z-index:9999;align-items:center;justify-content:center;flex-direction:column;gap:1rem">
  <div style="width:44px;height:44px;border:4px solid rgba(255,255,255,.2);border-top-color:#60a5fa;border-radius:50%;animation:spin .75s linear infinite"></div>
  <p style="color:#f1f5f9;font-size:1rem">Updating&hellip; please wait</p>
  <p style="color:#94a3b8;font-size:.8rem">The app will reload automatically when the update is complete.</p>
</div>
<script>
function dismissUpdateBanner() {
  var el = document.getElementById('update-banner');
  if (!el) return;
  document.cookie = 'update_dismissed=' + encodeURIComponent(el.dataset.version) + ';path=/;max-age=2592000';
  el.style.display = 'none';
}

function startInstall() {
  if (!confirm('Install the update now?\n\nThe database will be backed up first. The app will restart automatically.')) return;
  var overlay = document.getElementById('install-overlay');
  overlay.style.cssText = 'display:flex;position:fixed;inset:0;background:rgba(15,23,42,.8);z-index:9999;align-items:center;justify-content:center;flex-direction:column;gap:1rem';
  fetch('/admin/update/install', {
    method: 'POST',
    headers: { 'X-CSRF-Token': '<%= csrfToken %>' },
    credentials: 'include',
  }).then(function(r) {
    if (!r.ok) {
      return r.json().then(function(d) {
        overlay.style.display = 'none';
        alert('Update blocked: ' + (d.error || 'Backup failed before update.'));
      });
    }
    setTimeout(pollUntilUp, 4000);
  }).catch(function() {
    overlay.style.display = 'none';
    alert('Update request failed. Please try again.');
  });
}

function dismissBackupFailedBanner() {
  var el = document.getElementById('backup-failed-banner');
  if (!el) return;
  document.cookie = 'backup_failed_dismissed=' + encodeURIComponent(el.dataset.failedAt) + ';path=/;max-age=2592000';
  el.style.display = 'none';
}

function pollUntilUp() {
  fetch('/admin/update/ping', { credentials: 'include' })
    .then(function(r) {
      if (r.ok) { window.location.href = '/tickets'; }
      else { setTimeout(pollUntilUp, 2000); }
    })
    .catch(function() { setTimeout(pollUntilUp, 2000); });
}
</script>
<% } %>
