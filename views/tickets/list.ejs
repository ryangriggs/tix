<%- include('../partials/head', { title: 'Tickets' }) %>
<%- include('../partials/nav') %>
<% function fmtUser(u) {
  let s = u.name ? `${u.name} (${u.email})` : u.email;
  if (u.organization_name) s += ` - ${u.organization_name}`;
  return s;
} %>

<main class="container">
  <div class="page-toolbar">
    <h1 class="page-title">Tickets</h1>
  </div>

  <!-- Filters & Search -->
  <form method="GET" action="/tickets" class="filter-bar" id="filter-form">
    <% const activeStatuses   = (filters.status   || '').split(',').filter(Boolean); %>
    <% const activePriorities = (filters.priority || '').split(',').filter(Boolean); %>

    <!-- Hidden inputs -->
    <input type="hidden" name="status"   id="filter-status"   value="<%= filters.status %>">
    <input type="hidden" name="priority" id="filter-priority" value="<%= filters.priority %>">
    <input type="hidden" name="sort"     value="<%= filters.sort %>">
    <input type="hidden" name="order"    value="<%= filters.order %>">
    <% if (!organizations || !organizations.length) { %><input type="hidden" name="org" value=""><% } %>

    <!-- Search — prominent, top row -->
    <div class="filter-search-row">
      <div class="search-wrap">
        <input type="text" name="q" id="search-input" value="<%= filters.q %>" placeholder="Search tickets…" class="form-input filter-search-input">
        <button type="button" class="search-clear" id="search-clear" title="Clear search"
          style="<%= filters.q ? '' : 'display:none' %>">×</button>
      </div>
      <button type="button" class="btn btn-secondary btn-sm" onclick="this.form.submit()">🔎 Search</button>
      <button type="button" class="btn btn-sm btn-ghost" onclick="resetFilters()" title="Reset all filters to defaults">↺ Reset</button>
    </div>

    <!-- Status + Priority + Date + Org — groups wrap as whole units -->
    <div class="filter-row">

      <!-- Status group -->
      <div class="filter-group">
        <% const statuses = ['new','open','on_hold','closed']; %>
        <% const statusNames = { new:'New', open:'Open', on_hold:'On Hold', closed:'Closed' }; %>
        <% const statusColors = { new:'#fbbf24', open:'#3b82f6', on_hold:'#f97316', closed:'#d1d5db' }; %>
        <span class="filter-row-label">Status</span>
        <button type="button" class="filter-tab <%= !activeStatuses.length ? 'active' : '' %>"
                onclick="toggleAll('status')">All</button>
        <% for (const s of statuses) { %>
          <button type="button" class="filter-tab filter-tab-status filter-tab-s-<%= s %> <%= activeStatuses.includes(s) ? 'active' : '' %>"
                  style="border-left: 4px solid <%= statusColors[s] %>"
                  onclick="toggleFilter('status','<%= s %>')"><%= statusNames[s] %></button>
        <% } %>
      </div>

      <!-- Priority group -->
      <div class="filter-group">
        <% const priorities = ['urgent','high','medium','low']; %>
        <% const priorityNames = { urgent:'Urgent', high:'High', medium:'Medium', low:'Low' }; %>
        <span class="filter-row-label">Priority</span>
        <button type="button" class="filter-tab <%= !activePriorities.length ? 'active' : '' %>"
                onclick="toggleAll('priority')">All</button>
        <% for (const p of priorities) { %>
          <button type="button" class="filter-tab filter-tab-p-<%= p %> <%= activePriorities.includes(p) ? 'active' : '' %>"
                  onclick="toggleFilter('priority','<%= p %>')"><span class="priority-dot priority-dot-<%= p %>"></span> <%= priorityNames[p] %></button>
        <% } %>
      </div>

      <!-- Date group -->
      <div class="filter-group">
        <input type="hidden" name="since" id="filter-since" value="<%= filters.since %>">
        <span class="filter-row-label">Date</span>
        <% const sinceOpts = [['1d','24h'],['7d','7d'],['30d','30d'],['','All'],['custom','Custom']]; %>
        <% for (const [val, label] of sinceOpts) { %>
          <button type="button" class="filter-tab <%= filters.since===val ? 'active' : '' %>"
                  onclick="setSince('<%= val %>')"><%= label %></button>
        <% } %>
        <% if (filters.since === 'custom') { %>
          <input type="date" name="date_from" value="<%= filters.date_from %>" class="form-input form-input-sm filter-date-input" title="From">
          <span class="filter-date-sep">–</span>
          <input type="date" name="date_to"   value="<%= filters.date_to %>"   class="form-input form-input-sm filter-date-input" title="To">
          <button type="submit" class="btn btn-sm btn-secondary">Go</button>
        <% } %>
      </div>

      <!-- Org group -->
      <% if (organizations && organizations.length) { %>
        <div class="filter-group">
          <select name="org" class="form-select" onchange="this.form.submit()">
            <option value="" <%= !filters.org ? 'selected' : '' %>>Any org</option>
            <option value="unassigned" <%= filters.org === 'unassigned' ? 'selected' : '' %>>Not assigned</option>
            <% for (const o of organizations) { %>
              <option value="<%= o.id %>" <%= filters.org == o.id ? 'selected' : '' %>><%= o.name %></option>
            <% } %>
          </select>
        </div>
      <% } %>

      <!-- Assigned To group -->
      <% if (canFilterOwner) { %>
        <div class="filter-group">
          <select name="owner" class="form-select" onchange="this.form.submit()">
            <option value="me" <%= filters.owner === 'me' ? 'selected' : '' %>>Assigned to me</option>
            <option value=""   <%= !filters.owner || filters.owner === '' ? 'selected' : '' %>>All</option>
            <% if (user && user.role === 'admin') { %>
              <option value="unassigned" <%= filters.owner === 'unassigned' ? 'selected' : '' %>>Unassigned</option>
            <% } %>
            <% for (const o of distinctOwners) { %>
              <option value="<%= o.id %>" <%= filters.owner == o.id ? 'selected' : '' %>><%= fmtUser(o) %></option>
            <% } %>
          </select>
        </div>
      <% } else { %>
        <input type="hidden" name="owner" value="">
      <% } %>

    </div>
  </form>

  <!-- Mobile sort bar (hidden on desktop) -->
  <div class="mobile-sort-bar">
    <label for="mobile-sort" style="flex-shrink:0">Sort</label>
    <select id="mobile-sort" class="form-select form-select-sm" onchange="setSort(this.value)">
      <option value="updated_at"   <%= filters.sort==='updated_at'   ? 'selected':'' %>>Updated</option>
      <option value="priority"     <%= filters.sort==='priority'     ? 'selected':'' %>>Priority</option>
      <option value="status"       <%= filters.sort==='status'       ? 'selected':'' %>>Status</option>
      <option value="id"           <%= filters.sort==='id'           ? 'selected':'' %>>Ticket #</option>
      <option value="subject"      <%= filters.sort==='subject'      ? 'selected':'' %>>Subject</option>
      <option value="organization" <%= filters.sort==='organization' ? 'selected':'' %>>Org</option>
    </select>
    <button type="button" class="btn btn-sm btn-ghost" onclick="setSort('<%= filters.sort %>')" title="Toggle sort direction"><%= filters.order === 'desc' ? '↓' : '↑' %></button>
  </div>

  <!-- Column headers -->
  <div class="ticket-list-header">
    <div class="tlh-inner">
      <div class="tc-num" style="display:flex;align-items:center;gap:.25rem">
        <button type="button" class="tlh-sort-btn <%= filters.sort==='status'   ? 'tlh-active':'' %>" onclick="setSort('status')"   title="Sort by status">S<%= filters.sort==='status'   ? (filters.order==='desc'?' ↓':' ↑'):'' %></button>
        <span style="color:var(--border)">·</span>
        <button type="button" class="tlh-sort-btn <%= filters.sort==='priority' ? 'tlh-active':'' %>" onclick="setSort('priority')" title="Sort by priority">P<%= filters.sort==='priority' ? (filters.order==='desc'?' ↓':' ↑'):'' %></button>
        <span style="color:var(--border)">·</span>
        <button type="button" class="tlh-sort-btn <%= filters.sort==='id'       ? 'tlh-active':'' %>" onclick="setSort('id')"       title="Sort by ticket #">#<%= filters.sort==='id'       ? (filters.order==='desc'?' ↓':' ↑'):'' %></button>
      </div>
      <button type="button" class="tc-subject tlh-sort-btn <%= filters.sort==='subject'      ? 'tlh-active':'' %>" onclick="setSort('subject')"     >Subject<%= filters.sort==='subject'      ? (filters.order==='desc'?' ↓':' ↑'):'' %></button>
      <button type="button" class="tc-org     tlh-sort-btn <%= filters.sort==='organization' ? 'tlh-active':'' %>" onclick="setSort('organization')">Org<%= filters.sort==='organization'    ? (filters.order==='desc'?' ↓':' ↑'):'' %></button>
      <button type="button" class="tc-updated tlh-sort-btn <%= filters.sort==='updated_at'   ? 'tlh-active':'' %>" onclick="setSort('updated_at')"  >Updated<%= filters.sort==='updated_at'   ? (filters.order==='desc'?' ↓':' ↑'):'' %></button>
      <span class="tc-actor tlh-col">Updated by</span>
    </div>
    <% if (user && user.role === 'admin' && tickets.length > 0) { %>
    <div class="ticket-select-wrap tlh-ticket-count">
      <button type="button" class="tlh-sort-btn" id="select-menu-btn"
              onclick="toggleSelectMenu(event)" title="Selection options">...</button>
      <div class="ticket-select-menu" id="select-menu">
        <button type="button" class="tsm-item" onclick="selectAll()">Select All</button>
        <button type="button" class="tsm-item" onclick="deselectAll()">Deselect All</button>
        <button type="button" class="tsm-item" onclick="invertSelection()">Invert Selection</button>
        <div class="tsm-info" id="select-menu-info">0 / <%= tickets.length %> selected</div>
      </div>
    </div>
    <% } else { %>
    <span class="tlh-ticket-count"><%= tickets.length %></span>
    <% } %>
  </div>

  <!-- Ticket list wrapped in bulk form -->
  <form method="POST" action="/tickets/bulk" id="bulk-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="action" id="bulk-action" value="">

    <div class="ticket-list" id="ticket-list">
      <% if (tickets.length === 0) { %>
        <div class="empty-state">
          <p>No tickets found.</p>
          <% if (filters.since) { %>
            <a href="/tickets?status=<%= filters.status %>&priority=<%= filters.priority %>&sort=<%= filters.sort %>&order=<%= filters.order %>&since=" class="btn btn-secondary btn-sm">Show all time</a>
          <% } %>
          <a href="/tickets/new" class="btn btn-primary">Create one</a>
        </div>
      <% } %>

      <% for (const t of tickets) { %>
        <div class="ticket-card status-<%= t.status %>" data-ticket-id="<%= t.id %>">
          <a href="/tickets/<%= t.id %>" class="ticket-card-link">
            <span class="tc-num">
              <span class="priority-dot priority-dot-<%= t.priority %>" title="<%= t.priority %> priority"></span>
              <%= formatTicketId(t.id) %>
            </span>
            <span class="tc-subject"><%= t.subject %></span>
            <span class="tc-org"><%= t.organization_name || '' %></span>
            <span class="tc-updated" data-ts="<%= t.updated_at %>" data-actor="<%= t.last_actor || '' %>"><%= formatDate(t.updated_at) %></span>
            <span class="tc-actor"<% if (t.last_actor && t.last_actor !== t.last_actor_email) { %> title="<%= t.last_actor_email %>"<% } %>><%= t.last_actor || '' %></span>
          </a>
          <% if (user && user.role === 'admin') { %>
            <label class="ticket-card-checkbox" title="Select ticket">
              <input type="checkbox" name="ticketIds[]" value="<%= t.id %>" class="ticket-checkbox" onchange="updateBulkBar()">
            </label>
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- Floating bulk action bar — shown when tickets are selected -->
    <div class="bulk-bar" id="bulk-bar">
      <span class="bulk-count" id="bulk-count">0 selected</span>
      <div class="bulk-actions">
        <select id="bulk-status" name="bulkStatus" class="form-select form-select-sm" onchange="bulkSubmit('status')">
          <option value="">Status…</option>
          <option value="new">New</option>
          <option value="open">Open</option>
          <option value="on_hold">On Hold</option>
          <option value="closed">Closed</option>
        </select>
        <select id="bulk-priority" name="bulkPriority" class="form-select form-select-sm" onchange="bulkSubmit('priority')">
          <option value="">Priority…</option>
          <option value="urgent">🔴 Urgent</option>
          <option value="high">🟠 High</option>
          <option value="medium">🔵 Medium</option>
          <option value="low">⚫ Low</option>
        </select>
        <% if (assignableUsers && assignableUsers.length) { %>
        <select id="bulk-assignee" name="bulkAssignee" class="form-select form-select-sm" onchange="bulkSubmit('assign')">
          <option value="">Assign to…</option>
          <% for (const u of assignableUsers) { %>
            <option value="<%= u.id %>"><%= fmtUser(u) %></option>
          <% } %>
        </select>
        <% } %>
        <button type="button" class="btn btn-sm btn-danger" onclick="bulkDelete()">Delete</button>
      </div>
    </div>
  </form>
</main>

<!-- Scroll-to-top button -->
<button class="scroll-top-btn" id="scroll-top-btn" onclick="window.scrollTo({top:0,behavior:'smooth'})" title="Back to top" aria-label="Back to top">↑</button>

<script>
function setSince(val) {
  document.getElementById('filter-since').value = val;
  const form = document.getElementById('filter-form');
  if (val !== 'custom') {
    const df = form.querySelector('[name="date_from"]');
    const dt = form.querySelector('[name="date_to"]');
    if (df) df.value = '';
    if (dt) dt.value = '';
  }
  form.submit();
}

function toggleFilter(name, value) {
  const el = document.getElementById('filter-' + name);
  const vals = el.value ? el.value.split(',') : [];
  const idx = vals.indexOf(value);
  if (idx >= 0) vals.splice(idx, 1); else vals.push(value);
  el.value = vals.join(',');
  document.getElementById('filter-form').submit();
}

function toggleAll(name) {
  document.getElementById('filter-' + name).value = '';
  document.getElementById('filter-form').submit();
}

function resetFilters() {
  const form = document.getElementById('filter-form');
  document.getElementById('filter-status').value = 'new,open,on_hold';
  document.getElementById('filter-priority').value = '';
  form.querySelector('[name="sort"]').value = 'priority';
  form.querySelector('[name="order"]').value = 'desc';
  document.getElementById('filter-since').value = '1d';
  document.getElementById('search-input').value = '';
  document.getElementById('search-clear').style.display = 'none';
  const orgSel = form.querySelector('select[name="org"]');
  if (orgSel) orgSel.value = '';
  const ownerSel = form.querySelector('select[name="owner"]');
  if (ownerSel) ownerSel.value = 'me';
  const df = form.querySelector('[name="date_from"]');
  const dt = form.querySelector('[name="date_to"]');
  if (df) df.value = '';
  if (dt) dt.value = '';
  form.submit();
}

function setSort(col) {
  const form = document.getElementById('filter-form');
  const sortInput = form.querySelector('[name="sort"]');
  const orderInput = form.querySelector('[name="order"]');
  const isCurrent = sortInput.value === col;
  orderInput.value = isCurrent && orderInput.value === 'desc' ? 'asc' : 'desc';
  sortInput.value = col;
  form.submit();
}

function updateBulkBar() {
  const checked = document.querySelectorAll('.ticket-checkbox:checked');
  const total   = document.querySelectorAll('.ticket-checkbox').length;
  const bar = document.getElementById('bulk-bar');
  document.getElementById('bulk-count').textContent = `${checked.length} selected`;
  bar.classList.toggle('bulk-bar-visible', checked.length > 0);
  const info = document.getElementById('select-menu-info');
  if (info) info.textContent = `${checked.length} / ${total} selected`;
}

function toggleSelectMenu(e) {
  e.stopPropagation();
  const menu = document.getElementById('select-menu');
  menu.classList.toggle('open');
}

function selectAll() {
  document.querySelectorAll('.ticket-checkbox').forEach(cb => { cb.checked = true; });
  updateBulkBar();
  document.getElementById('select-menu').classList.remove('open');
}

function deselectAll() {
  document.querySelectorAll('.ticket-checkbox').forEach(cb => { cb.checked = false; });
  updateBulkBar();
  document.getElementById('select-menu').classList.remove('open');
}

function invertSelection() {
  document.querySelectorAll('.ticket-checkbox').forEach(cb => { cb.checked = !cb.checked; });
  updateBulkBar();
  document.getElementById('select-menu').classList.remove('open');
}

// Close dropdown when clicking outside
document.addEventListener('click', () => {
  document.getElementById('select-menu')?.classList.remove('open');
});

function bulkSubmit(type) {
  const checked = document.querySelectorAll('.ticket-checkbox:checked');
  if (!checked.length) return;
  const selectId = type === 'status' ? 'bulk-status' : type === 'priority' ? 'bulk-priority' : 'bulk-assignee';
  const select = document.getElementById(selectId);
  const value = select.value;
  if (!value) return;
  const label = type === 'assign'
    ? select.options[select.selectedIndex].text
    : type === 'status' ? value.replace('_', ' ') : value;
  const noun = type === 'assign' ? 'assignee' : type;
  if (confirm(`Change ${noun} of ${checked.length} ticket${checked.length !== 1 ? 's' : ''} to "${label}"?`)) {
    document.getElementById('bulk-action').value = type;
    document.getElementById('bulk-form').submit();
  } else {
    select.value = '';
  }
}

function bulkDelete() {
  const checked = document.querySelectorAll('.ticket-checkbox:checked');
  if (!checked.length) return;
  if (confirm(`Permanently delete ${checked.length} ticket${checked.length !== 1 ? 's' : ''}?`)) {
    document.getElementById('bulk-action').value = 'delete';
    document.getElementById('bulk-form').submit();
  }
}

window.addEventListener('scroll', () => {
  document.getElementById('scroll-top-btn').classList.toggle('visible', window.scrollY > 300);
}, { passive: true });

// Focus search box on load — desktop only (mobile focus triggers keyboard)
window.addEventListener('load', () => {
  const si = document.getElementById('search-input');
  const isTouch = ('ontouchstart' in window || navigator.maxTouchPoints > 0);
  if (si && !si.value && !isTouch) si.focus();
});

// Search clear button
const _searchInput = document.getElementById('search-input');
const _searchClear = document.getElementById('search-clear');
if (_searchInput && _searchClear) {
  _searchInput.addEventListener('input', () => {
    _searchClear.style.display = _searchInput.value ? '' : 'none';
  });
  _searchClear.addEventListener('click', () => {
    _searchInput.value = '';
    _searchClear.style.display = 'none';
    document.getElementById('filter-form').submit();
  });
}
</script>

<%- include('../partials/foot') %>
