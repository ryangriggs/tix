<%- include('../partials/head', { title: 'Tickets' }) %>
<%- include('../partials/nav') %>
<% function fmtUser(u) {
  let s = u.name ? `${u.name} (${u.email})` : u.email;
  if (u.organization_name) s += ` - ${u.organization_name}`;
  return s;
} %>

<main class="container">
  <div class="page-toolbar">
    <h1 class="page-title">Tickets</h1>
    <button type="button" class="btn btn-secondary btn-sm" onclick="refreshTicketList()" title="Refresh list" style="margin-left:auto">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
      Refresh
    </button>
  </div>

  <!-- Filters & Search -->
  <form method="GET" action="/tickets" class="filter-bar" id="filter-form">
    <% const activeStatuses   = (filters.status   || '').split(',').filter(Boolean); %>
    <% const activePriorities = (filters.priority || '').split(',').filter(Boolean); %>
    <% const _srtCols = (filters.sort  || '').split(',').map(s => s.trim()).filter(Boolean); %>
    <% const _srtDirs = (filters.order || '').split(',').map(s => s.trim()).filter(Boolean); %>
    <% const _multi   = _srtCols.length > 1; %>
    <% function _sh(col) { const i = _srtCols.indexOf(col); if (i < 0) return ''; const arrow = (_srtDirs[i] || 'desc') === 'desc' ? ' ↓' : ' ↑'; return arrow + (_multi ? `<span class="sort-prec">${i + 1}</span>` : ''); } %>

    <!-- Hidden inputs -->
    <input type="hidden" name="status"   id="filter-status"   value="<%= filters.status %>">
    <input type="hidden" name="priority" id="filter-priority" value="<%= filters.priority %>">
    <input type="hidden" name="sort"     value="<%= filters.sort %>">
    <input type="hidden" name="order"    value="<%= filters.order %>">
    <input type="hidden" name="org"      id="filter-org"      value="<%= filters.org || '' %>">
    <input type="hidden" name="owner"    id="filter-owner"    value="<%= filters.owner || '' %>">
    <input type="hidden" name="view"     id="filter-view"     value="<%= activeViewId || '' %>">

    <!-- Search — prominent, top row -->
    <div class="filter-search-row">
      <div class="search-wrap">
        <input type="text" name="q" id="search-input" value="<%= filters.q %>" placeholder="Search tickets…" class="form-input filter-search-input">
        <button type="button" class="search-clear" id="search-clear" title="Clear search"
          style="<%= filters.q ? '' : 'display:none' %>">×</button>
      </div>
      <button type="button" class="btn btn-secondary btn-sm" onclick="this.form.submit()">🔎 Search</button>
      <button type="button" class="btn btn-sm btn-ghost" onclick="resetFilters()" title="Reset all filters to defaults">↺ Reset</button>
    </div>

    <!-- Status + Priority + Date + Org — groups wrap as whole units -->
    <div class="filter-row">

      <!-- Status group -->
      <div class="filter-group">
        <% const statuses = ['new','pending','open','on_hold','closed']; %>
        <% const statusNames = { new:'New', pending:'Pending', open:'Open', on_hold:'On Hold', closed:'Closed' }; %>
        <% const statusColors = { new:'#fbbf24', pending:'#3b82f6', open:'#22c55e', on_hold:'#f97316', closed:'#6b7280' }; %>
        <span class="filter-row-label">Status</span>
        <button type="button" class="filter-tab <%= !activeStatuses.length ? 'active' : '' %>"
                onclick="toggleAll('status')">All</button>
        <% for (const s of statuses) { %>
          <% const _sActive = activeStatuses.includes(s); %>
          <button type="button" class="filter-tab filter-tab-status filter-tab-s-<%= s %> <%= _sActive ? 'active' : '' %>"
                  style="border-left: 4px solid <%= statusColors[s] %>; padding-right:.35rem"
                  onclick="soloFilter('status','<%= s %>')" title="Show only: <%= statusNames[s] %>"><%= statusNames[s] %><span
                    class="filter-tab-solo<%= _sActive ? ' filter-tab-solo--remove' : '' %>"
                    title="<%= _sActive ? 'Remove from filter' : 'Add to filter' %>"
                    onclick="event.stopPropagation();toggleFilter('status','<%= s %>')" ><%= _sActive ? '−' : '+' %></span></button>
        <% } %>
      </div>

      <!-- Priority group -->
      <div class="filter-group">
        <% const priorities = ['urgent','high','medium','low']; %>
        <% const priorityNames = { urgent:'Urgent', high:'High', medium:'Medium', low:'Low' }; %>
        <span class="filter-row-label">Priority</span>
        <button type="button" class="filter-tab <%= !activePriorities.length ? 'active' : '' %>"
                onclick="toggleAll('priority')">All</button>
        <% for (const p of priorities) { %>
          <button type="button" class="filter-tab filter-tab-p-<%= p %> <%= activePriorities.includes(p) ? 'active' : '' %>"
                  onclick="toggleFilter('priority','<%= p %>')"><span class="priority-dot priority-dot-<%= p %>"></span> <%= priorityNames[p] %></button>
        <% } %>
      </div>

      <!-- Date group -->
      <div class="filter-group">
        <input type="hidden" name="since" id="filter-since" value="<%= filters.since %>">
        <span class="filter-row-label">Date</span>
        <% const sinceOpts = [['','All'],['1d','24h'],['7d','7d'],['30d','30d'],['custom','Custom']]; %>
        <% for (const [val, label] of sinceOpts) { %>
          <button type="button" class="filter-tab <%= filters.since===val ? 'active' : '' %>"
                  onclick="setSince('<%= val %>')"><%= label %></button>
        <% } %>
        <% if (filters.since === 'custom') { %>
          <input type="date" name="date_from" value="<%= filters.date_from %>" class="form-input form-input-sm filter-date-input" title="From">
          <span class="filter-date-sep">–</span>
          <input type="date" name="date_to"   value="<%= filters.date_to %>"   class="form-input form-input-sm filter-date-input" title="To">
          <button type="submit" class="btn btn-sm btn-secondary">Go</button>
        <% } %>
      </div>

      <!-- Org group -->
      <% if (organizations && organizations.length) { %>
      <%
        const _activeOrgs = (filters.org || '').split(',').filter(Boolean);
        function _orgLabel() {
          if (!_activeOrgs.length) return 'Any org';
          const parts = [];
          if (_activeOrgs.includes('unassigned')) parts.push('Not assigned');
          for (const _oid of _activeOrgs.filter(v => v !== 'unassigned')) {
            const _o = organizations.find(o => String(o.id) === _oid);
            if (_o) parts.push(_o.name);
          }
          if (!parts.length) return 'Any org';
          return parts.length === 1 ? parts[0] : parts[0] + ' +' + (parts.length - 1);
        }
      %>
        <div class="filter-group">
          <span class="filter-row-label">Org</span>
          <div class="filter-dropdown" id="org-fdd">
            <button type="button" id="org-fdd-btn"
                    class="filter-dropdown-btn <%= _activeOrgs.length ? 'fdd-active' : '' %>"
                    onclick="fddToggle('org')">
              <span id="org-fdd-label"><%= _orgLabel() %></span>
              <span class="filter-dropdown-arrow">▾</span>
            </button>
            <div class="filter-dropdown-panel" id="org-fdd-panel">
              <label class="filter-dropdown-item">
                <input type="checkbox" id="org-cb-all" <%= !_activeOrgs.length ? 'checked' : '' %>
                       onchange="orgCbChange('all', this)"> Any org
              </label>
              <label class="filter-dropdown-item">
                <input type="checkbox" class="org-spec-cb" data-val="unassigned"
                       <%= _activeOrgs.includes('unassigned') ? 'checked' : '' %>
                       onchange="orgCbChange('unassigned', this)"> Not assigned
              </label>
              <% if (organizations.length) { %><hr class="filter-dropdown-sep"><% } %>
              <% for (const o of organizations) { %>
                <label class="filter-dropdown-item">
                  <input type="checkbox" class="org-spec-cb" data-val="<%= o.id %>"
                         <%= _activeOrgs.includes(String(o.id)) ? 'checked' : '' %>
                         onchange="orgCbChange(<%= o.id %>, this)"> <%= o.name %>
                </label>
              <% } %>
            </div>
          </div>
        </div>
      <% } %>

      <!-- Assigned To group -->
      <% if (canFilterOwner) { %>
      <%
        const _activeOwners = (filters.owner || '').split(',').filter(Boolean);
        function _ownerLabel() {
          if (!_activeOwners.length) return 'All';
          if (_activeOwners.length === 1) {
            if (_activeOwners[0] === 'me') return 'Assigned to me';
            if (_activeOwners[0] === 'unassigned') return 'Not assigned';
            const _u = distinctOwners.find(u => String(u.id) === _activeOwners[0]);
            return _u ? (_u.name || _u.email) : 'Selected';
          }
          return _activeOwners.length + ' selected';
        }
      %>
        <div class="filter-group">
          <span class="filter-row-label">Owner</span>
          <div class="filter-dropdown" id="owner-fdd">
            <button type="button" id="owner-fdd-btn"
                    class="filter-dropdown-btn <%= _activeOwners.length ? 'fdd-active' : '' %>"
                    onclick="fddToggle('owner')">
              <span id="owner-fdd-label"><%= _ownerLabel() %></span>
              <span class="filter-dropdown-arrow">▾</span>
            </button>
            <div class="filter-dropdown-panel" id="owner-fdd-panel">
              <label class="filter-dropdown-item">
                <input type="checkbox" id="owner-cb-all" <%= !_activeOwners.length ? 'checked' : '' %>
                       onchange="ownerCbChange('all', this)"> All
              </label>
              <label class="filter-dropdown-item">
                <input type="checkbox" class="owner-spec-cb" data-val="me"
                       <%= _activeOwners.includes('me') ? 'checked' : '' %>
                       onchange="ownerCbChange('me', this)"> Assigned to me
              </label>
              <% if (user && user.role === 'admin') { %>
              <label class="filter-dropdown-item">
                <input type="checkbox" class="owner-spec-cb" data-val="unassigned"
                       <%= _activeOwners.includes('unassigned') ? 'checked' : '' %>
                       onchange="ownerCbChange('unassigned', this)"> Not assigned
              </label>
              <% } %>
              <% if (distinctOwners.length) { %><hr class="filter-dropdown-sep"><% } %>
              <% for (const o of distinctOwners) { %>
                <label class="filter-dropdown-item">
                  <input type="checkbox" class="owner-spec-cb" data-val="<%= o.id %>"
                         <%= _activeOwners.includes(String(o.id)) ? 'checked' : '' %>
                         onchange="ownerCbChange(<%= o.id %>, this)"> <%= fmtUser(o) %>
                </label>
              <% } %>
            </div>
          </div>
        </div>
      <% } %>

      <!-- Views group -->
      <% const _activeView = savedViews.find(v => v.id === activeViewId); %>
      <div class="filter-group" id="views-filter-group">
        <span class="filter-row-label">Views</span>
        <div class="views-split filter-dropdown <%= _activeView ? 'fdd-active' : '' %>" id="views-fdd">
          <button type="button" class="views-split-main" onclick="fddToggle('views')" title="Load a saved view">
            <span id="views-fdd-label"><%= _activeView ? _activeView.name : 'Load view' %></span>
            <span class="filter-dropdown-arrow">▾</span>
          </button>
          <div class="views-split-divider"></div>
          <button type="button" class="views-split-new" onclick="viewNew()" title="Save current filters as a new view">+</button>
          <div class="filter-dropdown-panel" id="views-fdd-panel">
            <% if (!savedViews.length) { %>
              <div class="filter-dropdown-item" style="color:var(--text-muted);font-style:italic;cursor:default">No saved views yet</div>
            <% } %>
            <% for (const v of savedViews) { %>
              <div class="filter-dropdown-item views-item">
                <span class="views-item-name <%= v.id === activeViewId ? 'views-item-active' : '' %>"
                      onclick="loadView(<%= v.id %>)"><%= v.name %><% if (v.id === activeViewId) { %> <span style="color:var(--accent)">✓</span><% } %></span>
                <span class="views-item-actions">
                  <button type="button" class="views-icon-btn" onclick="viewSave(<%= v.id %>, event)" title="Save current filters to this view"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg></button>
                  <button type="button" class="views-icon-btn" onclick="viewRename(<%= v.id %>, event)" title="Rename this view"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                  <button type="button" class="views-icon-btn views-icon-btn-del" onclick="viewDelete(<%= v.id %>, event)" title="Delete this view"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg></button>
                </span>
              </div>
            <% } %>
            <div id="views-fdd-status" style="font-size:.75rem;color:var(--text-muted);padding:.2rem .85rem;min-height:1.1em"></div>
          </div>
        </div>
      </div>

    </div>
  </form>

  <!-- Mobile sort bar (hidden on desktop) -->
  <div class="mobile-sort-bar">
    <label for="mobile-sort" style="flex-shrink:0">Sort</label>
    <select id="mobile-sort" class="form-select form-select-sm" onchange="setSort(this.value, null)">
      <option value="updated_at"   <%= _srtCols[0]==='updated_at'   ? 'selected':'' %>>Updated</option>
      <option value="created_at"   <%= _srtCols[0]==='created_at'   ? 'selected':'' %>>Created</option>
      <option value="priority"     <%= _srtCols[0]==='priority'     ? 'selected':'' %>>Priority</option>
      <option value="status"       <%= _srtCols[0]==='status'       ? 'selected':'' %>>Status</option>
      <option value="id"           <%= _srtCols[0]==='id'           ? 'selected':'' %>>Ticket #</option>
      <option value="subject"      <%= _srtCols[0]==='subject'      ? 'selected':'' %>>Subject</option>
      <option value="organization" <%= _srtCols[0]==='organization' ? 'selected':'' %>>Org</option>
    </select>
    <button type="button" class="btn btn-sm btn-ghost" onclick="setSort('<%= _srtCols[0] || 'priority' %>', null)" title="Toggle sort direction"><%= (_srtDirs[0] || 'desc') === 'desc' ? '↓' : '↑' %></button>
  </div>

  <!-- Column headers -->
  <div class="ticket-list-header">
    <div class="tlh-inner">
      <div class="tc-num" style="display:flex;align-items:center;gap:.25rem">
        <button type="button" class="tlh-sort-btn <%= _srtCols.includes('status')   ? 'tlh-active':'' %>" onclick="setSort('status',   event)" title="Sort by status (Ctrl+click to add)">S<%- _sh('status') %></button>
        <span style="color:var(--border)">·</span>
        <button type="button" class="tlh-sort-btn <%= _srtCols.includes('priority') ? 'tlh-active':'' %>" onclick="setSort('priority', event)" title="Sort by priority (Ctrl+click to add)">P<%- _sh('priority') %></button>
        <span style="color:var(--border)">·</span>
        <button type="button" class="tlh-sort-btn <%= _srtCols.includes('id')       ? 'tlh-active':'' %>" onclick="setSort('id',       event)" title="Sort by ticket # (Ctrl+click to add)">#<%- _sh('id') %></button>
      </div>
      <button type="button" class="tc-subject tlh-sort-btn <%= _srtCols.includes('subject')      ? 'tlh-active':'' %>" onclick="setSort('subject',      event)" title="Ctrl+click to add to sort">Subject<%- _sh('subject') %></button>
      <button type="button" class="tc-org     tlh-sort-btn <%= _srtCols.includes('organization') ? 'tlh-active':'' %>" onclick="setSort('organization', event)" title="Ctrl+click to add to sort">Org<%- _sh('organization') %></button>
      <button type="button" class="tc-updated tlh-sort-btn <%= _srtCols.includes('updated_at') ? 'tlh-active':'' %>" onclick="setSort('updated_at', event)" title="Ctrl+click to add to sort">Updated<%- _sh('updated_at') %></button>
      <button type="button" class="tc-created tlh-sort-btn <%= _srtCols.includes('created_at') ? 'tlh-active':'' %>" onclick="setSort('created_at', event)" title="Ctrl+click to add to sort">Created<%- _sh('created_at') %></button>
    </div>
    <% if (user && user.role === 'admin' && tickets.length > 0) { %>
    <div class="ticket-select-wrap tlh-ticket-count">
      <button type="button" class="tlh-sort-btn" id="select-menu-btn"
              onclick="toggleSelectMenu(event)" title="Selection options">...</button>
      <div class="ticket-select-menu" id="select-menu">
        <button type="button" class="tsm-item" onclick="selectAll()">Select All</button>
        <button type="button" class="tsm-item" onclick="deselectAll()">Deselect All</button>
        <button type="button" class="tsm-item" onclick="invertSelection()">Invert Selection</button>
        <div class="tsm-info" id="select-menu-info">0 / <%= tickets.length %> selected</div>
      </div>
    </div>
    <% } else { %>
    <span class="tlh-ticket-count"><%= tickets.length %></span>
    <% } %>
  </div>

  <!-- Ticket list wrapped in bulk form -->
  <form method="POST" action="/tickets/bulk" id="bulk-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="action" id="bulk-action" value="">

    <div class="ticket-list" id="ticket-list">
      <div class="list-loading-overlay" id="list-loading-overlay"><span class="btn-spinner"></span></div>
      <% if (tickets.length === 0) { %>
        <div class="empty-state">
          <p>No tickets found.</p>
          <% if (filters.q) { %>
            <button type="button" class="btn btn-secondary btn-sm" onclick="clearFiltersKeepSearch()">Clear filters</button>
          <% } %>
          <% if (filters.since) { %>
            <a href="/tickets?status=<%= filters.status %>&priority=<%= filters.priority %>&sort=<%= filters.sort %>&order=<%= filters.order %>&since=" class="btn btn-secondary btn-sm">Show all time</a>
          <% } %>
          <a href="/tickets/new" class="btn btn-primary">Create one</a>
        </div>
      <% } %>

      <% for (const t of tickets) { %>
        <div class="ticket-card status-<%= t.status %>" data-ticket-id="<%= t.id %>">
          <a href="/tickets/<%= t.id %>" class="ticket-card-link">
            <span class="tc-num">
              <span class="priority-dot priority-dot-<%= t.priority %>" title="<%= t.priority %> priority"></span>
              <%= formatTicketId(t.id) %>
            </span>
            <span class="tc-subject"><%= t.subject %></span>
            <span class="tc-org"><%= t.organization_name || '' %></span>
            <span class="tc-updated" data-ts="<%= t.updated_at %>" data-actor="<%= t.last_actor || '' %>"><%= formatDate(t.updated_at) %></span>
            <span class="tc-created" data-ts="<%= t.created_at %>" title="<%= formatDateFull(t.created_at) %>"><%= formatDate(t.created_at) %></span>
          </a>
          <% if (user && user.role === 'admin') { %>
            <label class="ticket-card-checkbox" title="Select ticket">
              <input type="checkbox" name="ticketIds[]" value="<%= t.id %>" class="ticket-checkbox" onchange="updateBulkBar()">
            </label>
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- Pagination -->
    <%
      const _pq = Object.assign({}, filters);
      delete _pq.page;
      const _pBase = '/tickets?' + Object.entries(_pq).filter(([,v]) => v !== '').map(([k,v]) => k + '=' + encodeURIComponent(v)).join('&');
      function pageUrl(p) { return _pBase + '&page=' + p; }
    %>
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;padding:.75rem 0;margin-top:.25rem;border-top:1px solid var(--border)">
      <div style="display:flex;align-items:center;gap:.5rem;font-size:.875rem;color:var(--text-muted)">
        <span>Show:</span>
        <% for (const pp of [10, 50, 100, 0]) { %>
          <a href="<%= _pBase + '&per_page=' + pp + '&page=1' %>"
             style="padding:.2rem .5rem;border-radius:4px;text-decoration:none;font-weight:500;
                    background:<%= pagination.perPage === pp ? 'var(--primary)' : 'transparent' %>;
                    color:<%= pagination.perPage === pp ? '#fff' : 'var(--text-muted)' %>;
                    border:1px solid <%= pagination.perPage === pp ? 'var(--primary)' : 'var(--border)' %>">
            <%= pp === 0 ? 'All' : pp %>
          </a>
        <% } %>
        <span style="margin-left:.5rem">
          <% if (pagination.perPage > 0) { %>
            <%= (pagination.page - 1) * pagination.perPage + 1 %>–<%= Math.min(pagination.page * pagination.perPage, pagination.total) %> of <%= pagination.total %>
          <% } else { %>
            <%= pagination.total %> total
          <% } %>
        </span>
      </div>
      <% if (pagination.totalPages > 1) { %>
        <div style="display:flex;align-items:center;gap:.25rem">
          <% if (pagination.page > 1) { %>
            <a href="<%= pageUrl(1) %>" style="padding:.25rem .5rem;border:1px solid var(--border);border-radius:4px;text-decoration:none;font-size:.875rem;color:var(--text)">&laquo;</a>
            <a href="<%= pageUrl(pagination.page - 1) %>" style="padding:.25rem .5rem;border:1px solid var(--border);border-radius:4px;text-decoration:none;font-size:.875rem;color:var(--text)">&lsaquo;</a>
          <% } %>
          <%
            const _startPage = Math.max(1, pagination.page - 2);
            const _endPage   = Math.min(pagination.totalPages, pagination.page + 2);
          %>
          <% for (let _pi = _startPage; _pi <= _endPage; _pi++) { %>
            <a href="<%= pageUrl(_pi) %>"
               style="padding:.25rem .5rem;border-radius:4px;text-decoration:none;font-size:.875rem;min-width:2rem;text-align:center;
                      background:<%= _pi === pagination.page ? 'var(--primary)' : 'transparent' %>;
                      color:<%= _pi === pagination.page ? '#fff' : 'var(--text)' %>;
                      border:1px solid <%= _pi === pagination.page ? 'var(--primary)' : 'var(--border)' %>">
              <%= _pi %>
            </a>
          <% } %>
          <% if (pagination.page < pagination.totalPages) { %>
            <a href="<%= pageUrl(pagination.page + 1) %>" style="padding:.25rem .5rem;border:1px solid var(--border);border-radius:4px;text-decoration:none;font-size:.875rem;color:var(--text)">&rsaquo;</a>
            <a href="<%= pageUrl(pagination.totalPages) %>" style="padding:.25rem .5rem;border:1px solid var(--border);border-radius:4px;text-decoration:none;font-size:.875rem;color:var(--text)">&raquo;</a>
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- Floating bulk action bar — shown when tickets are selected -->
    <div class="bulk-bar" id="bulk-bar">
      <span class="bulk-count" id="bulk-count">0 selected</span>
      <div class="bulk-actions">
        <select id="bulk-status" name="bulkStatus" class="form-select form-select-sm" onchange="bulkSubmit('status')">
          <option value="">Status…</option>
          <option value="new">New</option>
          <option value="pending">Pending</option>
          <option value="open">Open</option>
          <option value="on_hold">On Hold</option>
          <option value="closed">Closed</option>
        </select>
        <select id="bulk-priority" name="bulkPriority" class="form-select form-select-sm" onchange="bulkSubmit('priority')">
          <option value="">Priority…</option>
          <option value="urgent">🔴 Urgent</option>
          <option value="high">🟠 High</option>
          <option value="medium">🔵 Medium</option>
          <option value="low">⚫ Low</option>
        </select>
        <% if (assignableUsers && assignableUsers.length) { %>
        <select id="bulk-assignee" name="bulkAssignee" class="form-select form-select-sm" onchange="bulkSubmit('assign')">
          <option value="">Assign to…</option>
          <% for (const u of assignableUsers) { %>
            <option value="<%= u.id %>"><%= fmtUser(u) %></option>
          <% } %>
        </select>
        <% } %>
        <button type="button" class="btn btn-sm btn-danger" onclick="bulkDelete()">Delete</button>
      </div>
    </div>
  </form>
</main>

<!-- Scroll-to-top button -->
<button class="scroll-top-btn" id="scroll-top-btn" onclick="window.scrollTo({top:0,behavior:'smooth'})" title="Back to top" aria-label="Back to top">↑</button>

<script>
// Show loading overlay whenever the filter form navigates
document.getElementById('filter-form').addEventListener('submit', () => {
  document.getElementById('list-loading-overlay').style.display = 'flex';
});

function setSince(val) {
  document.getElementById('filter-since').value = val;
  const form = document.getElementById('filter-form');
  if (val !== 'custom') {
    const df = form.querySelector('[name="date_from"]');
    const dt = form.querySelector('[name="date_to"]');
    if (df) df.value = '';
    if (dt) dt.value = '';
  }
  form.submit();
}

function toggleFilter(name, value) {
  const el = document.getElementById('filter-' + name);
  const vals = el.value ? el.value.split(',') : [];
  const idx = vals.indexOf(value);
  if (idx >= 0) vals.splice(idx, 1); else vals.push(value);
  el.value = vals.join(',');
  document.getElementById('filter-form').submit();
}

function soloFilter(name, value) {
  document.getElementById('filter-' + name).value = value;
  document.getElementById('filter-form').submit();
}

function toggleAll(name) {
  document.getElementById('filter-' + name).value = '';
  document.getElementById('filter-form').submit();
}

function clearFiltersKeepSearch() {
  document.getElementById('filter-status').value = '';
  document.getElementById('filter-priority').value = '';
  document.getElementById('filter-since').value = '';
  document.getElementById('filter-org').value = '';
  document.getElementById('filter-owner').value = '';
  document.getElementById('filter-view').value = '';
  const form = document.getElementById('filter-form');
  const df = form.querySelector('[name="date_from"]');
  const dt = form.querySelector('[name="date_to"]');
  if (df) df.value = '';
  if (dt) dt.value = '';
  form.submit();
}

function resetFilters() {
  const form = document.getElementById('filter-form');
  document.getElementById('filter-status').value = 'new,pending,open,on_hold';
  document.getElementById('filter-priority').value = '';
  form.querySelector('[name="sort"]').value = 'priority';
  form.querySelector('[name="order"]').value = 'desc';
  document.getElementById('filter-since').value = '';
  document.getElementById('search-input').value = '';
  document.getElementById('search-clear').style.display = 'none';
  document.getElementById('filter-org').value = '';
  document.getElementById('filter-owner').value = 'me';
  document.getElementById('filter-view').value = '';
  const df = form.querySelector('[name="date_from"]');
  const dt = form.querySelector('[name="date_to"]');
  if (df) df.value = '';
  if (dt) dt.value = '';
  form.submit();
}

// ---- Multi-select filter dropdowns ----
let _fddDirty = false;

function fddToggle(name) {
  const panel = document.getElementById(name + '-fdd-panel');
  const isOpen = panel.classList.contains('fdd-open');
  _closeAllFdd(true);
  if (!isOpen) {
    panel.classList.add('fdd-open');
    _fddDirty = false;
  }
}

function _closeAllFdd(submit) {
  let wasOpen = false;
  document.querySelectorAll('.filter-dropdown-panel.fdd-open').forEach(p => {
    p.classList.remove('fdd-open');
    wasOpen = true;
  });
  if (wasOpen && submit && _fddDirty) {
    _fddDirty = false;
    document.getElementById('filter-form').submit();
  }
}

document.addEventListener('click', e => {
  if (!e.target.closest('.filter-dropdown')) _closeAllFdd(true);
});
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') _closeAllFdd(true);
});

function _syncFddHidden(name) {
  const checked = [...document.querySelectorAll('.' + name + '-spec-cb:checked')].map(cb => cb.dataset.val);
  document.getElementById('filter-' + name).value = checked.join(',');
  const allCb = document.getElementById(name + '-cb-all');
  if (allCb) allCb.checked = checked.length === 0;
  _fddDirty = true;
}

function orgCbChange(val, el) {
  if (val === 'all') {
    document.querySelectorAll('.org-spec-cb').forEach(cb => { cb.checked = false; });
    document.getElementById('filter-org').value = '';
    _fddDirty = true;
  } else {
    document.getElementById('org-cb-all').checked = false;
    _syncFddHidden('org');
  }
}

function ownerCbChange(val, el) {
  if (val === 'all') {
    document.querySelectorAll('.owner-spec-cb').forEach(cb => { cb.checked = false; });
    document.getElementById('filter-owner').value = '';
    _fddDirty = true;
  } else {
    document.getElementById('owner-cb-all').checked = false;
    _syncFddHidden('owner');
  }
}

// ---- Saved Views ----
const _savedViews  = <%- JSON.stringify(savedViews).replace(/</g, '\\u003C') %>;
const _activeViewId = <%= activeViewId || 'null' %>;
const _viewCsrf     = '<%= csrfToken %>';

function _captureFilters() {
  const form = document.getElementById('filter-form');
  return JSON.stringify({
    status:    document.getElementById('filter-status').value,
    priority:  document.getElementById('filter-priority').value,
    sort:      form.querySelector('[name="sort"]').value,
    order:     form.querySelector('[name="order"]').value,
    since:     document.getElementById('filter-since').value,
    date_from: form.querySelector('[name="date_from"]')?.value || '',
    date_to:   form.querySelector('[name="date_to"]')?.value   || '',
    org:       document.getElementById('filter-org').value,
    owner:     document.getElementById('filter-owner').value,
    q:         document.getElementById('search-input').value,
  });
}

function _viewStatus(msg, isError) {
  const el = document.getElementById('views-fdd-status');
  if (!el) return;
  el.textContent = msg;
  el.style.color = isError ? 'var(--danger)' : 'var(--text-muted)';
  if (msg) setTimeout(() => { if (el.textContent === msg) el.textContent = ''; }, 2500);
}

function loadView(id) {
  const view = _savedViews.find(v => v.id === id);
  if (!view) return;
  const f = JSON.parse(view.filters);
  const params = new URLSearchParams();
  const keys = ['status','priority','sort','order','since','date_from','date_to','org','owner','q'];
  keys.forEach(k => { if (f[k] != null && f[k] !== '') params.set(k, f[k]); });
  params.set('view', id);
  window.location.href = '/tickets?' + params.toString();
}

async function viewSave(id, event) {
  event.stopPropagation();
  const body = new URLSearchParams({ _csrf: _viewCsrf, filters: _captureFilters() });
  const res  = await fetch('/tickets/views/' + id + '/save', { method: 'POST', body });
  const data = await res.json();
  _viewStatus(data.ok ? 'Saved.' : (data.error || 'Error'), !data.ok);
}

async function viewRename(id, event) {
  event.stopPropagation();
  const view = _savedViews.find(v => v.id === id);
  const name = prompt('Rename view:', view?.name || '');
  if (!name || !name.trim()) return;
  const body = new URLSearchParams({ _csrf: _viewCsrf, name: name.trim() });
  const res  = await fetch('/tickets/views/' + id + '/rename', { method: 'POST', body });
  const data = await res.json();
  if (data.ok) { location.reload(); } else { _viewStatus(data.error || 'Error', true); }
}

async function viewDelete(id, event) {
  event.stopPropagation();
  const view = _savedViews.find(v => v.id === id);
  if (!confirm('Delete view "' + (view?.name || '') + '"?')) return;
  const body = new URLSearchParams({ _csrf: _viewCsrf });
  const res  = await fetch('/tickets/views/' + id + '/delete', { method: 'POST', body });
  const data = await res.json();
  if (data.ok) {
    if (id === _activeViewId) document.getElementById('filter-view').value = '';
    document.getElementById('filter-form').submit();
  } else {
    _viewStatus(data.error || 'Error', true);
  }
}

async function viewNew() {
  const name = prompt('View name:');
  if (!name || !name.trim()) return;
  const body = new URLSearchParams({ _csrf: _viewCsrf, name: name.trim(), filters: _captureFilters() });
  const res  = await fetch('/tickets/views', { method: 'POST', body });
  const data = await res.json();
  if (data.ok && data.view) {
    document.getElementById('filter-view').value = data.view.id;
    document.getElementById('filter-form').submit();
  } else {
    _viewStatus(data.error || 'Error', true);
  }
}

function setSort(col, event) {
  const form = document.getElementById('filter-form');
  const sortInput  = form.querySelector('[name="sort"]');
  const orderInput = form.querySelector('[name="order"]');
  const cols   = sortInput.value  ? sortInput.value.split(',')  : [];
  const orders = orderInput.value ? orderInput.value.split(',') : [];

  if (event && event.ctrlKey) {
    const idx = cols.indexOf(col);
    if (idx >= 0) {
      orders[idx] = (orders[idx] || 'desc') === 'desc' ? 'asc' : 'desc';
    } else {
      cols.push(col);
      orders.push('desc');
    }
    sortInput.value  = cols.join(',');
    orderInput.value = orders.join(',');
  } else {
    const isSolo    = cols.length === 1 && cols[0] === col;
    const curDir    = orders[0] || 'desc';
    sortInput.value  = col;
    orderInput.value = isSolo && curDir === 'desc' ? 'asc' : 'desc';
  }
  form.submit();
}

function updateBulkBar() {
  const checked = document.querySelectorAll('.ticket-checkbox:checked');
  const total   = document.querySelectorAll('.ticket-checkbox').length;
  const bar = document.getElementById('bulk-bar');
  document.getElementById('bulk-count').textContent = `${checked.length} selected`;
  bar.classList.toggle('bulk-bar-visible', checked.length > 0);
  const info = document.getElementById('select-menu-info');
  if (info) info.textContent = `${checked.length} / ${total} selected`;
}

function toggleSelectMenu(e) {
  e.stopPropagation();
  const menu = document.getElementById('select-menu');
  menu.classList.toggle('open');
}

function selectAll() {
  document.querySelectorAll('.ticket-checkbox').forEach(cb => { cb.checked = true; });
  updateBulkBar();
  document.getElementById('select-menu').classList.remove('open');
}

function deselectAll() {
  document.querySelectorAll('.ticket-checkbox').forEach(cb => { cb.checked = false; });
  updateBulkBar();
  document.getElementById('select-menu').classList.remove('open');
}

function invertSelection() {
  document.querySelectorAll('.ticket-checkbox').forEach(cb => { cb.checked = !cb.checked; });
  updateBulkBar();
  document.getElementById('select-menu').classList.remove('open');
}

// Close dropdown when clicking outside
document.addEventListener('click', () => {
  document.getElementById('select-menu')?.classList.remove('open');
});

function bulkSubmit(type) {
  const checked = document.querySelectorAll('.ticket-checkbox:checked');
  if (!checked.length) return;
  const selectId = type === 'status' ? 'bulk-status' : type === 'priority' ? 'bulk-priority' : 'bulk-assignee';
  const select = document.getElementById(selectId);
  const value = select.value;
  if (!value) return;
  const label = type === 'assign'
    ? select.options[select.selectedIndex].text
    : type === 'status' ? value.replace('_', ' ') : value;
  const noun = type === 'assign' ? 'assignee' : type;
  if (confirm(`Change ${noun} of ${checked.length} ticket${checked.length !== 1 ? 's' : ''} to "${label}"?`)) {
    document.getElementById('bulk-action').value = type;
    document.getElementById('bulk-form').submit();
  } else {
    select.value = '';
  }
}

function bulkDelete() {
  const checked = document.querySelectorAll('.ticket-checkbox:checked');
  if (!checked.length) return;
  if (confirm(`Permanently delete ${checked.length} ticket${checked.length !== 1 ? 's' : ''}?`)) {
    document.getElementById('bulk-action').value = 'delete';
    document.getElementById('bulk-form').submit();
  }
}

window.addEventListener('scroll', () => {
  document.getElementById('scroll-top-btn').classList.toggle('visible', window.scrollY > 300);
}, { passive: true });

// Focus search box on load — desktop only (mobile focus triggers keyboard)
window.addEventListener('load', () => {
  const si = document.getElementById('search-input');
  const isTouch = ('ontouchstart' in window || navigator.maxTouchPoints > 0);
  if (si && !si.value && !isTouch) si.focus();
});

// Search clear button
const _searchInput = document.getElementById('search-input');
const _searchClear = document.getElementById('search-clear');
if (_searchInput && _searchClear) {
  _searchInput.addEventListener('input', () => {
    _searchClear.style.display = _searchInput.value ? '' : 'none';
  });
  _searchClear.addEventListener('click', () => {
    _searchInput.value = '';
    _searchClear.style.display = 'none';
    document.getElementById('filter-form').submit();
  });
}
</script>

<%- include('../partials/foot') %>
