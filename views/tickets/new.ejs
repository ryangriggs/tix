<%- include('../partials/head', { title: 'New Ticket' }) %>
<%- include('../partials/nav') %>

<!-- Quill -->
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>

<main class="container container-narrow">
  <div class="page-toolbar">
    <a href="/tickets" class="btn btn-ghost">← Back</a>
    <h1 class="page-title">New Ticket</h1>
  </div>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form method="POST" action="/tickets?_csrf=<%= csrfToken %>" enctype="multipart/form-data" id="ticket-form" class="ticket-form">

    <div class="form-group">
      <label for="subject">Subject <span class="required">*</span></label>
      <input type="text" id="subject" name="subject" class="form-input" placeholder="Brief description of the issue" autofocus required>
    </div>

    <div class="form-group">
      <label>Description</label>
      <div id="editor" class="quill-editor"></div>
      <input type="hidden" name="body" id="body">
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="priority">Priority</label>
        <select id="priority" name="priority" class="form-select">
          <option value="low">Low</option>
          <option value="medium" selected>Medium</option>
          <option value="high">High</option>
          <option value="urgent">Urgent</option>
        </select>
      </div>
      <div class="form-group">
        <label for="due_date">Due date <span class="optional">(optional)</span></label>
        <input type="date" id="due_date" name="due_date" class="form-input">
      </div>
    </div>

    <div class="form-group">
      <label for="attachments">Attachments <span class="optional">(optional)</span></label>
      <input type="file" id="attachments" name="attachments" multiple class="form-file">
      <p class="form-hint">Max 25 MB per file. Accepted: images, PDF, text, CSV, ZIP, Office documents.</p>
    </div>

    <div class="form-actions">
      <a href="/tickets" class="btn btn-ghost">Cancel</a>
      <button type="submit" class="btn btn-primary">Create Ticket</button>
    </div>
  </form>
</main>

<script>
  const quill = new Quill('#editor', {
    theme: 'snow',
    placeholder: 'Describe the issue…',
    modules: {
      toolbar: [
        ['bold', 'italic', 'underline', 'strike'],
        ['blockquote', 'code-block'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        ['link'],
        ['clean'],
      ]
    }
  });

  document.getElementById('ticket-form').addEventListener('submit', () => {
    document.getElementById('body').value = quill.root.innerHTML;
  });
</script>

<%- include('../partials/foot') %>
