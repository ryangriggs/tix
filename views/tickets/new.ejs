<%- include('../partials/head', { title: 'New Ticket' }) %>
<%- include('../partials/nav') %>

<!-- Quill -->
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>

<main class="container container-narrow">
  <div class="page-toolbar">
    <a href="/tickets" class="btn btn-ghost">← Back</a>
    <h1 class="page-title">New Ticket</h1>
  </div>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form method="POST" action="/tickets?_csrf=<%= csrfToken %>" enctype="multipart/form-data" id="ticket-form" class="ticket-form">

    <div class="form-group">
      <label for="subject">Subject <span class="required">*</span></label>
      <input type="text" id="subject" name="subject" class="form-input" placeholder="Brief description of the issue" autofocus required>
    </div>

    <div class="form-group">
      <label>Description</label>
      <div id="editor" class="quill-editor"></div>
      <input type="hidden" name="body" id="body">
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="priority">Priority</label>
        <select id="priority" name="priority" class="form-select">
          <option value="urgent">🔴 Urgent</option>
          <option value="high">🟠 High</option>
          <option value="medium" selected>🔵 Medium</option>
          <option value="low">⚫ Low</option>
        </select>
      </div>
      <div class="form-group">
        <label for="due_date">Due date <span class="optional">(optional)</span></label>
        <input type="date" id="due_date" name="due_date" class="form-input">
      </div>
    </div>

    <div class="form-group">
      <label for="organization_name">Organization <span class="optional">(optional)</span></label>
      <div style="position:relative">
        <input type="text" id="organization_name" name="organization_name"
               class="form-input" placeholder="Type to search or click to browse…"
               autocomplete="off"
               value="<%= user && user.organization_name ? user.organization_name : '' %>">
      </div>
      <p class="form-hint">Start typing to search, or click the field to browse existing organizations. Enter a new name to create one.</p>
    </div>

    <div class="form-group">
      <label>Collaborators <span class="optional">(optional)</span></label>
      <div id="new-collab-tags" style="display:flex;flex-wrap:wrap;gap:.35rem;margin-bottom:.375rem"></div>
      <div id="new-collab-hiddens"></div>
      <div style="position:relative">
        <input type="text" id="new-collab-input"
               placeholder="Search by name, email, or org…"
               class="form-input form-input-sm" autocomplete="off">
      </div>
      <p class="form-hint">Search for users, or type an email address and press Enter to add.</p>
    </div>

    <div class="form-group">
      <label for="attachments">Attachments <span class="optional">(optional)</span></label>
      <input type="file" id="attachments" name="attachments" multiple class="form-file">
      <p class="form-hint">Max 25 MB per file. Accepted: images, PDF, text, CSV, ZIP, Office documents.</p>
    </div>

    <div class="form-actions">
      <a href="/tickets" class="btn btn-ghost">Cancel</a>
      <button type="submit" class="btn btn-primary">Create Ticket</button>
    </div>
  </form>
</main>

<script>
  const quill = new Quill('#editor', {
    theme: 'snow',
    placeholder: 'Describe the issue…',
    modules: {
      toolbar: [
        ['bold', 'italic', 'underline', 'strike'],
        ['blockquote', 'code-block'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        ['link'],
        ['clean'],
      ]
    }
  });

  // Tab from subject skips toolbar and jumps directly into editor
  document.getElementById('subject').addEventListener('keydown', function(e) {
    if (e.key === 'Tab' && !e.shiftKey) {
      e.preventDefault();
      quill.focus();
    }
  });

  document.getElementById('ticket-form').addEventListener('submit', () => {
    document.getElementById('body').value = quill.root.innerHTML;
  });

</script>
<script>
document.addEventListener('DOMContentLoaded', () => {
  if (typeof createAutocomplete !== 'function') return;

  // Organization autocomplete
  const orgInput = document.getElementById('organization_name');
  if (orgInput) {
    createAutocomplete(orgInput, {
      fetchUrl: q => `/api/organizations/search?q=${encodeURIComponent(q)}`,
      formatItem: item => `<span>${item.name}</span>`,
      onSelect: item => { orgInput.value = item.name; },
      showOnFocus: true,
    });
  }

  // Collaborators
  const collabInput   = document.getElementById('new-collab-input');
  const collabTags    = document.getElementById('new-collab-tags');
  const collabHiddens = document.getElementById('new-collab-hiddens');
  if (!collabInput) return;

  const _esc = s => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  let _collabKey = 0;

  function addCollab(id, email, display) {
    const key = ++_collabKey;
    const tag = document.createElement('span');
    tag.style.cssText = 'display:inline-flex;align-items:center;gap:.2rem;background:#eff6ff;border:1px solid #bfdbfe;border-radius:999px;padding:.15rem .5rem .15rem .65rem;font-size:.8rem';
    tag.dataset.collabKey = key;
    tag.innerHTML = `<span>${_esc(display)}</span><button type="button" style="background:none;border:none;cursor:pointer;font-size:1.1rem;line-height:1;color:#64748b;padding:0 .1rem" title="Remove">×</button>`;
    tag.querySelector('button').addEventListener('click', () => {
      tag.remove();
      collabHiddens.querySelector(`[data-collab-key="${key}"]`)?.remove();
    });
    collabTags.appendChild(tag);

    const hidden = document.createElement('input');
    hidden.type = 'hidden';
    hidden.dataset.collabKey = key;
    hidden.name = id ? 'collaboratorIds[]' : 'collaboratorEmails[]';
    hidden.value = id || email;
    collabHiddens.appendChild(hidden);
  }

  createAutocomplete(collabInput, {
    fetchUrl: q => `/api/users/search?q=${encodeURIComponent(q)}`,
    formatItem: item => {
      const name = item.name ? `<strong>${item.name}</strong> ` : '';
      const org  = item.org  ? ` <em style="color:#6b7280">[${item.org}]</em>` : '';
      return `${name}(${item.email})${org}`;
    },
    onSelect: item => {
      addCollab(item.id, item.email, item.name || item.email);
      collabInput.value = '';
    },
  });

  collabInput.addEventListener('keydown', e => {
    if (e.key !== 'Enter') return;
    const val = collabInput.value.trim();
    if (!val) return;
    if (/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val)) {
      e.preventDefault();
      addCollab(null, val, val);
      collabInput.value = '';
    }
  });
});
</script>

<%- include('../partials/foot') %>
