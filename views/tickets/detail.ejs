<%- include('../partials/head', { title: `#${formatTicketId(ticket.id)} — ${ticket.subject}` }) %>
<%- include('../partials/nav') %>

<!-- Quill (only needed for the comment editor) -->
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>

<main class="container" id="ticket-detail"
  data-ticket-id="<%= ticket.id %>"
  data-comment-count="<%= comments.length %>"
  data-updated-at="<%= ticket.updated_at %>">

  <!-- Back link + copy actions -->
  <div style="margin-bottom:1rem;display:flex;align-items:center;gap:.5rem;flex-wrap:wrap">
    <a href="/tickets" class="btn btn-ghost btn-sm nav-guard">← All Tickets</a>
    <button type="button" class="btn btn-ghost btn-sm" id="copy-url-btn"
            title="Copy ticket URL to clipboard">Copy URL</button>
    <button type="button" class="btn btn-ghost btn-sm" id="copy-email-btn"
            title="Copy reply-to email address">Copy Email</button>
  </div>

  <!-- Ticket header -->
  <div class="ticket-header">
    <div class="ticket-header-top">
      <span class="ticket-num">#<%= formatTicketId(ticket.id) %></span>
      <span class="badge badge-priority-<%= ticket.priority %>" id="badge-priority"><%= ticket.priority %></span>
      <span class="badge badge-status-<%= ticket.status %>" id="badge-status"><%= ticket.status.replace('_',' ') %></span>
    </div>
    <% if (user && user.role === 'admin') { %>
      <form id="subject-form" style="display:flex;align-items:center;gap:.5rem;margin:.25rem 0">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="text" name="subject" id="subject-input"
               value="<%= ticket.subject %>"
               class="form-input ticket-title-input"
               style="font-size:1.4rem;font-weight:700;flex:1;min-width:0">
        <button type="submit" id="subject-save" class="btn btn-sm btn-primary" style="display:none">Save</button>
        <button type="button" id="subject-cancel" class="btn btn-sm btn-ghost" style="display:none">Cancel</button>
      </form>
    <% } else { %>
      <h1 class="ticket-title"><%= ticket.subject %></h1>
    <% } %>
    <div class="ticket-meta-row">
      <span class="meta-item">Created <span data-ts="<%= ticket.created_at %>" data-fmt="full"><%= formatDateFull(ticket.created_at) %></span></span>
      <span class="meta-item">Updated <span data-ts="<%= ticket.updated_at %>"><%= formatDate(ticket.updated_at) %></span></span>
      <span id="due-date-meta" class="meta-item<%= ticket.due_date && ticket.due_date < (Date.now()/1000) ? ' overdue' : '' %>"
            style="<%= ticket.due_date ? '' : 'display:none' %>">Due <span id="due-date-text" data-ts="<%= ticket.due_date || '' %>" data-fmt="date"><%= formatDateOnly(ticket.due_date) %></span></span>
    </div>
  </div>

  <div class="ticket-layout">

    <!-- Left column: body + comments -->
    <div class="ticket-main">

      <!-- Ticket body -->
      <%
        const canEditBody = user && (user.role === 'admin' || (typeof access === 'string' && access === 'owner'));
      %>
      <div style="position:relative">
        <div class="ticket-body rich-content" id="ticket-body-display"><%- ticket.body %></div>
        <% if (canEditBody) { %>
        <button type="button" class="btn-icon btn-icon-danger" id="ticket-body-edit-btn"
                title="Edit ticket body"
                style="position:absolute;top:0;right:0"
                onclick="startEditTicketBody()"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></button>
        <div id="ticket-body-edit-area" style="display:none;margin-top:.5rem">
          <div id="ticket-body-editor" class="quill-editor quill-compact"></div>
          <div style="display:flex;gap:.5rem;margin-top:.5rem">
            <button type="button" class="btn btn-primary btn-sm"
              onclick="saveTicketBody(this)">Save</button>
            <button type="button" class="btn btn-ghost btn-sm"
              onclick="cancelEditTicketBody()">Cancel</button>
            <span id="ticket-body-edit-status" style="font-size:.875rem;align-self:center"></span>
          </div>
        </div>
        <% } %>
      </div>

      <!-- Add comment (above activity) -->
      <div class="comment-form-section">
        <h3 class="section-title">Reply</h3>
        <form method="POST" action="/tickets/<%= ticket.id %>/comments?_csrf=<%= csrfToken %>" enctype="multipart/form-data" id="comment-form">
          <div class="form-group">
            <div id="comment-editor" class="quill-editor quill-compact"></div>
            <input type="hidden" name="body" id="comment-body">
            <p class="form-hint">Use [#x] (where x = ticket number) to insert links to other tickets.</p>
          </div>
          <div class="form-group">
            <div class="attach-stage" id="attach-stage-comment"></div>
            <div id="attach-btnwrap-comment"></div>
            <input type="file" name="attachments" multiple id="attach-input-comment" style="display:none">
          </div>
          <% if (isTechOrAdmin && (enableBillableHours || enableLocation)) { %>
          <div class="form-row" style="gap:.75rem;flex-wrap:wrap;margin-bottom:.5rem">
            <% if (enableBillableHours) { %>
            <div class="form-group" style="flex:0 0 auto;margin-bottom:0">
              <label for="billable-hours">Billable Hours <span class="optional">(optional)</span></label>
              <input type="number" id="billable-hours" name="billable_hours"
                     min="0" step="0.25" placeholder="0.00" class="form-input form-input-sm"
                     style="width:6rem">
            </div>
            <% } %>
            <% if (enableLocation) { %>
            <div class="form-group" style="flex:1 1 200px;margin-bottom:0;position:relative">
              <label for="location-input">Location <span class="optional">(optional)</span></label>
              <input type="text" id="location-input" name="location_name"
                     placeholder="<%= ticket.organization_id ? 'Type or select a location…' : 'No organization assigned' %>"
                     class="form-input form-input-sm"
                     autocomplete="off"
                     data-org-id="<%= ticket.organization_id || '' %>"
                     <%= !ticket.organization_id ? 'disabled' : '' %>>
              <input type="hidden" id="location-id" name="location_id">
            </div>
            <% } %>
          </div>
          <% } %>
          <div class="form-actions" style="flex-wrap:wrap;gap:.5rem">
            <% if (canManage) { %>
              <select name="status_change" class="form-select form-select-sm" style="width:auto">
                <option value=""        <%= ticket.status!=='closed'  ? 'selected':'' %>>Keep status</option>
                <option value="new"     <%= ticket.status==='new'     ? 'disabled':'' %>>New</option>
                <option value="pending" <%= ticket.status==='pending' ? 'disabled':'' %>>Pending</option>
                <option value="open"    <%= ticket.status==='closed'  ? 'selected':'' %> <%= ticket.status==='open' ? 'disabled':'' %>>Open</option>
                <option value="on_hold" <%= ticket.status==='on_hold' ? 'disabled':'' %>>On Hold</option>
                <% if (canClose) { %>
                <option value="closed"  <%= ticket.status==='closed'  ? 'disabled':'' %>>Closed</option>
                <% } %>
              </select>
            <% } %>
            <% if (userVisibilityCap !== 'user') { %>
              <select name="visibility" id="comment-visibility" class="form-select form-select-sm" style="width:auto">
                <option value="user">Visible: All</option>
                <option value="technician">Visible: Tech+</option>
                <% if (userVisibilityCap === 'admin') { %>
                <option value="admin">Visible: Admin only</option>
                <% } %>
              </select>
            <% } else { %>
              <input type="hidden" name="visibility" value="user">
            <% } %>
            <label style="display:flex;align-items:center;gap:.3rem;font-size:.875rem;cursor:pointer;white-space:nowrap">
              <input type="checkbox" name="notify" value="1" checked id="comment-notify"> Notify
            </label>
            <button type="submit" class="btn btn-primary">Post comment</button>
          </div>
        </form>
      </div>

      <!-- All attachments (ticket + comments, grouped here) -->
      <% if (attachments.length) { %>
        <div class="attachments-section">
          <h3 class="section-title">Attachments (<%= attachments.length %>)</h3>
          <ul class="attachment-list">
            <% for (const a of attachments) { %>
              <%
                const _aExt = (a.original_name || '').split('.').pop().toLowerCase();
                const _aAnnotatable = annotationExts.has(_aExt);
              %>
              <li>
                <a href="/tickets/attachments/<%= a.stored_name %>" class="attachment-link" target="_blank">📎 <%= a.original_name %></a>
                <span class="meta-item" style="margin-left:.25rem">(<%= (a.size/1024).toFixed(1) %> KB)</span>
                <span class="meta-item" style="margin-left:.25rem" data-ts="<%= a.created_at %>" data-fmt="full"><%= formatDateFull(a.created_at) %></span>
                <% if (a.uploader_name) { %><span class="meta-item"> — <%= a.uploader_name %></span><% } %>
                <% if (_aAnnotatable) { %>
                  <a href="/tickets/<%= ticket.id %>/attachments/<%= a.stored_name %>/annotate"
                     target="_blank" class="btn-icon" title="Annotate" style="margin-left:.25rem;text-decoration:none">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                  </a>
                <% } %>
                <% if (user && user.role === 'admin') { %>
                  <form method="POST" action="/tickets/attachments/<%= a.stored_name %>/delete" style="display:inline;margin-left:.25rem">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn-icon btn-icon-danger" title="Delete attachment"
                      onclick="return confirm('Permanently delete this attachment?')">×</button>
                  </form>
                <% } %>
              </li>
            <% } %>
          </ul>
        </div>
      <% } %>

      <!-- Comments -->
      <div class="comments-section" id="comments">
        <h2 class="section-title">Activity</h2>

        <% for (const c of comments) { %>
          <%
            const canEditComment = user && (user.role === 'admin' || (c.user_id && c.user_id === user.id));
            const cVis = c.visibility || 'user';
            const canChangeVis = user && (user.role === 'admin' || (c.user_id && c.user_id === user.id)) && userVisibilityCap !== 'user';
            const visLabels = { user: 'All', technician: 'Tech+', admin: 'Admin only' };
          %>
          <div class="comment" id="comment-<%= c.id %>">
            <div class="comment-header">
              <span class="comment-author">
                <% if (c.user_name) { %>
                  <%= c.user_name %><span class="comment-author-sub"><%= c.user_email %></span>
                <% } else { %>
                  <%= c.user_email || 'System' %>
                <% } %>
              </span>
              <% if (c.is_email) { %><span class="badge badge-email">via email</span><% } %>
              <% if (enableBillableHours && isTechOrAdmin && c.billable_hours) { %><span class="badge badge-billing"><%= c.billable_hours %>h</span><% } %>
              <% if (enableLocation && c.location_name) { %><span class="badge badge-location">📍 <%= c.location_name %></span><% } %>
              <% if (canChangeVis) { %>
                <select class="badge-visibility-select badge-visibility-<%= cVis %>"
                        id="vis-select-<%= c.id %>"
                        onchange="changeCommentVisibility(<%= c.id %>, this)">
                  <option value="user"       <%= cVis==='user'       ? 'selected':'' %>>👁 All</option>
                  <option value="technician" <%= cVis==='technician' ? 'selected':'' %>>👁 Tech+</option>
                  <% if (userVisibilityCap === 'admin') { %>
                  <option value="admin"      <%= cVis==='admin'      ? 'selected':'' %>>👁 Admin only</option>
                  <% } %>
                </select>
              <% } else if (cVis !== 'user') { %>
                <span class="badge badge-visibility-<%= cVis %>">👁 <%= visLabels[cVis] %></span>
              <% } %>
              <span class="comment-time" data-ts="<%= c.created_at %>" data-fmt="full"><%= formatDateFull(c.created_at) %></span>
              <% if (canEditComment) { %>
                <button type="button" class="btn-icon btn-icon-danger" title="Edit comment"
                  onclick="startEditComment(<%= c.id %>)" style="margin-left:.5rem"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></button>
              <% } %>
              <% if (user && user.role === 'admin') { %>
                <form method="POST" action="/tickets/<%= ticket.id %>/comments/<%= c.id %>/delete" style="display:inline;margin-left:.25rem">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn-icon btn-icon-danger" title="Delete comment"
                    onclick="return confirm('Permanently delete this comment?')"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg></button>
                </form>
              <% } %>
            </div>
            <div class="comment-body rich-content" id="comment-body-<%= c.id %>"><%- c.body %></div>
            <% if (canEditComment) { %>
            <div class="comment-edit-area" id="comment-edit-<%= c.id %>" style="display:none;margin-top:.75rem">
              <div id="comment-edit-editor-<%= c.id %>" class="quill-editor quill-compact"></div>
              <div style="display:flex;gap:.5rem;margin-top:.5rem">
                <button type="button" class="btn btn-primary btn-sm"
                  onclick="saveEditComment(<%= c.id %>, this)">Save</button>
                <button type="button" class="btn btn-ghost btn-sm"
                  onclick="cancelEditComment(<%= c.id %>)">Cancel</button>
                <span class="comment-edit-status" id="comment-edit-status-<%= c.id %>"
                  style="font-size:.875rem;align-self:center"></span>
              </div>
            </div>
            <% } %>
          </div>
        <% } %>
      </div>

    </div><!-- /.ticket-main -->

    <!-- Right column: sidebar -->
    <aside class="ticket-sidebar">

      <!-- Status -->
      <% if (canManage) { %>
        <div class="sidebar-section">
          <div class="sidebar-label">Status</div>
          <div class="pill-group" id="status-pills">
            <% for (const [sv, sl] of [['new','New'],['pending','Pending'],['open','Open'],['on_hold','On Hold'],['closed','Closed']]) { %>
              <button type="button"
                class="pill-btn pill-status-<%= sv %><%= ticket.status===sv ? ' pill-active' : '' %>"
                data-status="<%= sv %>"><%= sl %></button>
            <% } %>
          </div>
        </div>

        <!-- Priority -->
        <div class="sidebar-section">
          <div class="sidebar-label">Priority</div>
          <div class="pill-group" id="priority-pills">
            <% for (const [pv, pl] of [['urgent','Urgent'],['high','High'],['medium','Medium'],['low','Low']]) { %>
              <button type="button"
                class="pill-btn pill-priority-<%= pv %><%= ticket.priority===pv ? ' pill-active' : '' %>"
                data-priority="<%= pv %>"><%= pl %></button>
            <% } %>
          </div>
        </div>

        <!-- Due date -->
        <div class="sidebar-section">
          <div class="sidebar-label">Due date</div>
          <form id="due-date-form" class="inline-form">
            <input type="date" name="due_date" value="<%= formatDateInput(ticket.due_date) %>" class="form-input form-input-sm">
            <button type="submit" class="btn btn-sm btn-secondary">Set</button>
          </form>
        </div>
      <% } else { %>
        <div class="sidebar-section">
          <div class="sidebar-label">Status</div>
          <span class="badge badge-status-<%= ticket.status %>"><%= ticket.status.replace('_',' ') %></span>
        </div>
        <div class="sidebar-section">
          <div class="sidebar-label">Priority</div>
          <span class="badge badge-priority-<%= ticket.priority %>"><%= ticket.priority %></span>
        </div>
        <% if (ticket.due_date) { %>
          <div class="sidebar-section">
            <div class="sidebar-label">Due date</div>
            <span class="<%= ticket.due_date < (Date.now()/1000) ? 'overdue' : '' %>" data-ts="<%= ticket.due_date || '' %>" data-fmt="date"><%= formatDateOnly(ticket.due_date) %></span>
          </div>
        <% } %>
      <% } %>

      <!-- Organization -->
      <div class="sidebar-section">
        <div class="sidebar-label">Organization</div>
        <% if (canManage) { %>
          <form id="org-form" class="inline-form">
            <div style="position:relative">
              <input type="text" id="org-name-input" name="organization_name"
                     class="form-input form-input-sm"
                     value="<%= ticket.organization_name || '' %>"
                     placeholder="None" autocomplete="off">
            </div>
            <button type="submit" class="btn btn-sm btn-secondary">Set</button>
          </form>
        <% } else { %>
          <span><%= ticket.organization_name || '—' %></span>
        <% } %>
      </div>

      <!-- Billable Hours total (admin only) -->
      <% if (enableBillableHours && user && user.role === 'admin' && ticket.total_billable_hours > 0) { %>
      <div class="sidebar-section">
        <div class="sidebar-label">Billable Hours</div>
        <span class="billing-total"><%= ticket.total_billable_hours.toFixed(2) %> hrs</span>
      </div>
      <% } %>

      <!-- Parties -->
      <div class="sidebar-section">
        <div class="sidebar-label">People</div>
        <ul class="party-list" id="party-list"
            data-can-manage="<%= canManage ? 'true' : 'false' %>"
            data-current-user-id="<%= user.id %>"
            data-ticket-id="<%= ticket.id %>">
          <% for (const p of parties) { %>
            <li class="party-item" data-user-id="<%= p.user_id %>" data-notifications-disabled="<%= p.notifications_disabled ? '1' : '0' %>">
              <div class="party-info">
                <% if (p.name) { %>
                  <span class="party-name"><%= p.name %></span>
                  <a href="mailto:<%= p.email %>" class="party-email-link"><%= p.email %></a>
                <% } else { %>
                  <span class="party-name"><%= p.email %></span>
                <% } %>
                <% if (p.organization_name) { %><span class="party-org">[<%= p.organization_name %>]</span><% } %>
              </div>
              <% if (user && user.role === 'admin') { %>
                <select class="badge badge-role role-select" data-user-id="<%= p.user_id %>" title="Change role">
                  <option value="submitter"    <%= p.role === 'submitter'    ? 'selected' : '' %>>submitter</option>
                  <option value="owner"        <%= p.role === 'owner'        ? 'selected' : '' %>>owner</option>
                  <option value="collaborator" <%= p.role === 'collaborator' ? 'selected' : '' %>>collaborator</option>
                </select>
              <% } else { %>
                <span class="badge badge-role"><%= p.role %></span>
              <% } %>
              <% if (canManage && p.role !== 'submitter') { %>
                <button type="button" class="btn-icon notify-party-btn" data-user-id="<%= p.user_id %>"
                        title="<%= p.notifications_disabled ? 'Enable notifications' : 'Mute notifications' %>">
                  <% if (p.notifications_disabled) { %>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13.73 21a2 2 0 0 1-3.46 0"/><path d="M18.63 13A17.89 17.89 0 0 1 18 8"/><path d="M6.26 6.26A5.86 5.86 0 0 0 6 8c0 7-3 9-3 9h14"/><path d="M18 8a6 6 0 0 0-9.33-5"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                  <% } else { %>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                  <% } %>
                </button>
              <% } %>
              <% if (canManage && p.user_id !== user.id) { %>
                <button type="button" class="btn-icon remove-party-btn" data-user-id="<%= p.user_id %>" title="Remove">×</button>
              <% } %>
            </li>
          <% } %>
        </ul>

        <% if (canManage) { %>
          <details class="add-party-details">
            <summary class="link-btn">+ Add person</summary>
            <form id="add-party-form" class="add-party-form">
              <input type="hidden" name="userId" id="add-party-user-id" value="">
              <div style="position:relative">
                <input type="text" id="add-party-input" name="email"
                       placeholder="Search by name, email, or org…"
                       class="form-input form-input-sm" autocomplete="off">
              </div>
              <select name="role" class="form-select form-select-sm">
                <option value="collaborator">Collaborator</option>
                <option value="owner">Owner</option>
              </select>
              <button type="submit" class="btn btn-sm btn-primary">Add</button>
            </form>
          </details>
        <% } %>
      </div>

      <% if (user && user.role === 'admin') { %>
        <div class="sidebar-section">
          <form method="POST" action="/tickets/<%= ticket.id %>/delete"
            onsubmit="return confirm('Permanently delete this ticket and all its data?')">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-danger btn-full btn-sm">Delete Ticket</button>
          </form>
        </div>
      <% } %>

    </aside><!-- /.ticket-sidebar -->
  </div><!-- /.ticket-layout -->
</main>

<script>
  // Comment editor
  const quill = new Quill('#comment-editor', {
    theme: 'snow',
    placeholder: 'Write a comment… (Ctrl+Enter to submit)',
    modules: {
      toolbar: [
        ['bold', 'italic', 'underline', 'strike'],
        ['blockquote', 'code-block'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        [{ color: [] }, { background: [] }],
        ['link'],
        ['clean'],
      ],
      keyboard: {
        bindings: {
          submitComment: {
            key: 'Enter',
            ctrlKey: true,
            handler() {
              document.getElementById('comment-form').requestSubmit();
            }
          }
        }
      }
    }
  });

  document.getElementById('comment-form').addEventListener('submit', e => {
    // Require comment text
    if (!quill.getText().trim()) {
      e.preventDefault();
      let err = document.getElementById('comment-required-err');
      if (!err) {
        err = document.createElement('p');
        err.id = 'comment-required-err';
        err.className = 'form-hint form-hint-error';
        err.textContent = 'A comment is required.';
        document.getElementById('comment-editor').insertAdjacentElement('afterend', err);
      }
      quill.focus();
      return;
    }
    document.getElementById('comment-required-err')?.remove();

    document.getElementById('comment-body').value = quill.root.innerHTML;
    _quillDirty = false;
  });

  // Clear the required-error when user starts typing
  quill.on('text-change', () => {
    if (quill.getText().trim()) document.getElementById('comment-required-err')?.remove();
  });

  // ---- Comment inline editing ----
  const _editQuills = {};

  function startEditComment(id) {
    const bodyEl = document.getElementById('comment-body-' + id);
    const editEl = document.getElementById('comment-edit-' + id);
    if (!editEl) return;
    bodyEl.style.display = 'none';
    editEl.style.display = '';

    if (!_editQuills[id]) {
      _editQuills[id] = new Quill('#comment-edit-editor-' + id, {
        theme: 'snow',
        modules: {
          toolbar: [
            ['bold', 'italic', 'underline', 'strike'],
            ['blockquote', 'code-block'],
            [{ list: 'ordered' }, { list: 'bullet' }],
            [{ color: [] }, { background: [] }],
            ['link'],
            ['clean'],
          ],
        },
      });
      // Seed with current content
      _editQuills[id].clipboard.dangerouslyPasteHTML(bodyEl.innerHTML);
    }
    _editQuills[id].focus();
  }

  function cancelEditComment(id) {
    document.getElementById('comment-body-' + id).style.display = '';
    document.getElementById('comment-edit-' + id).style.display = 'none';
    document.getElementById('comment-edit-status-' + id).textContent = '';
  }

  async function saveEditComment(id, btn) {
    const q = _editQuills[id];
    if (!q || !q.getText().trim()) return;
    const body = q.root.innerHTML;
    const statusEl = document.getElementById('comment-edit-status-' + id);
    window.spinButton(btn);
    statusEl.textContent = '';
    statusEl.style.color = '';
    try {
      const resp = await fetch('/tickets/<%= ticket.id %>/comments/' + id + '/edit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-CSRF-Token': '<%= csrfToken %>' },
        credentials: 'include',
        body: '_csrf=<%= csrfToken %>&body=' + encodeURIComponent(body),
      });
      const data = await resp.json();
      if (data.ok) {
        document.getElementById('comment-body-' + id).innerHTML = data.body;
        cancelEditComment(id);
      } else {
        statusEl.textContent = data.error || 'Save failed.';
        statusEl.style.color = '#b91c1c';
      }
    } catch (err) {
      statusEl.textContent = 'Save failed: ' + err.message;
      statusEl.style.color = '#b91c1c';
    } finally {
      window.restoreButton(btn);
    }
  }

  // ---- Comment visibility change ----
  async function changeCommentVisibility(id, selectEl) {
    const newVis = selectEl.value;
    const prev = selectEl.dataset.prev || selectEl.querySelector('[selected]')?.value || 'user';
    selectEl.dataset.prev = newVis;
    selectEl.disabled = true;
    try {
      const resp = await fetch('/tickets/<%= ticket.id %>/comments/' + id + '/visibility', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-CSRF-Token': '<%= csrfToken %>' },
        credentials: 'include',
        body: '_csrf=<%= csrfToken %>&visibility=' + encodeURIComponent(newVis),
      });
      const data = await resp.json();
      if (data.ok) {
        selectEl.className = 'badge-visibility-select badge-visibility-' + data.visibility;
        selectEl.dataset.prev = data.visibility;
      } else {
        selectEl.value = selectEl.dataset.prev || prev;
        alert(data.error || 'Failed to update visibility.');
      }
    } catch (err) {
      selectEl.value = selectEl.dataset.prev || prev;
      alert('Failed to update visibility: ' + err.message);
    } finally {
      selectEl.disabled = false;
    }
  }

  // ---- Ticket body inline editing ----
  <% if (canEditBody) { %>
  let _bodyQuill = null;

  function startEditTicketBody() {
    document.getElementById('ticket-body-display').style.display = 'none';
    document.getElementById('ticket-body-edit-btn').style.display = 'none';
    document.getElementById('ticket-body-edit-area').style.display = '';
    if (!_bodyQuill) {
      _bodyQuill = new Quill('#ticket-body-editor', {
        theme: 'snow',
        modules: {
          toolbar: [
            ['bold', 'italic', 'underline', 'strike'],
            ['blockquote', 'code-block'],
            [{ list: 'ordered' }, { list: 'bullet' }],
            [{ color: [] }, { background: [] }],
            ['link'],
            ['clean'],
          ],
        },
      });
      _bodyQuill.clipboard.dangerouslyPasteHTML(document.getElementById('ticket-body-display').innerHTML);
    }
    _bodyQuill.focus();
  }

  function cancelEditTicketBody() {
    document.getElementById('ticket-body-display').style.display = '';
    document.getElementById('ticket-body-edit-btn').style.display = '';
    document.getElementById('ticket-body-edit-area').style.display = 'none';
    document.getElementById('ticket-body-edit-status').textContent = '';
  }

  async function saveTicketBody(btn) {
    if (!_bodyQuill || !_bodyQuill.getText().trim()) return;
    const body = _bodyQuill.root.innerHTML;
    const statusEl = document.getElementById('ticket-body-edit-status');
    window.spinButton(btn);
    statusEl.textContent = '';
    statusEl.style.color = '';
    try {
      const resp = await fetch('/tickets/<%= ticket.id %>/body', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-CSRF-Token': '<%= csrfToken %>' },
        credentials: 'include',
        body: '_csrf=<%= csrfToken %>&body=' + encodeURIComponent(body),
      });
      const data = await resp.json();
      if (data.ok) {
        document.getElementById('ticket-body-display').innerHTML = data.body;
        cancelEditTicketBody();
      } else {
        statusEl.textContent = data.error || 'Save failed.';
        statusEl.style.color = '#b91c1c';
      }
    } catch (err) {
      statusEl.textContent = 'Save failed: ' + err.message;
      statusEl.style.color = '#b91c1c';
    } finally {
      window.restoreButton(btn);
    }
  }
  <% } %>

  // Attachment UI — init after tix.js loads
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof initAttachmentUI === 'function') {
      initAttachmentUI({ stageId: 'attach-stage-comment', inputId: 'attach-input-comment', btnWrapperId: 'attach-btnwrap-comment', prefix: 'comment' });
    }
  });

  // Location autocomplete — init after tix.js loads (tix.js is in foot.ejs, after this block)
  document.addEventListener('DOMContentLoaded', function () {
    const locInput = document.getElementById('location-input');
    if (!locInput) return;

    // fetchUrl reads orgId dynamically so re-init isn't needed when org changes
    createAutocomplete(locInput, {
      fetchUrl:    q => `/api/organizations/${locInput.dataset.orgId}/locations?q=${encodeURIComponent(q)}`,
      formatItem:  l => l.name + (l.distance_miles > 0 ? ' (' + l.distance_miles + ' mi)' : ''),
      onSelect:    l => {
        document.getElementById('location-id').value = l.id;
        locInput.value = l.name;
      },
      showOnFocus: true,
    });
    locInput.addEventListener('input', () => {
      document.getElementById('location-id').value = '';
    });
  });

  // Focus the editor on load — desktop only (mobile focus triggers keyboard)
  if (!('ontouchstart' in window || navigator.maxTouchPoints > 0)) quill.focus();

  // Track whether the Quill editor has unsaved content
  let _quillDirty = false;
  quill.on('text-change', () => {
    _quillDirty = quill.getText().trim().length > 0;
  });

  // Warn before leaving the page if there are unsaved changes
  function _hasUnsavedChanges() {
    if (_quillDirty) return true;
    const subj = document.getElementById('subject-input');
    if (subj && subj.dataset.dirty === 'true') return true;
    return false;
  }

  window.addEventListener('beforeunload', e => {
    if (_hasUnsavedChanges()) {
      e.preventDefault();
      e.returnValue = '';
    }
  });

  // Intercept nav-guard links so they show a friendly confirm dialog
  document.querySelectorAll('a.nav-guard').forEach(a => {
    a.addEventListener('click', e => {
      if (_hasUnsavedChanges()) {
        e.preventDefault();
        if (confirm('You have unsaved changes. Leave anyway?')) {
          _quillDirty = false; // suppress beforeunload
          const subj = document.getElementById('subject-input');
          if (subj) subj.dataset.dirty = '';
          window.location.href = a.href;
        }
      }
    });
  });

</script>
<script>
// Editable ticket title
const _subjectInput  = document.getElementById('subject-input');
const _subjectSave   = document.getElementById('subject-save');
const _subjectCancel = document.getElementById('subject-cancel');
if (_subjectInput) {
  let _original = _subjectInput.value;
  const _setDirty = () => {
    const dirty = _subjectInput.value !== _original;
    _subjectSave.style.display   = dirty ? '' : 'none';
    _subjectCancel.style.display = dirty ? '' : 'none';
    _subjectInput.dataset.dirty  = dirty ? 'true' : '';
  };
  _subjectInput.addEventListener('input', _setDirty);
  _subjectCancel.addEventListener('click', () => {
    _subjectInput.value = _original;
    _setDirty();
  });

  document.getElementById('subject-form').addEventListener('submit', async e => {
    e.preventDefault();
    const subject = _subjectInput.value.trim();
    if (!subject || subject === _original) { _subjectCancel.click(); return; }
    try {
      const res = await fetch(`/tickets/<%= ticket.id %>/subject`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
        body:    new URLSearchParams({ _csrf: '<%= csrfToken %>', subject }),
      });
      const json = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(json.error || 'Failed');
      _original = subject;
      _setDirty(); // hides Save/Cancel, clears dirty flag
      document.title = `#<%= formatTicketId(ticket.id) %> \u2014 ${subject}`;
    } catch (err) { alert('Could not save title: ' + err.message); }
  });
}

document.addEventListener('DOMContentLoaded', () => {
  if (typeof createAutocomplete !== 'function') return;

  // Organization autocomplete on sidebar
  const orgInput = document.getElementById('org-name-input');
  if (orgInput) {
    createAutocomplete(orgInput, {
      fetchUrl: q => `/api/organizations/search?q=${encodeURIComponent(q)}`,
      formatItem: item => `<span>${item.name}</span>`,
      onSelect: item => { orgInput.value = item.name; },
      showOnFocus: true,
    });
  }

  // User autocomplete on add-party form
  const addPartyInput = document.getElementById('add-party-input');
  if (addPartyInput) {
    createAutocomplete(addPartyInput, {
      fetchUrl: q => `/api/users/search?q=${encodeURIComponent(q)}`,
      formatItem: item => {
        const name = item.name ? `<strong>${item.name}</strong> ` : '';
        const org  = item.org  ? ` <em style="color:#6b7280">[${item.org}]</em>` : '';
        return `${name}(${item.email})${org}`;
      },
      onSelect: item => {
        addPartyInput.value = item.name ? `${item.name} <${item.email}>` : item.email;
        document.getElementById('add-party-user-id').value = item.id;
      },
    });
    addPartyInput.addEventListener('input', () => {
      if (!addPartyInput.value.trim()) {
        document.getElementById('add-party-user-id').value = '';
      }
    });

    // Auto-focus the input when the Add Person details panel opens
    const addPartyDetails = document.querySelector('.add-party-details');
    if (addPartyDetails) {
      addPartyDetails.addEventListener('toggle', () => {
        if (addPartyDetails.open) setTimeout(() => addPartyInput.focus(), 50);
      });
    }
  }
});
</script>

<script>
// ============================================================
// Sidebar AJAX actions — no page reload for sidebar changes
// ============================================================
(function() {
  const TICKET_ID          = '<%= ticket.id %>';
  const CSRF               = '<%= csrfToken %>';
  const CAN_MANAGE         = <%= canManage ? 'true' : 'false' %>;
  const CURRENT_USER_ID    = <%= user.id %>;
  const IS_ADMIN           = <%= user.role === 'admin' ? 'true' : 'false' %>;
  const BILLABLE_ENABLED   = <%= enableBillableHours ? 'true' : 'false' %>;

  async function sidebarPost(path, data, spinEl) {
    if (spinEl) window.spinButton(spinEl);
    const body = new URLSearchParams({ _csrf: CSRF, ...data });
    try {
      const res = await fetch(path, {
        method:  'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
        body:    body.toString(),
      });
      const json = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(json.error || `Request failed (${res.status})`);
      return json;
    } finally {
      if (spinEl) window.restoreButton(spinEl);
    }
  }

  function flashBtn(btn, ok) {
    const orig = btn.textContent;
    btn.textContent = ok ? '✓' : '✗';
    setTimeout(() => { btn.textContent = orig; }, 1200);
  }

  // --- Status pills ---
  const _currentStatus = '<%= ticket.status %>';
  document.querySelectorAll('#status-pills .pill-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const sv = btn.dataset.status;
      try {
        await sidebarPost(`/tickets/${TICKET_ID}/status`, { status: sv }, btn);
        document.querySelectorAll('#status-pills .pill-btn').forEach(b => b.classList.remove('pill-active'));
        btn.classList.add('pill-active');
        const badge = document.getElementById('badge-status');
        if (badge) { badge.className = `badge badge-status-${sv}`; badge.textContent = sv.replace(/_/g, ' '); }
      } catch (err) { alert('Could not update status: ' + err.message); }
    });
  });

  // --- Priority pills ---
  document.querySelectorAll('#priority-pills .pill-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const pv = btn.dataset.priority;
      try {
        await sidebarPost(`/tickets/${TICKET_ID}/priority`, { priority: pv }, btn);
        document.querySelectorAll('#priority-pills .pill-btn').forEach(b => b.classList.remove('pill-active'));
        btn.classList.add('pill-active');
        const badge = document.getElementById('badge-priority');
        if (badge) { badge.className = `badge badge-priority-${pv}`; badge.textContent = pv; }
      } catch (err) { alert('Could not update priority: ' + err.message); }
    });
  });

  // --- Due date form ---
  const dueDateForm = document.getElementById('due-date-form');
  if (dueDateForm) {
    dueDateForm.addEventListener('submit', async e => {
      e.preventDefault();
      const input = dueDateForm.querySelector('[name="due_date"]');
      const setBtn = dueDateForm.querySelector('[type="submit"]');
      try {
        const data = await sidebarPost(`/tickets/${TICKET_ID}/due-date`, { due_date: input.value }, setBtn);
        const meta = document.getElementById('due-date-meta');
        if (data.dueDate) {
          const dtEl = document.getElementById('due-date-text');
          dtEl.textContent = fmtTs(data.dueDate, 'date');
          dtEl.dataset.ts = data.dueDate;
          const overdue = data.dueDate < Math.floor(Date.now() / 1000);
          meta.className = 'meta-item' + (overdue ? ' overdue' : '');
          meta.style.display = '';
        } else {
          meta.style.display = 'none';
        }
        flashBtn(setBtn, true);
      } catch (err) { alert('Could not update due date: ' + err.message); }
    });
  }

  // --- Organization form ---
  const orgForm = document.getElementById('org-form');
  if (orgForm) {
    orgForm.addEventListener('submit', async e => {
      e.preventDefault();
      const input  = orgForm.querySelector('[name="organization_name"]');
      const setBtn = orgForm.querySelector('[type="submit"]');
      try {
        const data = await sidebarPost(`/tickets/${TICKET_ID}/organization`, { organization_name: input.value }, setBtn);
        if (data.orgName) input.value = data.orgName; // normalise capitalisation
        flashBtn(setBtn, true);

        // Sync location input with new org
        const locInput = document.getElementById('location-input');
        if (locInput) {
          locInput.dataset.orgId = data.orgId || '';
          locInput.value = '';
          document.getElementById('location-id').value = '';
          const hasOrg = !!data.orgId;
          locInput.disabled = !hasOrg || '<%= ticket.status %>' === 'closed';
          locInput.placeholder = hasOrg ? 'Type or select a location…' : 'No organization assigned';
        }
      } catch (err) { alert('Could not update organization: ' + err.message); }
    });
  }

  // --- Party list helpers ---
  function _esc(s) { return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  const BELL_SVG     = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>`;
  const BELL_OFF_SVG = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13.73 21a2 2 0 0 1-3.46 0"/><path d="M18.63 13A17.89 17.89 0 0 1 18 8"/><path d="M6.26 6.26A5.86 5.86 0 0 0 6 8c0 7-3 9-3 9h14"/><path d="M18 8a6 6 0 0 0-9.33-5"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`;

  function renderPartyItem(p) {
    const muted    = !!p.notificationsDisabled;
    const nameHtml = p.name
      ? `<span class="party-name">${_esc(p.name)}</span><a href="mailto:${_esc(p.email)}" class="party-email-link">${_esc(p.email)}</a>`
      : `<span class="party-name">${_esc(p.email)}</span>`;
    const orgHtml    = p.orgName ? `<span class="party-org">[${_esc(p.orgName)}]</span>` : '';
    const notifyHtml = CAN_MANAGE && p.role !== 'submitter'
      ? `<button type="button" class="btn-icon notify-party-btn" data-user-id="${p.userId}" title="${muted ? 'Enable notifications' : 'Mute notifications'}">${muted ? BELL_OFF_SVG : BELL_SVG}</button>`
      : '';
    const removeHtml = CAN_MANAGE && p.userId !== CURRENT_USER_ID
      ? `<button type="button" class="btn-icon remove-party-btn" data-user-id="${p.userId}" title="Remove">×</button>`
      : '';
    const roleBadge = IS_ADMIN
      ? `<select class="badge badge-role role-select" data-user-id="${p.userId}" title="Change role">
          <option value="submitter"    ${p.role === 'submitter'    ? 'selected' : ''}>submitter</option>
          <option value="owner"        ${p.role === 'owner'        ? 'selected' : ''}>owner</option>
          <option value="collaborator" ${p.role === 'collaborator' ? 'selected' : ''}>collaborator</option>
        </select>`
      : `<span class="badge badge-role">${_esc(p.role)}</span>`;
    return `<li class="party-item" data-user-id="${p.userId}" data-notifications-disabled="${muted ? '1' : '0'}">
      <div class="party-info">${nameHtml}${orgHtml}</div>
      ${roleBadge}
      ${notifyHtml}
      ${removeHtml}
    </li>`;
  }

  // Delegated remove listener — handles both server-rendered and dynamically added rows
  document.getElementById('party-list')?.addEventListener('click', async e => {
    const removeBtn = e.target.closest('.remove-party-btn');
    if (removeBtn) {
      const userId = removeBtn.dataset.userId;
      try {
        await sidebarPost(`/tickets/${TICKET_ID}/parties/remove`, { userId }, removeBtn);
        document.querySelector(`#party-list [data-user-id="${userId}"]`)?.remove();
      } catch (err) { alert('Could not remove person: ' + err.message); }
      return;
    }

    const notifyBtn = e.target.closest('.notify-party-btn');
    if (notifyBtn) {
      const userId = notifyBtn.dataset.userId;
      try {
        const data = await sidebarPost(`/tickets/${TICKET_ID}/parties/notify`, { userId }, notifyBtn);
        const li   = document.querySelector(`#party-list [data-user-id="${userId}"]`);
        if (!li) return;
        const disabled = data.notificationsDisabled;
        li.dataset.notificationsDisabled = disabled ? '1' : '0';
        notifyBtn.title     = disabled ? 'Enable notifications' : 'Mute notifications';
        notifyBtn.innerHTML = disabled ? BELL_OFF_SVG : BELL_SVG;
      } catch (err) { alert('Could not toggle notifications: ' + err.message); }
    }
  });

  // Delegated role-change listener
  document.getElementById('party-list')?.addEventListener('change', async e => {
    const sel = e.target.closest('.role-select');
    if (!sel) return;
    const userId  = sel.dataset.userId;
    const newRole = sel.value;
    const prev    = sel.querySelector('[selected]')?.value || sel.dataset.prev;
    sel.dataset.prev = newRole;
    sel.disabled = true;
    try {
      await sidebarPost(`/tickets/${TICKET_ID}/parties/role`, { userId, role: newRole });
      // update the [selected] attribute so prev tracks correctly on next change
      for (const opt of sel.options) opt.removeAttribute('selected');
      sel.querySelector(`[value="${newRole}"]`)?.setAttribute('selected', '');
    } catch (err) {
      alert('Could not change role: ' + err.message);
      sel.value = prev || sel.querySelector('[selected]')?.value;
    } finally {
      sel.disabled = false;
    }
  });

  // --- Add party form ---
  const addPartyForm = document.getElementById('add-party-form');
  if (addPartyForm) {
    addPartyForm.addEventListener('submit', async e => {
      e.preventDefault();
      const emailInput  = addPartyForm.querySelector('[name="email"]');
      const userIdInput = document.getElementById('add-party-user-id');
      const roleSelect  = addPartyForm.querySelector('[name="role"]');
      const addBtn      = e.submitter || addPartyForm.querySelector('[type=submit]');
      try {
        const data = await sidebarPost(`/tickets/${TICKET_ID}/parties`, {
          userId: userIdInput.value || '',
          email:  emailInput.value  || '',
          role:   roleSelect.value,
        }, addBtn);
        const list = document.getElementById('party-list');
        if (!list.querySelector(`[data-user-id="${data.party.userId}"]`))
          list.insertAdjacentHTML('beforeend', renderPartyItem(data.party));
        emailInput.value  = '';
        userIdInput.value = '';
        addPartyForm.closest('details').open = false;
      } catch (err) { alert('Could not add person: ' + err.message); }
    });
  }

})();
</script>

<script>
// Auto-linkify plain URLs in ticket body and comments
(function linkifyContent() {
  const URL_RE = /https?:\/\/[^\s<>"')\]]+/g;
  document.querySelectorAll('.rich-content').forEach(el => {
    const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        let p = node.parentElement;
        while (p && p !== el) {
          if (p.tagName === 'A' || p.tagName === 'PRE' || p.tagName === 'CODE')
            return NodeFilter.FILTER_REJECT;
          p = p.parentElement;
        }
        return NodeFilter.FILTER_ACCEPT;
      }
    });
    const nodes = [];
    let n;
    while ((n = walker.nextNode())) {
      URL_RE.lastIndex = 0;
      if (URL_RE.test(n.textContent)) nodes.push(n);
    }
    for (const node of nodes) {
      URL_RE.lastIndex = 0;
      const text = node.textContent;
      const frag = document.createDocumentFragment();
      let last = 0, m;
      while ((m = URL_RE.exec(text)) !== null) {
        if (m.index > last) frag.appendChild(document.createTextNode(text.slice(last, m.index)));
        const a = document.createElement('a');
        a.href = m[0]; a.textContent = m[0]; a.target = '_blank'; a.rel = 'noopener noreferrer';
        frag.appendChild(a);
        last = m.index + m[0].length;
      }
      if (last < text.length) frag.appendChild(document.createTextNode(text.slice(last)));
      node.parentNode.replaceChild(frag, node);
    }
  });
})();
</script>

<script>
// Ticket cross-references: replace [#N] with a link to that ticket
document.querySelectorAll('.rich-content').forEach(el => {
  el.innerHTML = el.innerHTML.replace(
    /\[#(\d+)\]/g,
    '<a href="/tickets/$1" class="ticket-ref">#$1</a>'
  );
});
</script>

