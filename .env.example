# Application
PORT=3000
SMTP_PORT=25

# Site name shown in nav bar and login pages (can also be changed in the Settings UI)
SITE_NAME=✅ Tix

# Public URL of this instance — used in all outbound email links
# No trailing slash. Example: https://tickets.yourcompany.com
APP_URL=https://tickets.yourcompany.com

# Security - change this to a long random string in production
JWT_SECRET=change-this-to-a-long-random-string

# OTP brute-force protection
# Max wrong attempts before the code is locked; lockout duration in seconds (default: 5 tries, 5-minute lock)
OTP_MAX_TRIES=5
OTP_LOCKOUT_SECONDS=300

# Inbound email rate limiting — max messages accepted per minute per sender.
# EMAIL_RATE_LIMIT_PER_TICKET: replies to the same ticket from the same address (default: 10)
# EMAIL_RATE_LIMIT_NEW_TICKETS: new ticket creations from the same address (default: 3)
# Set to 0 to disable a limit entirely.
EMAIL_RATE_LIMIT_PER_TICKET=10
EMAIL_RATE_LIMIT_NEW_TICKETS=3

# File upload extension whitelist (comma-separated, no dots).
# Only these types will be accepted. Leave blank to allow all extensions.
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,bmp,pdf,txt,md,csv,zip,doc,docx,xls,xlsx,ppt,pptx

# Extensions to always reject even if listed in the whitelist above.
UPLOAD_BLOCKED_EXTENSIONS=

# The email address that receives new tickets
TICKET_EMAIL=tickets@yourdomain.com

# Optional prefix prepended to all ticket IDs in the UI and emails.
# Example: TICKET_PREFIX=tx54  →  ticket 123 displays as tx54123
# Leave blank for plain numeric IDs.
TICKET_PREFIX=

# Display name used in the From field of all outbound emails (default: Ticketing)
MAIL_FROM_NAME=Ticketing

# Default assignee for inbound/forwarded emails (optional)
DEFAULT_ASSIGNEE_EMAIL=you@yourdomain.com

# This email address always gets admin role
ADMIN_EMAIL=you@yourdomain.com

# Outbound mail transport: mailgun|smtp|gmail (default: mailgun)
MAIL_TRANSPORT=smtp

# SMTP relay — used when MAIL_TRANSPORT=smtp
# port 587 → STARTTLS, port 465 → implicit TLS
SMTP_RELAY_HOST=
SMTP_RELAY_PORT=587
SMTP_RELAY_USER=
SMTP_RELAY_PASS=

# Mailgun — only needed when MAIL_TRANSPORT=mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Gmail API — only needed when MAIL_TRANSPORT=gmail
#
# Goal: send outbound mail FROM tickets@tix.yourdomain.com (a subdomain alias)
# using a Google Workspace account, with no "sent on behalf of" message.
#
# How it works: Gmail API allows sending as any verified "Send As" alias.
# Adding a Workspace subdomain as a domain alias lets Gmail verify the alias
# without requiring a separate SMTP server.
#
# ── Part 1: Google Workspace Admin (one-time, do this first) ──────────────────
#
# 1. Sign in to admin.google.com with a Workspace Super Admin account.
#
# 2. Menu → Account → Domains → Manage domains → Add a domain.
#    - Choose "Add a domain alias of <yourdomain.com>"
#    - Enter your subdomain: tix.yourdomain.com
#    - Click "Add domain & start verification"
#
# 3. Add the DNS TXT verification record shown to your DNS provider.
#    Wait for Google to confirm ownership (can take a few minutes to hours).
#    The domain will show "Verified" when ready.
#
# ── Part 2: Gmail Settings — add the alias as a Send As address ───────────────
#
# 4. Open Gmail as the account that will send the email (e.g. you@yourdomain.com).
#    Go to Settings (gear icon) → See all settings → Accounts tab.
#
# 5. Under "Send mail as", click "Add another email address".
#    - Name: whatever you want recipients to see (e.g. "Tix Support")
#    - Email address: tickets@tix.yourdomain.com
#    - IMPORTANT: leave "Treat as an alias" checked
#    - Click Next Step
#
# 6. On the next screen, choose "Send through Gmail" (not SMTP).
#    This option only appears because the subdomain is a verified Workspace alias.
#    Click "Add Account". No verification email is needed.
#
# 7. The alias now appears under "Send mail as". You can optionally set it as
#    your default, but that is not required for this app.
#
# ── Part 3: Google Cloud Console — enable Gmail API & create credentials ───────
#
# 8. Go to console.cloud.google.com. Create a project (or select one).
#
# 9. APIs & Services → Enable APIs & Services → search "Gmail API" → Enable.
#
# 10. APIs & Services → OAuth consent screen
#     - User type: Internal (Workspace only — no review required)
#     - Fill in app name and support email → Save and Continue
#     - Scopes → Add or Remove Scopes → paste:
#         https://www.googleapis.com/auth/gmail.send
#       → Update → Save and Continue
#
# 11. APIs & Services → Credentials → Create Credentials → OAuth client ID
#     - Application type: Desktop app
#     - Name: anything (e.g. "Tix mailer")
#     - Create → copy the Client ID and Client Secret into this file below.
#
# ── Part 4: Generate the refresh token ────────────────────────────────────────
#
# 12. Set GMAIL_CLIENT_ID and GMAIL_CLIENT_SECRET below, then run:
#       npm run gmail-setup
#     A browser window opens. Sign in as the SAME account you added the alias to
#     (e.g. you@yourdomain.com) and approve access.
#     The refresh token is printed to the terminal — paste it into
#     GMAIL_REFRESH_TOKEN below.
#
# ── Part 5: Configure this file ───────────────────────────────────────────────
#
# 13. Set the values below:
#     MAIL_TRANSPORT=gmail
#     GMAIL_USER      = the Google account that owns the alias (you@yourdomain.com)
#     TICKET_EMAIL    = the alias address (tickets@tix.yourdomain.com)
#     MAIL_FROM_NAME  = display name for the From field (e.g. "Tix Support")
#
# The refresh token does not expire unless revoked or unused for 6+ months.
#
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=you@yourdomain.com

# Data directory inside the container (leave as-is for Docker)
DATA_DIR=/app/data
UPLOADS_DIR=/app/data/uploads
